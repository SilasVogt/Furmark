+  height: 2.7rem;
+  flex: 0 0 auto;
+  place-items: center;
+  border: 1px solid color-mix(in srgb, var(--accent), transparent 50%);
+  border-radius: var(--radius);
+  background: var(--accent-soft);
+  color: var(--accent-strong);
+}
+
+.feature-card-1 .icon-box {
+  background: rgb(85 191 192 / 0.12);
+  color: #8ad8d7;
+}
+
+.workflow-band {
+  padding-block: 5.5rem;
+  border-block: 1px solid var(--line);
+  background:
+    linear-gradient(90deg, color-mix(in srgb, var(--accent-soft), transparent 38%), transparent),
+    var(--surface);
+}
+
+.workflow-grid {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 1px;
+  overflow: hidden;
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  background: var(--line);
+}
+
+.workflow-card {
+  min-width: 0;
+  background: var(--surface-strong);
+  padding: 1.25rem;
+}
+
+.workflow-card svg {
+  margin-bottom: 1.25rem;
+  color: var(--accent-strong);
+}
+
+.security {
+  display: grid;
+  grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
+  align-items: center;
+  gap: 3rem;
+}
+
+.security-copy .icon-box {
+  margin-bottom: 1rem;
+}
+
+.security-panel {
+  display: grid;
+  gap: 0.75rem;
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  background: var(--surface-strong);
+  padding: 1rem;
+}
+
+.safeguard {
+  gap: 0.7rem;
+  border-radius: var(--radius);
+  background: var(--surface-muted);
+  color: var(--ink-soft);
+  padding: 0.9rem;
+}
+
+.safeguard svg {
+  flex: 0 0 auto;
+  color: var(--accent-strong);
+}
+
+.team-layout {
+  display: grid;
+  grid-template-columns: 1.15fr 0.95fr 0.9fr;
+  gap: 1rem;
+}
+
+.team-layout article {
+  min-width: 0;
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  background: var(--surface-strong);
+  padding: 1.25rem;
+}
+
+.team-layout svg {
+  margin-bottom: 1.1rem;
+  color: var(--accent-strong);
+}
+
+.closing {
+  padding-block: 4.5rem;
+  background: var(--panel);
+  color: #edf6f1;
+}
+
+.closing-inner {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 2rem;
+}
+
+.closing h2 {
+  color: #edf6f1;
+}
+
+.closing p {
+  max-width: 36rem;
+  color: #b7c8c1;
+}
+
+.site-footer {
+  background: var(--panel);
+  color: #b7c8c1;
+}
+
+.footer-inner {
+  justify-content: space-between;
+  border-top: 1px solid rgb(255 255 255 / 0.1);
+  padding-block: 1.3rem;
+}
+
+.footer-inner span {
+  color: #edf6f1;
+  font-weight: 760;
+}
+
+.footer-inner a:hover {
+  color: #edf6f1;
+}
+
+@media (prefers-reduced-motion: no-preference) {
+  .hero-copy,
+  .product-frame,
+  .signal-grid,
+  .feature-card,
+  .workflow-card,
+  .security,
+  .team-layout article {
+    animation: rise-in 560ms ease both;
+  }
+
+  .product-frame {
+    animation-delay: 90ms;
+  }
+
+  .feature-card:nth-child(2),
+  .workflow-card:nth-child(2),
+  .team-layout article:nth-child(2) {
+    animation-delay: 70ms;
+  }
+
+  .feature-card:nth-child(3),
+  .workflow-card:nth-child(3),
+  .team-layout article:nth-child(3) {
+    animation-delay: 120ms;
+  }
+
+  .feature-card:nth-child(4),
+  .workflow-card:nth-child(4) {
+    animation-delay: 170ms;
+  }
+}
+
+@keyframes rise-in {
+  from {
+    opacity: 0;
+    transform: translateY(16px);
+  }
+
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+@media (max-width: 980px) {
+  .hero {
+    grid-template-columns: 1fr;
+    gap: 2rem;
+    padding-block: 3.2rem;
+  }
+
+  h1 {
+    max-width: 13ch;
+    font-size: 3.4rem;
+  }
+
+  .hero-text {
+    max-width: 40rem;
+  }
+
+  .feature-grid,
+  .security,
+  .team-layout {
+    grid-template-columns: 1fr;
+  }
+
+  .feature-card-1 {
+    grid-row: auto;
+  }
+
+  .workflow-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 760px) {
+  .section-shell,
+  .nav-shell {
+    width: min(100% - 32px, 1120px);
+  }
+
+  .nav-shell {
+    min-height: 64px;
+  }
+
+  .nav-links {
+    display: none;
+  }
+
+  .brand {
+    font-size: 0.98rem;
+  }
+
+  .nav-cta {
+    min-height: 2.45rem;
+    padding-inline: 0.78rem;
+  }
+
+  .hero {
+    min-height: calc(100dvh - 64px);
+    padding-block: 2.4rem 2rem;
+  }
+
+  h1 {
+    max-width: 12ch;
+    font-size: 2.7rem;
+  }
+
+  h2 {
+    font-size: 2.05rem;
+  }
+
+  .hero-text {
+    font-size: 1rem;
+  }
+
+  .signal-grid,
+  .workflow-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .signal-grid div {
+    padding-inline: 0;
+  }
+
+  .signal-grid div + div {
+    border-left: 0;
+    border-top: 1px solid var(--line);
+  }
+
+  .features,
+  .teams,
+  .security,
+  .workflow-band {
+    padding-block: 4.2rem;
+  }
+
+  .feature-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .feature-card {
+    grid-template-columns: 1fr;
+  }
+
+  .closing-inner {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
+
+@media (max-width: 460px) {
+  .hero-actions,
+  .hero-actions .button,
+  .closing .button {
+    width: 100%;
+  }
+
+  .button {
+    padding-inline: 0.9rem;
+  }
+
+  h1 {
+    font-size: 2.35rem;
+  }
+
+  .product-frame {
+    margin-inline: -0.25rem;
+  }
+}
