{
  "name": "furmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:pages": "tsc -p tsconfig.json --noEmit && FURMARK_RELATIVE_BASE=true vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "bench:dry-run": "tsx scripts/dry-run.ts",
    "bench:run": "tsx scripts/bench-run.ts",
    "bench:score": "tsx scripts/score.ts",
    "bench:sites": "tsx scripts/publish-sites.ts",
    "bench:skill": "tsx scripts/skill.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "playwright": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.33.2"
}
