+          <span>{paused ? "Resume" : "Pause"}</span>
+        </button>
+        {prefersReduced && <span className="motion-note">Reduced motion</span>}
+      </div>
+    </main>
+  );
 }
 
 createRoot(document.getElementById("root")!).render(<App />);
diff --git a/src/style.css b/src/style.css
index 6a6f6bd..830e29b 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,100 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+* {
+  box-sizing: border-box;
+}
+
+html,
+body,
+#root {
+  min-height: 100%;
+}
+
+body {
+  margin: 0;
+  font-family:
+    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
+    sans-serif;
+  background: #041014;
+  color: #f8fafc;
+}
+
+button {
+  font: inherit;
+}
+
+.orbit-field {
+  position: relative;
+  min-height: 100svh;
+  overflow: hidden;
+  background: #041014;
+}
+
+.orbit-field canvas {
+  display: block;
+  width: 100vw;
+  height: 100svh;
+  touch-action: none;
+}
+
+.controls {
+  position: absolute;
+  top: clamp(12px, 2vw, 22px);
+  right: clamp(12px, 2vw, 22px);
+  display: flex;
+  align-items: center;
+  gap: 10px;
+}
+
+.motion-button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-width: 112px;
+  min-height: 44px;
+  gap: 8px;
+  padding: 10px 16px;
+  border: 1px solid rgba(255, 255, 255, 0.3);
+  border-radius: 8px;
+  background: rgba(4, 16, 20, 0.74);
+  color: #f8fafc;
+  cursor: pointer;
+  backdrop-filter: blur(14px);
+}
+
+.motion-button:hover {
+  background: rgba(20, 33, 44, 0.9);
+}
+
+.motion-button:focus-visible {
+  outline: 3px solid #7ee7ff;
+  outline-offset: 3px;
+}
+
+.motion-note {
+  padding: 8px 10px;
+  border: 1px solid rgba(255, 255, 255, 0.22);
+  border-radius: 8px;
+  background: rgba(4, 16, 20, 0.65);
+  color: #d7f7ff;
+  font-size: 0.875rem;
+  white-space: nowrap;
+  backdrop-filter: blur(14px);
+}
+
+@media (max-width: 520px) {
+  .controls {
+    left: 12px;
+    right: 12px;
+    justify-content: space-between;
+  }
+
+  .motion-button {
+    min-width: 104px;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .motion-button,
+  .motion-note {
+    transition: none;
+  }
+}
