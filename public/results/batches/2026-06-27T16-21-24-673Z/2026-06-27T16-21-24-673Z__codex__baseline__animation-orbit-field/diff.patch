+type PointerState = {
+  x: number;
+  y: number;
+  active: boolean;
+};
+
+type Satellite = {
+  angle: number;
+  orbit: number;
+  speed: number;
+  size: number;
+  tilt: number;
+  hue: number;
+  arc: number;
+  phase: number;
+  skew: number;
+};
+
+const satelliteCount = 96;
+const tau = Math.PI * 2;
+
+function seededRandom(seed: number) {
+  const next = Math.sin(seed * 12.9898) * 43758.5453;
+  return next - Math.floor(next);
+}
+
+function createSatellites() {
+  return Array.from({ length: satelliteCount }, (_, index): Satellite => {
+    const seed = index + 1;
+    const lane = index % 12;
+
+    return {
+      angle: seededRandom(seed) * tau,
+      orbit: 0.14 + (lane / 12) * 0.68 + seededRandom(seed + 11) * 0.035,
+      speed: 0.18 + seededRandom(seed + 23) * 0.55,
+      size: 1.1 + seededRandom(seed + 37) * 2.4,
+      tilt: 0.3 + seededRandom(seed + 41) * 0.46,
+      hue: [24, 46, 178, 218, 332][index % 5],
+      arc: 0.18 + seededRandom(seed + 53) * 0.42,
+      phase: seededRandom(seed + 67) * tau,
+      skew: -1 + seededRandom(seed + 79) * 2,
+    };
+  });
+}
