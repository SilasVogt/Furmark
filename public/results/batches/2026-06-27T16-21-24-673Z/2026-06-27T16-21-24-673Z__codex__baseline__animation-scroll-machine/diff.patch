+        aria-label="Scroll-driven assembly line"
+      >
+        <div className="machine-sticky">
+          <div className="machine-shell">
+            <header className="machine-header">
+              <div className="machine-title">
+                <p className="eyebrow">
+                  <Factory aria-hidden="true" size={18} />
+                  Assembly cell 04
+                </p>
+                <h1>Assembly line in motion</h1>
