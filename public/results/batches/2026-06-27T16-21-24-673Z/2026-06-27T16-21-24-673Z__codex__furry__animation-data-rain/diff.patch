+    const y = bar.y + velocity * deltaSeconds;
+    const targetY = Math.max(8, stageHeight - laneStacks[bar.lane] - bar.height);
+
+    if (y >= targetY) {
+      laneStacks[bar.lane] += bar.height + STACK_GAP;
+      return {
+        ...bar,
+        y: targetY,
+        velocity: 0,
+        settled: true,
+        settledAt: now,
+      };
+    }
+
+    return { ...bar, y, velocity };
+  });
+}
