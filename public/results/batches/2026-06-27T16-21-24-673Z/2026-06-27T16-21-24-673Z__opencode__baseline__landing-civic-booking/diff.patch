+            checked={topic === "access"}
+            onChange={() => setTopic("access")}
+          />
+          <label htmlFor="topic-access">Accessibility or accommodation</label>
+        </div>
+        <div className="radio-row">
+          <input
+            id="topic-other"
+            type="radio"
+            name="topic"
+            value="other"
+            checked={topic === "other"}
+            onChange={() => setTopic("other")}
+          />
+          <label htmlFor="topic-other">Something else</label>
+        </div>
+      </fieldset>
+
+      <div className="field" style={{ marginTop: "1rem" }}>
+        <label htmlFor="sf-message">
+          Message <span className="req" aria-hidden="true">*</span>
+          <span className="sr-only">required</span>
+        </label>
+        <span id="sf-message-help" className="help">
+          Tell us what you need. Include an appointment number if you have one.
+        </span>
+        <textarea
+          id="sf-message"
+          name="message"
+          rows={4}
+          required
+          aria-describedby="sf-message-help"
+          aria-required="true"
+        />
+      </div>
+
+      <div className="checkbox-row" style={{ marginTop: "0.5rem" }}>
+        <input
+          id="sf-callback"
+          type="checkbox"
+          checked={needCallback}
+          onChange={(e) => setNeedCallback(e.target.checked)}
+        />
+        <label htmlFor="sf-callback">
+          I would like a phone call back. Standard accessibility supports are
+          available.
+        </label>
+      </div>
+
+      <div className="form-actions">
+        <button type="submit" className="btn btn--primary">
+          Send message
+        </button>
+        {sent && (
+          <span className="form-status" role="status">
+            Thanks. We received your message and will reply within one business
+            day.
+          </span>
+        )}
+      </div>
+    </form>
+  );
 }
 
 createRoot(document.getElementById("root")!).render(<App />);
