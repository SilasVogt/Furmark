+
+      {/* light cone */}
+      <polygon points={conePts} fill={coreColor} opacity="0.16" filter={`url(#${blurId})`} />
+      <polygon points={conePts} fill={coreColor} opacity="0.12" />
+
+      {/* ground shadow */}
+      <ellipse cx={baseCx} cy={groundY + 4} rx="86" ry="9" fill="#000" opacity="0.45" filter={`url(#${blurId})`} />
