+  width: 36px;
+  height: 36px;
+  place-items: center;
+  border: 1px solid var(--line);
+  border-radius: var(--radius-sm);
+  background: var(--surface-low);
+  color: var(--text);
+  cursor: pointer;
+  transition: transform 180ms ease, border-color 180ms ease, color 180ms ease;
+}
+
+.console-actions button:hover {
+  border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
+  color: var(--accent-strong);
+}
+
+.signal-summary {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 1px;
+  border-bottom: 1px solid var(--line);
+  background: var(--line);
+}
+
+.signal-summary div {
+  min-width: 0;
+  padding: 13px 14px;
+  background: var(--surface-low);
+}
+
+.signal-summary span,
+.signal-summary strong {
+  display: block;
+}
+
+.signal-summary strong {
+  margin-top: 3px;
+  color: var(--text);
+  font-family: var(--mono);
+  font-size: 0.88rem;
+  font-weight: 740;
+}
+
+.timeline-list {
+  display: grid;
+  gap: 12px;
+  padding: 16px;
+}
+
+.timeline-event {
+  display: grid;
+  grid-template-columns: 54px 34px minmax(0, 1fr);
+  align-items: start;
+  gap: 10px;
+  min-width: 0;
+  padding: 12px;
+  border: 1px solid var(--line);
+  border-radius: var(--radius-sm);
+  background: var(--surface-low);
+}
+
+.timeline-event time {
+  padding-top: 7px;
+  color: var(--muted);
+  font-family: var(--mono);
+  font-size: 0.8rem;
+}
+
+.event-node {
+  display: grid;
+  width: 32px;
+  height: 32px;
+  place-items: center;
+  border-radius: 10px;
+  background: var(--surface);
+  color: var(--accent-strong);
+}
+
+.tone-alert .event-node {
+  color: var(--danger);
+}
+
+.tone-note .event-node {
+  color: var(--warning);
+}
+
+.tone-resolved .event-node {
+  color: var(--success);
+}
+
+.event-copy {
+  min-width: 0;
+}
+
+.event-copy h3 {
+  margin: 3px 0 0;
+  color: var(--text);
+  font-size: 0.96rem;
+  line-height: 1.25;
+}
+
+.event-copy p {
+  margin: 7px 0 0;
+  color: var(--muted);
+  font-size: 0.86rem;
+  line-height: 1.45;
+}
+
+.audience-strip {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  max-width: 1180px;
+  margin: 0 auto;
+  padding: 0 24px 34px;
+}
+
+.audience-strip div {
+  min-width: 0;
+  padding: 18px 20px;
+  border-top: 1px solid var(--line);
+  border-bottom: 1px solid var(--line);
+}
+
+.audience-strip div + div {
+  border-left: 1px solid var(--line);
+}
+
+.audience-strip strong,
+.audience-strip span {
+  display: block;
+}
+
+.audience-strip strong {
+  font-size: 0.98rem;
+}
+
+.audience-strip span {
+  margin-top: 5px;
+  color: var(--muted);
+  font-size: 0.9rem;
+  line-height: 1.45;
+}
+
+.section {
+  max-width: 1180px;
+  margin: 0 auto;
+  padding: 82px 24px;
+}
+
+.section-intro {
+  max-width: 720px;
+  margin-bottom: 28px;
+}
+
+.section-intro.compact {
+  max-width: 680px;
+}
+
+.section h2,
+.final-cta h2 {
+  max-width: 760px;
+  font-size: clamp(2rem, 4vw, 3.7rem);
+  line-height: 1.02;
+}
+
+.section-intro p,
+.security-copy p,
+.final-cta p {
+  max-width: 650px;
+  margin: 16px 0 0;
+  color: var(--muted);
+  font-size: 1rem;
+  line-height: 1.6;
+}
+
+.feature-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
+  gap: 16px;
+}
+
+.feature-card,
+.workflow-card,
+.control-panel,
+.final-cta {
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+}
+
+.feature-card,
+.workflow-card {
+  min-width: 0;
+  padding: 24px;
+  background: var(--surface);
+}
+
+.feature-card {
+  min-height: 220px;
+}
+
+.feature-wide {
+  grid-row: span 2;
+  background:
+    linear-gradient(145deg, color-mix(in srgb, var(--surface) 75%, var(--accent-soft)), var(--surface-low));
+}
+
+.feature-accent {
+  background: var(--accent-soft);
+  border-color: color-mix(in srgb, var(--accent) 35%, var(--line));
+}
+
+.icon-badge {
+  justify-content: center;
+  width: 38px;
+  height: 38px;
+  border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line));
+  border-radius: 12px;
+  background: color-mix(in srgb, var(--accent-soft) 72%, var(--surface));
+  color: var(--accent-strong);
+}
+
+.feature-card h3,
+.workflow-card h3 {
+  margin: 18px 0 0;
+  font-size: 1.18rem;
+  line-height: 1.25;
+}
+
+.feature-card p,
+.workflow-card p {
+  margin: 10px 0 0;
+  color: var(--muted);
+  line-height: 1.55;
+}
+
+.mini-correlation {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 10px;
+  margin-top: auto;
+  padding-top: 28px;
+}
+
+.mini-correlation div {
+  min-width: 0;
+  padding: 14px;
+  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
+  border-radius: var(--radius-sm);
+  background: color-mix(in srgb, var(--surface) 76%, var(--accent-soft));
+}
+
+.mini-correlation strong {
+  display: block;
+  margin-top: 7px;
+  font-size: 0.9rem;
+  line-height: 1.25;
+}
+
+.export-panel {
+  display: grid;
+  gap: 8px;
+  margin-top: 22px;
+}
+
+.export-panel span {
+  padding: 10px 12px;
+  border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--line));
+  border-radius: var(--radius-sm);
+  background: color-mix(in srgb, var(--surface) 72%, var(--accent-soft));
+  color: var(--text);
+}
+
+.workflow-section {
+  border-top: 1px solid var(--line);
+}
+
+.workflow-grid {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 16px;
+}
+
+.workflow-card {
+  position: relative;
+  min-height: 250px;
+}
+
+.workflow-card:nth-child(even) {
+  margin-top: 28px;
+}
+
+.integration-band {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  max-width: 1180px;
+  margin: 0 auto;
+  padding: 0 24px 34px;
+}
+
+.integration-band > div {
+  min-width: 0;
+  gap: 10px;
+  padding: 18px;
+  border-top: 1px solid var(--line);
+  border-bottom: 1px solid var(--line);
+  color: var(--muted);
+  font-size: 0.92rem;
+  font-weight: 650;
+}
+
+.integration-band > div + div {
+  border-left: 1px solid var(--line);
+}
+
+.security-section {
+  display: grid;
+  grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
+  align-items: center;
+  gap: 32px;
+}
+
+.security-copy {
+  min-width: 0;
+}
+
+.security-copy .icon-badge {
+  margin-bottom: 18px;
+}
+
+.control-panel {
+  overflow: hidden;
+  background: var(--surface);
+}
+
+.control-row {
+  gap: 12px;
+  min-width: 0;
+  padding: 18px 20px;
+  color: var(--text);
+  font-weight: 680;
+}
+
+.control-row + .control-row {
+  border-top: 1px solid var(--line);
+}
+
+.control-row svg {
+  flex: 0 0 auto;
+  color: var(--accent-strong);
+}
+
+.final-cta {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  align-items: center;
+  gap: 24px;
+  max-width: 1180px;
+  margin: 24px auto 0;
+  padding: 34px;
+  background: var(--accent-strong);
+  color: var(--accent-text);
+}
+
+.final-cta svg {
+  color: currentColor;
+}
+
+.final-cta h2,
+.final-cta p {
+  color: currentColor;
+}
+
+.final-cta p {
+  opacity: 0.82;
+}
+
+.final-cta .button-primary {
+  background: var(--surface);
+  color: var(--text);
+}
+
+.final-cta .button-primary:hover {
+  background: var(--surface-low);
+}
+
+.site-footer {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 20px;
+  max-width: 1180px;
+  margin: 0 auto;
+  padding: 34px 24px 42px;
+  color: var(--muted);
+}
+
+.site-footer p {
+  margin: 0;
+  text-align: right;
+}
+
+@media (max-width: 980px) {
+  .hero {
+    grid-template-columns: 1fr;
+    min-height: auto;
+    padding-top: 44px;
+  }
+
+  .hero h1 {
+    max-width: 760px;
+  }
+
+  .feature-grid,
+  .security-section {
+    grid-template-columns: 1fr;
+  }
+
+  .feature-wide {
+    grid-row: auto;
+  }
+
+  .workflow-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .workflow-card:nth-child(even) {
+    margin-top: 0;
+  }
+}
+
+@media (max-width: 760px) {
+  body {
+    overflow-x: hidden;
+  }
+
+  .nav-shell {
+    grid-template-columns: 1fr auto;
+    gap: 10px 14px;
+    padding: 12px 18px;
+  }
+
+  .nav-links {
+    grid-column: 1 / -1;
+    justify-content: flex-start;
+    flex-wrap: wrap;
+    gap: 6px 16px;
+  }
+
+  .nav-links a {
+    padding: 4px 0;
+    font-size: 0.86rem;
+  }
+
+  .hero,
+  .section,
+  .audience-strip,
+  .integration-band,
+  .site-footer {
+    padding-right: 18px;
+    padding-left: 18px;
+  }
+
+  .hero {
+    gap: 32px;
+    padding-top: 34px;
+    padding-bottom: 38px;
+  }
+
+  .hero h1 {
+    font-size: clamp(2.45rem, 12vw, 3.4rem);
+  }
+
+  .console-topbar {
+    align-items: flex-start;
+  }
+
+  .console-actions {
+    gap: 6px;
+  }
+
+  .console-actions button {
+    width: 34px;
+    height: 34px;
+  }
+
+  .signal-summary,
+  .audience-strip,
+  .integration-band {
+    grid-template-columns: 1fr;
+  }
+
+  .audience-strip div + div,
+  .integration-band > div + div {
+    border-left: 0;
+    border-top: 0;
+  }
+
+  .section {
+    padding-top: 64px;
+    padding-bottom: 64px;
+  }
+
+  .mini-correlation,
+  .workflow-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .final-cta {
+    grid-template-columns: 1fr;
+    margin-right: 18px;
+    margin-left: 18px;
+    padding: 24px;
+  }
+
+  .site-footer {
+    flex-direction: column;
+    align-items: flex-start;
+  }
+
+  .site-footer p {
+    text-align: left;
+  }
+}
+
+@media (max-width: 520px) {
+  .nav-cta {
+    padding-right: 12px;
+    padding-left: 12px;
+  }
+
+  .hero-actions {
+    align-items: stretch;
+  }
+
+  .button {
+    min-width: 0;
+  }
+
+  .timeline-list {
+    padding: 10px;
+  }
+
+  .timeline-event {
+    grid-template-columns: 46px 30px minmax(0, 1fr);
+    gap: 8px;
+    padding: 10px;
+  }
+
+  .event-node {
+    width: 30px;
+    height: 30px;
+  }
+
+  .event-copy h3 {
+    font-size: 0.9rem;
+  }
+
+  .event-copy p {
+    font-size: 0.82rem;
+  }
+
+  .feature-card,
+  .workflow-card {
+    padding: 20px;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    transition-duration: 0.01ms !important;
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+  }
+}
