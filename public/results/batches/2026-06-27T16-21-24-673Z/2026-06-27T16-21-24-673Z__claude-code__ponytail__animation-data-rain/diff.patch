@@ -1 +1,15 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root { color-scheme: dark; }
+body { margin: 0; font-family: system-ui, sans-serif; background: #14141a; color: #e8e8ef; }
+main { max-width: 800px; margin: 0 auto; padding: 24px 16px; }
+h1 { font-size: 1.4rem; margin: 0 0 4px; }
+.sub { margin: 0 0 16px; color: #9a9aa8; font-size: .9rem; }
+.controls { display: flex; align-items: center; gap: 16px; margin-bottom: 12px; }
+button { background: #2d2d3a; color: #fff; border: 1px solid #44445a; border-radius: 6px; padding: 6px 14px; font-size: .9rem; cursor: pointer; }
+button:hover { background: #3a3a4d; }
+label { display: flex; align-items: center; gap: 6px; font-size: .9rem; }
+.meta { margin-left: auto; color: #9a9aa8; font-size: .85rem; font-variant-numeric: tabular-nums; }
+canvas { display: block; width: 100%; background: #0c0c11; border: 1px solid #2a2a33; border-radius: 8px; }
+.status { margin-top: 8px; font-family: monospace; font-size: .85rem; color: #cfcfe0; }
+.legend { display: flex; flex-wrap: wrap; gap: 14px; list-style: none; padding: 0; margin: 12px 0 0; font-size: .82rem; color: #b8b8c8; }
+.legend li { display: flex; align-items: center; gap: 6px; }
+.sw { width: 12px; height: 12px; border-radius: 2px; display: inline-block; }
