+.note ul {
+  margin: 0;
+  padding-left: 18px;
+}
+.note li {
+  margin-bottom: 6px;
+}
+
+/* Booking form */
+.book-form {
+  display: grid;
+  gap: 16px;
+  max-width: 640px;
+}
+.field {
+  display: grid;
+  gap: 5px;
+}
+.field label {
+  font-weight: 600;
+  font-size: 0.95rem;
+}
+.field input,
+.field select {
+  font: inherit;
+  color: var(--ink);
+  background: #fff;
+  border: 1px solid var(--line);
+  border-bottom-width: 2px;
+  border-radius: 8px;
+  padding: 10px 12px;
+  width: 100%;
+}
+.field input:focus,
+.field select:focus {
+  outline: none;
+  border-color: var(--brand);
+  box-shadow: 0 0 0 3px rgba(15, 76, 129, 0.18);
+}
+.help {
+  color: var(--muted);
+  font-size: 0.85rem;
+}
+.when {
+  border: 1px solid var(--line);
+  border-radius: 10px;
+  padding: 14px 16px;
+  margin: 0;
+}
+.when legend {
+  font-weight: 600;
+  padding: 0 4px;
+}
+.checks {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
+  gap: 8px;
+  margin-top: 8px;
+}
+.check {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  font-size: 0.95rem;
+  padding: 8px 10px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  cursor: pointer;
+  background: #fff;
+}
+.check:hover {
+  border-color: var(--brand);
+}
+.check.remember {
+  display: flex;
+  background: #f6f9fc;
+}
+.status {
+  margin: 0;
+  font-weight: 600;
+  color: var(--accent);
+  min-height: 1.2em;
+}
+.fineprint {
+  margin: 0;
+  font-size: 0.82rem;
+  color: var(--muted);
+}
+
+/* Contact */
+.contact-list {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  gap: 14px;
+}
+.contact-list li {
+  display: flex;
+  gap: 12px;
+  align-items: flex-start;
+}
+.contact-list svg {
+  width: 22px;
+  height: 22px;
+  color: var(--brand);
+  margin-top: 2px;
+  flex-shrink: 0;
+}
+.contact-list strong {
+  display: block;
+}
+.contact-list a {
+  display: block;
+  text-decoration: none;
+}
+.contact-list small {
+  display: block;
+  color: var(--muted);
+  font-size: 0.85rem;
+}
+
+/* Footer */
+.site-footer {
+  background: #0f1b2d;
+  color: #cdd8ea;
+  padding: 36px 0;
+  margin-top: 24px;
+}
+.footer-grid {
+  display: grid;
+  grid-template-columns: 1fr 1fr 1.2fr;
+  gap: 20px;
+  align-items: start;
+}
+.site-footer a {
+  color: #fff;
+  text-decoration: none;
+  display: block;
+  padding: 3px 0;
+}
+.site-footer a:hover {
+  text-decoration: underline;
+}
+.brand-sm {
+  font-weight: 700;
+  margin: 0 0 4px;
+  color: #fff;
+}
+.muted {
+  color: #9fb0c9;
+  font-size: 0.9rem;
+}
+
+/* Responsive */
+@media (max-width: 820px) {
+  .site-header nav {
+    display: none;
+  }
+  .grid-2 {
+    grid-template-columns: 1fr;
+  }
+  .footer-grid {
+    grid-template-columns: 1fr;
+  }
+}
+@media (max-width: 480px) {
+  .hero-inner {
+    padding: 36px 18px;
+  }
+  .section {
+    padding: 36px 0;
+  }
+  .bar {
+    flex-wrap: wrap;
+  }
+  .cta {
+    margin-left: auto;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  * {
+    transition: none !important;
+    scroll-behavior: auto !important;
+  }
+}
