-import React from "react";
+import React, { useEffect, useRef } from "react";
 import { createRoot } from "react-dom/client";
 import "./style.css";
 
+const stations = [
+  {
+    id: "feed",
+    step: "01",
+    title: "Feed",
+    copy: "Blank housings enter the line on indexed carriers.",
+    x: "8%",
+  },
+  {
+    id: "cut",
+    step: "02",
+    title: "Cut",
+    copy: "A punch trims the profile and opens the center slot.",
+    x: "30%",
+  },
+  {
+    id: "drill",
+    step: "03",
+    title: "Drill",
+    copy: "Twin spindles add mounting holes while the carrier locks.",
+    x: "52%",
+  },
+  {
+    id: "paint",
+    step: "04",
+    title: "Finish",
+    copy: "A spray gantry coats the part and cures the surface.",
+    x: "74%",
+  },
+  {
+    id: "pack",
+    step: "05",
+    title: "Pack",
+    copy: "The finished module drops into a shipping tray.",
+    x: "93%",
+  },
+];
+
+const clamp = (value: number) => Math.min(1, Math.max(0, value));
+
+const ramp = (value: number, start: number, end: number) =>
+  clamp((value - start) / (end - start));
+
+const pulse = (value: number, center: number, width: number) =>
+  clamp(1 - Math.abs(value - center) / width);
+
+function useAssemblyProgress() {
+  const ref = useRef<HTMLElement | null>(null);
+
+  useEffect(() => {
+    const scene = ref.current;
+    if (!scene) return;
+
+    const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
+    let frame = 0;
+
+    const writeStaticState = () => {
+      scene.style.setProperty("--progress-width", "100%");
+      scene.style.setProperty("--carrier-left", "93%");
+      scene.style.setProperty("--belt-offset", "0px");
+      scene.style.setProperty("--feed-rotation", "0deg");
+      scene.style.setProperty("--cut-head-y", "0px");
+      scene.style.setProperty("--drill-head-y", "0px");
+      scene.style.setProperty("--pack-jaw-y", "0px");
+      scene.style.setProperty("--cut-done", "1");
+      scene.style.setProperty("--drill-done", "1");
+      scene.style.setProperty("--paint-done", "1");
+      scene.style.setProperty("--pack-done", "1");
+      scene.style.setProperty("--spark-opacity", "0");
+      scene.style.setProperty("--spray-opacity", "0");
+      scene.style.setProperty("--part-scale", "1");
+      scene.dataset.phase = "all";
+    };
+
+    const update = () => {
+      frame = 0;
+
+      if (motionQuery.matches) {
+        writeStaticState();
+        return;
+      }
+
+      const rect = scene.getBoundingClientRect();
+      const viewport = window.innerHeight || 1;
+      const travel = Math.max(rect.height - viewport, 1);
+      const progress = clamp(-rect.top / travel);
+      const cutPulse = pulse(progress, 0.28, 0.08);
+      const drillPulse = pulse(progress, 0.5, 0.08);
+      const paintPulse = pulse(progress, 0.72, 0.1);
+      const packPulse = pulse(progress, 0.9, 0.08);
+      const phase = Math.min(stations.length - 1, Math.floor(progress * stations.length));
+
+      scene.style.setProperty("--progress-width", `${Math.round(progress * 1000) / 10}%`);
+      scene.style.setProperty("--carrier-left", `${8 + progress * 85}%`);
+      scene.style.setProperty("--belt-offset", `${progress * 180}px`);
+      scene.style.setProperty("--feed-rotation", `${progress * 900}deg`);
+      scene.style.setProperty("--cut-head-y", `${cutPulse * 34}px`);
+      scene.style.setProperty("--drill-head-y", `${drillPulse * 32}px`);
+      scene.style.setProperty("--pack-jaw-y", `${packPulse * 18}px`);
+      scene.style.setProperty("--cut-done", `${ramp(progress, 0.28, 0.38)}`);
+      scene.style.setProperty("--drill-done", `${ramp(progress, 0.5, 0.58)}`);
+      scene.style.setProperty("--paint-done", `${ramp(progress, 0.68, 0.78)}`);
+      scene.style.setProperty("--pack-done", `${ramp(progress, 0.88, 0.97)}`);
+      scene.style.setProperty("--spark-opacity", `${Math.max(cutPulse, drillPulse)}`);
+      scene.style.setProperty("--spray-opacity", `${paintPulse}`);
+      scene.style.setProperty("--part-scale", `${1 + packPulse * 0.04}`);
+      scene.dataset.phase = String(phase);
+    };
+
+    const schedule = () => {
+      if (frame) return;
+      frame = window.requestAnimationFrame(update);
+    };
+
+    window.addEventListener("scroll", schedule, { passive: true });
+    window.addEventListener("resize", schedule);
+    motionQuery.addEventListener("change", schedule);
+    schedule();
+
+    return () => {
+      if (frame) window.cancelAnimationFrame(frame);
+      window.removeEventListener("scroll", schedule);
+      window.removeEventListener("resize", schedule);
+      motionQuery.removeEventListener("change", schedule);
+    };
+  }, []);
+
+  return ref;
+}
+
+function StationTool({ station }: { station: (typeof stations)[number] }) {
+  return (
+    <div
+      className={`station-tool station-${station.id}`}
+      style={{ "--station-x": station.x } as React.CSSProperties}
+    >
+      <span className="station-step">{station.step}</span>
+      <div className="tool-column" />
+      <div className="tool-head">
+        <span />
+      </div>
+    </div>
+  );
+}
+
+function PartVisual({ variant = "active" }: { variant?: "active" | "small" }) {
+  return (
+    <div className={`part part-${variant}`}>
+      <span className="part-blank" />
+      <span className="part-slot" />
+      <span className="part-hole part-hole-left" />
+      <span className="part-hole part-hole-right" />
+      <span className="part-coat" />
+      <span className="part-box" />
+    </div>
+  );
+}
+
+function Machine() {
+  return (
+    <section
+      className="machine-panel"
+      aria-label="Assembly machine animation with feed, cut, drill, finish, and pack stations"
+    >
+      <div className="machine-hud">
+        <div>
+          <span className="eyebrow">Line A7</span>
+          <strong>Indexed assembly run</strong>
+        </div>
+        <div className="hud-meter" aria-hidden="true">
+          <span />
+        </div>
+      </div>
+
+      <div className="machine" aria-hidden="true">
+        <div className="overhead-rail" />
+        <div className="station-bank">
+          {stations.map((station) => (
+            <StationTool station={station} key={station.id} />
+          ))}
+        </div>
+
+        <div className="spark-field">
+          <span />
+          <span />
+          <span />
+        </div>
+
+        <div className="spray-field">
+          <span />
+          <span />
+          <span />
+        </div>
+
+        <div className="belt">
+          <div className="belt-slats" />
+          <div className="belt-fill" />
+        </div>
+
+        <div className="carrier">
+          <div className="carrier-bed" />
+          <PartVisual />
+        </div>
+
+        <div className="static-parts">
+          {stations.map((station) => (
+            <div className="static-part" style={{ "--station-x": station.x } as React.CSSProperties} key={station.id}>
+              <PartVisual variant="small" />
+            </div>
+          ))}
+        </div>
+      </div>
+    </section>
+  );
+}
+
+function StationCards() {
+  return (
+    <ol className="stage-list" aria-label="Assembly stations">
+      {stations.map((station) => (
+        <li className="stage-card" key={station.id}>
+          <span>{station.step}</span>
+          <div>
+            <h3>{station.title}</h3>
+            <p>{station.copy}</p>
+          </div>
+        </li>
+      ))}
+    </ol>
+  );
+}
+
 function App() {
-  return <main><h1>Furmark task workspace</h1></main>;
+  const sceneRef = useAssemblyProgress();
+
+  return (
+    <main className="page">
+      <section className="intro">
+        <div className="intro-copy">
+          <span className="eyebrow">Assembly sequence</span>
+          <h1>Machine line in motion</h1>
+          <p>
+            A raw housing rides through feed, cutting, drilling, finishing, and packing stations while the
+            line advances.
+          </p>
+        </div>
+      </section>
+
+      <section className="factory-scroll" ref={sceneRef} data-phase="0">
+        <div className="factory-stage">
+          <div className="factory-grid">
+            <Machine />
+            <StationCards />
+          </div>
+        </div>
+      </section>
+
+      <section className="process-map">
+        <span className="eyebrow">Station map</span>
+        <h2>Same line, static view</h2>
+        <p>
+          Each station keeps the same production step visible, from the first blank housing to the packed
+          finished module.
+        </p>
+        <StationCards />
+      </section>
+    </main>
+  );
 }
 
 createRoot(document.getElementById("root")!).render(<App />);
