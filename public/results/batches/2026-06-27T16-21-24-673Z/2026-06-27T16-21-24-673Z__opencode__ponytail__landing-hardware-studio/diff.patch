+
+// ponytail: 3-anchor lerp, accurate enough for a preview glow; full blackbody curve unnecessary here
+function kelvin(k: number): [number, number, number] {
+  const stops: [number, [number, number, number]][] = [
+    [2700, [255, 179, 71]],
+    [4500, [255, 232, 200]],
+    [6500, [200, 224, 255]],
+  ];
+  if (k <= stops[0][0]) return stops[0][1];
+  if (k >= stops[2][0]) return stops[2][1];
+  const i = k < stops[1][0] ? 0 : 1;
+  const [k0, c0] = stops[i];
+  const [k1, c1] = stops[i + 1];
+  const t = (k - k0) / (k1 - k0);
+  return [
+    Math.round(c0[0] + (c1[0] - c0[0]) * t),
+    Math.round(c0[1] + (c1[1] - c0[1]) * t),
+    Math.round(c0[2] + (c1[2] - c0[2]) * t),
+  ];
+}
+const rgba = (c: [number, number, number], a: number) => `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${a})`;
