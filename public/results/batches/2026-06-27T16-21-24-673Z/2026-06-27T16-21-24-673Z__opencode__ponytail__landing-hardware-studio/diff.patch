+  // head drops to lens
+  const lensCx = head.x;
+  const lensCy = head.y + 46;
+
+  const conePts = [
+    `${lensCx - 9},${lensCy}`,
+    `${lensCx + 9},${lensCy}`,
+    `${lensCx + spread / 2},${groundY}`,
+    `${lensCx - spread / 2},${groundY}`,
+  ].join(" ");
+
+  const coreColor = rgba(c, 1);
+  const haloId = "halo";
+  const blurId = "soft";
+
+  return (
+    <svg className="lamp" viewBox="0 0 400 460" role="img" aria-label={`Arcwell lamp with ${ARMS[arm].label.toLowerCase()} arm, ${LENSES[lens].label.toLowerCase()} lens, ${b.label.toLowerCase()} base`}>
+      <defs>
+        <radialGradient id={haloId} cx="50%" cy="50%" r="50%">
