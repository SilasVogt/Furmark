@@ -1 +1,107 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  color-scheme: dark;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html,
+body,
+#root {
+  height: 100%;
+}
+
+body {
+  margin: 0;
+  font-family: system-ui, sans-serif;
+  background: #05070f;
+  color: #e7ecff;
+}
+
+main {
+  display: flex;
+  flex-direction: column;
+  gap: 12px;
+  padding: 16px;
+  height: 100%;
+}
+
+h1 {
+  margin: 0;
+  font-size: 1.05rem;
+  letter-spacing: 0.04em;
+  text-transform: uppercase;
+  color: #9fb4ff;
+}
+
+.orbit-stage {
+  position: relative;
+  flex: 1;
+  min-height: 320px;
+  border-radius: 14px;
+  overflow: hidden;
+  border: 1px solid rgba(160, 180, 255, 0.18);
+  background: #070a19;
+  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45) inset;
+}
+
+.orbit-canvas {
+  display: block;
+  width: 100%;
+  height: 100%;
+  touch-action: none;
+}
+
+.orbit-controls {
+  position: absolute;
+  left: 12px;
+  bottom: 12px;
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  padding: 8px 10px;
+  border-radius: 10px;
+  background: rgba(10, 14, 30, 0.72);
+  border: 1px solid rgba(160, 180, 255, 0.18);
+  backdrop-filter: blur(6px);
+}
+
+.orbit-btn {
+  appearance: none;
+  border: 1px solid rgba(160, 180, 255, 0.4);
+  background: linear-gradient(180deg, #2a3578, #1a2150);
+  color: #fff;
+  font: inherit;
+  font-size: 0.9rem;
+  font-weight: 600;
+  padding: 6px 14px;
+  border-radius: 8px;
+  cursor: pointer;
+  min-width: 84px;
+}
+
+.orbit-btn:hover:not(:disabled) {
+  border-color: #9fb4ff;
+}
+
+.orbit-btn:focus-visible {
+  outline: 2px solid #9fb4ff;
+  outline-offset: 2px;
+}
+
+.orbit-btn:disabled {
+  opacity: 0.5;
+  cursor: not-allowed;
+}
+
+.orbit-status {
+  font-size: 0.82rem;
+  color: #c2cdf7;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .orbit-status {
+    font-style: italic;
+  }
+}
