+      <circle cx={elbow.x} cy={elbow.y} r="3" fill="#1c1f24" />
+
+      {/* upper arm */}
+      <line x1={elbow.x} y1={elbow.y} x2={head.x} y2={head.y} stroke="url(#metal)" strokeWidth="10" strokeLinecap="round" />
+      <circle cx={head.x} cy={head.y} r="7" fill="#6b727c" />
+
+      {/* head housing */}
+      <line x1={head.x} y1={head.y} x2={lensCx} y2={lensCy} stroke="#2c3138" strokeWidth="15" strokeLinecap="round" />
+
+      {/* lens */}
+      {lens === "spot" && (
+        <>
+          <circle cx={lensCx} cy={lensCy} r="9.5" fill="#16181c" stroke="#3a3f47" strokeWidth="1.5" />
+          <circle cx={lensCx} cy={lensCy} r="6" fill={coreColor} />
+        </>
+      )}
+      {lens === "flood" && (
+        <>
+          <ellipse cx={lensCx} cy={lensCy} rx="16" ry="7.5" fill="#16181c" stroke="#3a3f47" strokeWidth="1.5" />
+          <ellipse cx={lensCx} cy={lensCy} rx="12" ry="4.5" fill={coreColor} />
