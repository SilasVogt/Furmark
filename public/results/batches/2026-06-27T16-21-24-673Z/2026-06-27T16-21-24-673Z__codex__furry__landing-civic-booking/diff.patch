+.service-grid {
+  display: grid;
+  grid-template-columns: 1.08fr 0.92fr;
+  gap: 1rem;
+}
+
+.service-card {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 1rem;
+  min-height: 13rem;
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  background: var(--surface);
+  padding: clamp(1rem, 2vw, 1.3rem);
+}
+
+.service-card:first-child {
+  grid-row: span 2;
+  background:
+    linear-gradient(135deg, var(--accent-soft), transparent 65%),
+    var(--surface);
+}
+
+.service-card:nth-child(3) {
+  background: var(--surface-soft);
+}
+
+.service-card p,
+.commitment p,
+.visit-list p {
+  color: var(--muted);
+}
+
+.service-card span {
+  display: block;
+  margin-top: 0.85rem;
+  color: var(--accent-strong);
+  font-size: 0.92rem;
+  font-weight: 800;
+}
+
+.card-icon,
+.visit-icon {
+  display: grid;
+  width: 3rem;
+  height: 3rem;
+  place-items: center;
+  border-radius: var(--radius-small);
+  background: var(--accent-soft);
+  color: var(--accent-strong);
+}
+
+.availability {
+  border-top: 1px solid var(--line);
+  border-bottom: 1px solid var(--line);
+}
+
+.availability-layout {
+  display: grid;
+  grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
+  align-items: start;
+  gap: clamp(1.5rem, 5vw, 4rem);
+}
+
+.availability-panel {
+  padding: clamp(1rem, 2.2vw, 1.35rem);
+}
+
+.panel-topline {
+  display: flex;
+  align-items: center;
+  gap: 0.6rem;
+  margin-bottom: 1rem;
+  color: var(--accent-strong);
+  font-weight: 850;
+}
+
+.availability-panel ul,
+.visit-list {
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+
+.availability-panel li {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 0.7rem;
+  padding: 0.8rem 0;
+  border-top: 1px solid var(--line);
+}
+
+.availability-panel li svg {
+  color: var(--accent-strong);
+  margin-top: 0.15rem;
+}
+
+.visit-list {
+  display: grid;
+  grid-template-columns: 1.25fr 0.9fr 1fr;
+  gap: 1rem;
+  counter-reset: visit;
+}
+
+.visit-list li {
+  display: grid;
+  gap: 0.85rem;
+  align-content: start;
+  min-height: 14rem;
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  background: var(--surface);
+  padding: clamp(1rem, 2vw, 1.35rem);
+}
+
+.visit-list li:nth-child(2) {
+  margin-top: 2rem;
+  background: var(--surface-soft);
+}
+
+.commitment-grid {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 1rem;
+}
+
+.commitment {
+  border-top: 4px solid var(--accent);
+  border-radius: var(--radius);
+  background: var(--surface);
+  padding: 1.2rem;
+}
+
+.commitment svg {
+  color: var(--accent-strong);
+  margin-bottom: 1rem;
+}
+
+.support {
+  display: grid;
+  grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
+  align-items: start;
+  gap: clamp(1.5rem, 5vw, 4rem);
+}
+
+.contact-methods {
+  display: grid;
+  gap: 0.8rem;
+  margin-top: 1.4rem;
+  font-style: normal;
+}
+
+.contact-methods a,
+.contact-methods span {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.65rem;
+  width: fit-content;
+  color: var(--ink);
+  font-weight: 700;
+}
+
+.contact-methods svg {
+  color: var(--accent-strong);
+  flex: 0 0 auto;
+}
+
+.support-form {
+  display: grid;
+  gap: 1rem;
+  padding: clamp(1rem, 2.2vw, 1.35rem);
+}
+
+.site-footer {
+  border-top: 1px solid var(--line);
+  color: var(--muted);
+}
+
+.footer-inner {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  width: min(1180px, calc(100% - 2rem));
+  margin: 0 auto;
+  padding: 1.35rem 0;
+}
+
+.footer-inner p {
+  margin: 0;
+}
+
+.footer-inner a {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.35rem;
+  color: var(--accent-strong);
+  font-weight: 800;
+  text-decoration: none;
+  white-space: nowrap;
+}
+
+@media (prefers-reduced-motion: no-preference) {
+  html {
+    scroll-behavior: smooth;
+  }
+
+  a,
+  button,
+  input,
+  select,
+  textarea,
+  .service-card,
+  .visit-list li,
+  .commitment {
+    transition:
+      border-color 180ms ease,
+      box-shadow 180ms ease,
+      color 180ms ease,
+      transform 180ms ease,
+      background-color 180ms ease;
+  }
+
+  .header-action:hover,
+  .primary-button:hover,
+  .secondary-button:hover,
+  .service-card:hover,
+  .visit-list li:hover,
+  .commitment:hover {
+    transform: translateY(-1px);
+  }
+
+  .header-action:active,
+  .primary-button:active,
+  .secondary-button:active {
+    transform: translateY(1px);
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  html {
+    scroll-behavior: auto;
+  }
+
+  *,
+  *::before,
+  *::after {
+    transition-duration: 0.01ms !important;
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+  }
+}
+
+@media (max-width: 920px) {
+  .header-inner {
+    grid-template-columns: 1fr auto;
+  }
+
+  .primary-nav {
+    grid-column: 1 / -1;
+    grid-row: 2;
+    justify-content: flex-start;
+    overflow-x: auto;
+    padding-bottom: 0.7rem;
+  }
+
+  .hero,
+  .availability-layout,
+  .support {
+    grid-template-columns: 1fr;
+  }
+
+  .hero {
+    min-height: auto;
+  }
+
+  .hero-media {
+    order: -1;
+  }
+
+  .hero-media img {
+    max-height: 22rem;
+  }
+
+  .service-grid,
+  .visit-list,
+  .commitment-grid {
+    grid-template-columns: 1fr 1fr;
+  }
+
+  .service-card:first-child {
+    grid-row: auto;
+    grid-column: 1 / -1;
+  }
+
+  .visit-list li:nth-child(2) {
+    margin-top: 0;
+  }
+}
+
+@media (max-width: 640px) {
+  .header-inner {
+    width: min(100% - 1rem, 1180px);
+    gap: 0.7rem;
+    min-height: 68px;
+  }
+
+  .brand span:last-child {
+    font-size: 0.98rem;
+  }
+
+  .header-action {
+    padding-inline: 0.85rem;
+  }
+
+  .section-shell {
+    width: min(100% - 1rem, 1180px);
+    padding: 2.7rem 0;
+  }
+
+  .hero {
+    padding-top: 1.5rem;
+  }
+
+  h1 {
+    max-width: 12ch;
+    font-size: clamp(2.35rem, 14vw, 3.6rem);
+  }
+
+  h2 {
+    font-size: clamp(1.75rem, 9vw, 2.4rem);
+  }
+
+  .form-grid,
+  .service-grid,
+  .visit-list,
+  .commitment-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .booking-form,
+  .support-form,
+  .availability-panel,
+  .service-card,
+  .visit-list li,
+  .commitment {
+    padding: 1rem;
+  }
+
+  .primary-button,
+  .secondary-button {
+    width: 100%;
+  }
+
+  .hero-media img {
+    max-height: 16rem;
+  }
+
+  .footer-inner {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
