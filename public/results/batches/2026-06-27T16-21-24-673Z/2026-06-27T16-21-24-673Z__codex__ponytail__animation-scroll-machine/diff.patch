diff --git a/src/main.tsx b/src/main.tsx
index eedf3e8..f3a738e 100644
--- a/src/main.tsx
+++ b/src/main.tsx
@@ -2,8 +2,185 @@ import React from "react";
 import { createRoot } from "react-dom/client";
 import "./style.css";
 
+const stations = [
+  ["feed", 0],
+  ["stamp", 0.28],
+  ["drill", 0.5],
+  ["inspect", 0.72],
+  ["pack", 0.94],
+] as const;
+
+const steps = [
+  ["Feed", "Blank parts drop from the hopper onto the belt."],
+  ["Stamp", "The press forms the outer shell."],
+  ["Drill", "The spindle opens two mounting holes."],
+  ["Inspect", "The camera checks alignment before release."],
+  ["Pack", "Approved parts roll into the shipping tray."],
+] as const;
+
 function App() {
-  return <main><h1>Furmark task workspace</h1></main>;
+  const sceneRef = React.useRef<HTMLElement>(null);
+
+  React.useEffect(() => {
+    const scene = sceneRef.current;
+    if (!scene) return;
+
+    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
+    let frame = 0;
+    let watching = false;
+
+    const clamp = (value: number) => Math.min(1, Math.max(0, value));
+    const smooth = (value: number) => value * value * (3 - 2 * value);
+    const ramp = (start: number, end: number, value: number) =>
+      smooth(clamp((value - start) / (end - start)));
+
+    const paint = () => {
+      const rect = scene.getBoundingClientRect();
+      const distance = Math.max(1, rect.height - window.innerHeight);
+      const progress = clamp(-rect.top / distance);
+      const panel = scene.querySelector<HTMLElement>(".machine-panel");
+      const travel = Math.max(180, (panel?.clientWidth ?? scene.clientWidth) * 0.78 - 64);
+
+      scene.style.setProperty("--progress", progress.toFixed(4));
+      scene.style.setProperty("--part-x", `${Math.round(progress * travel)}px`);
+      scene.style.setProperty("--formed", ramp(0.2, 0.36, progress).toFixed(4));
+      scene.style.setProperty("--drilled", ramp(0.42, 0.56, progress).toFixed(4));
+      scene.style.setProperty("--checked", ramp(0.64, 0.76, progress).toFixed(4));
+      scene.style.setProperty("--boxed", ramp(0.82, 0.94, progress).toFixed(4));
+
+      for (const [name, center] of stations) {
+        scene.style.setProperty(`--${name}`, smooth(clamp(1 - Math.abs(progress - center) / 0.18)).toFixed(4));
+      }
+    };
+
+    const requestPaint = () => {
+      if (frame) return;
+      frame = requestAnimationFrame(() => {
+        frame = 0;
+        paint();
+      });
+    };
+
+    const stop = () => {
+      if (!watching) return;
+      watching = false;
+      window.removeEventListener("scroll", requestPaint);
+      window.removeEventListener("resize", requestPaint);
+      if (frame) cancelAnimationFrame(frame);
+      frame = 0;
+    };
+
+    const start = () => {
+      if (watching) return;
+      watching = true;
+      window.addEventListener("scroll", requestPaint, { passive: true });
+      window.addEventListener("resize", requestPaint);
+      requestPaint();
+    };
+
+    const configureMotion = () => {
+      if (!reducedMotion.matches) {
+        start();
+        return;
+      }
+
+      stop();
+      scene.style.setProperty("--progress", "1");
+      scene.style.setProperty("--part-x", "0px");
+      for (const [name] of stations) scene.style.setProperty(`--${name}`, "1");
+      for (const name of ["formed", "drilled", "checked", "boxed"]) scene.style.setProperty(`--${name}`, "1");
+    };
+
+    configureMotion();
+    reducedMotion.addEventListener("change", configureMotion);
+
+    return () => {
+      stop();
+      reducedMotion.removeEventListener("change", configureMotion);
+    };
+  }, []);
+
+  return (
+    <main>
+      <section className="intro">
+        <p className="eyebrow">Assembly line</p>
+        <h1>One part moves through five machine stations.</h1>
+      </section>
+
+      <section className="scroll-scene" ref={sceneRef} aria-labelledby="machine-title">
+        <div className="machine-sticky">
+          <div className="copy">
+            <p className="eyebrow">Line progress</p>
+            <h2 id="machine-title">Feed, stamp, drill, inspect, pack.</h2>
+          </div>
+
+          <div
+            className="machine-panel"
+            role="img"
+            aria-label="A conveyor machine moves a part through feed, stamp, drill, inspection, and pack stations."
+          >
+            <div className="progress-track" aria-hidden="true">
+              <span />
+            </div>
+
+            <div className="stations" aria-hidden="true">
+              <div className="station station-feed">
+                <span>01 Feed</span>
+                <div className="hopper" />
+              </div>
+              <div className="station station-stamp">
+                <span>02 Stamp</span>
+                <div className="press">
+                  <b />
+                </div>
+              </div>
+              <div className="station station-drill">
+                <span>03 Drill</span>
+                <div className="drill">
+                  <b />
+                </div>
+              </div>
+              <div className="station station-inspect">
+                <span>04 Inspect</span>
+                <div className="scanner" />
+              </div>
+              <div className="station station-pack">
+                <span>05 Pack</span>
+                <div className="tray" />
+              </div>
+            </div>
+
+            <div className="conveyor" aria-hidden="true">
+              <i />
+              <i />
+              <i />
+              <i />
+              <i />
+              <div className="part">
+                <span className="cap" />
+                <span className="hole hole-a" />
+                <span className="hole hole-b" />
+                <span className="check" />
+              </div>
+            </div>
+          </div>
+
+          <ol className="step-list" aria-label="Assembly sequence">
+            {steps.map(([title, text]) => (
+              <li key={title}>
+                <strong>{title}</strong>
+                <span>{text}</span>
+              </li>
+            ))}
+          </ol>
+        </div>
+      </section>
+
+      <section className="outro">
+        <p>Completed units leave the line ready for batching.</p>
+      </section>
+    </main>
+  );
 }
 
 createRoot(document.getElementById("root")!).render(<App />);
diff --git a/src/style.css b/src/style.css
index 6a6f6bd..628c7cf 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,464 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  color: #182027;
+  background: #f2f5f7;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  font-synthesis: none;
+  text-rendering: optimizeLegibility;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  background: #f2f5f7;
+}
+
+main {
+  min-height: 100vh;
+}
+
+.intro,
+.outro {
+  display: grid;
+  min-height: 72svh;
+  place-content: center;
+  padding: clamp(24px, 6vw, 80px);
+}
+
+.intro {
+  background: #e9eef2;
+}
+
+.outro {
+  min-height: 44svh;
+  background: #182027;
+  color: #f7fafc;
+  text-align: center;
+}
+
+.eyebrow {
+  margin: 0 0 10px;
+  color: #0f7a5f;
+  font-size: 0.78rem;
+  font-weight: 800;
+  letter-spacing: 0;
+  text-transform: uppercase;
+}
+
+h1,
+h2,
+p {
+  margin: 0;
+}
+
+h1 {
+  max-width: 780px;
+  font-size: clamp(2.4rem, 8vw, 6.5rem);
+  line-height: 0.95;
+}
+
+h2 {
+  max-width: 820px;
+  font-size: clamp(1.7rem, 4.5vw, 4.2rem);
+  line-height: 1;
+}
+
+.scroll-scene {
+  --progress: 0;
+  --part-x: 0px;
+  --feed: 1;
+  --stamp: 0;
+  --drill: 0;
+  --inspect: 0;
+  --pack: 0;
+  --formed: 0;
+  --drilled: 0;
+  --checked: 0;
+  --boxed: 0;
+  min-height: 430svh;
+  background: #f8fafb;
+}
+
+.machine-sticky {
+  position: sticky;
+  top: 0;
+  display: grid;
+  grid-template-rows: auto minmax(330px, 1fr) auto;
+  gap: clamp(16px, 2.5vw, 28px);
+  min-height: 100svh;
+  padding: clamp(18px, 4vw, 48px);
+}
+
+.copy {
+  display: grid;
+  gap: 4px;
+}
+
+.machine-panel {
+  position: relative;
+  overflow: hidden;
+  min-height: 360px;
+  border: 1px solid #d7dee4;
+  border-radius: 8px;
+  background:
+    linear-gradient(#dfe6eb 1px, transparent 1px),
+    linear-gradient(90deg, #dfe6eb 1px, transparent 1px),
+    #ffffff;
+  background-size: 44px 44px;
+  box-shadow: 0 24px 70px rgb(24 32 39 / 12%);
+}
+
+.progress-track {
+  position: absolute;
+  top: 18px;
+  right: 18px;
+  left: 18px;
+  height: 8px;
+  overflow: hidden;
+  border-radius: 999px;
+  background: #dce3e8;
+}
+
+.progress-track span {
+  display: block;
+  width: 100%;
+  height: 100%;
+  border-radius: inherit;
+  background: #0f7a5f;
+  transform: scaleX(var(--progress));
+  transform-origin: left center;
+}
+
+.stations {
+  position: absolute;
+  inset: 58px 6% 120px;
+  display: grid;
+  grid-template-columns: repeat(5, minmax(72px, 1fr));
+  gap: clamp(8px, 2vw, 24px);
+  align-items: stretch;
+}
+
+.station {
+  --active: 0;
+  position: relative;
+  display: grid;
+  place-items: center;
+  min-width: 0;
+  border: 1px solid #cbd4dc;
+  border-radius: 8px;
+  background: rgb(255 255 255 / 88%);
+  transform: translateY(calc(var(--active) * -10px));
+}
+
+.station::before {
+  position: absolute;
+  inset: -1px;
+  border: 2px solid #0f7a5f;
+  border-radius: inherit;
+  opacity: var(--active);
+  content: "";
+}
+
+.station span {
+  position: absolute;
+  top: 10px;
+  right: 8px;
+  left: 8px;
+  overflow: hidden;
+  color: #55636f;
+  font-size: clamp(0.62rem, 1.4vw, 0.78rem);
+  font-weight: 800;
+  text-align: center;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.station-feed {
+  --active: var(--feed);
+}
+
+.station-stamp {
+  --active: var(--stamp);
+}
+
+.station-drill {
+  --active: var(--drill);
+}
+
+.station-inspect {
+  --active: var(--inspect);
+}
+
+.station-pack {
+  --active: var(--pack);
+}
+
+.hopper {
+  width: 52%;
+  min-width: 42px;
+  height: 48%;
+  margin-top: 24px;
+  border: 12px solid #2d4655;
+  border-bottom-width: 18px;
+  clip-path: polygon(0 0, 100% 0, 78% 100%, 22% 100%);
+}
+
+.press {
+  position: relative;
+  width: 52%;
+  min-width: 42px;
+  height: 70%;
+  border-top: 14px solid #334a58;
+}
+
+.press b {
+  position: absolute;
+  top: 22%;
+  left: 50%;
+  width: 58%;
+  height: 34%;
+  background: #d05b3f;
+  transform: translate(-50%, calc(var(--stamp) * 44px));
+}
+
+.drill {
+  position: relative;
+  width: 50%;
+  min-width: 42px;
+  height: 70%;
+  border-top: 14px solid #334a58;
+}
+
+.drill b {
+  position: absolute;
+  top: 22%;
+  left: 50%;
+  width: 16px;
+  height: 58%;
+  border-radius: 999px;
+  background: #1f8bd1;
+  transform: translateX(-50%) translateY(calc(var(--drill) * 28px)) rotate(calc(var(--drill) * 210deg));
+  transform-origin: center 20%;
+}
+
+.scanner {
+  position: relative;
+  width: 58%;
+  min-width: 46px;
+  height: 52%;
+  border: 12px solid #314756;
+  border-bottom: 0;
+}
+
+.scanner::after {
+  position: absolute;
+  right: 12%;
+  bottom: -54%;
+  left: 12%;
+  height: 54%;
+  background: rgb(31 139 209 / 34%);
+  opacity: var(--inspect);
+  content: "";
+}
+
+.tray {
+  width: 64%;
+  min-width: 48px;
+  height: 40%;
+  margin-top: 42px;
+  border: 14px solid #2d4655;
+  border-top: 0;
+  transform: translateY(calc((1 - var(--pack)) * 22px));
+}
+
+.conveyor {
+  position: absolute;
+  right: 6%;
+  bottom: 54px;
+  left: 6%;
+  display: flex;
+  align-items: center;
+  justify-content: space-around;
+  height: 58px;
+  border-radius: 999px;
+  background: #253743;
+}
+
+.conveyor i {
+  width: 26px;
+  height: 26px;
+  border: 5px solid #90a0aa;
+  border-radius: 50%;
+  background: #f8fafb;
+}
+
+.part {
+  position: absolute;
+  bottom: 42px;
+  left: 8%;
+  width: 64px;
+  height: 40px;
+  border: 3px solid #8b5d2e;
+  border-radius: 7px;
+  background: #d99a4a;
+  box-shadow: 0 10px 0 rgb(0 0 0 / 15%);
+  transform: translateX(var(--part-x)) scale(calc(1 + var(--formed) * 0.08));
+}
+
+.cap {
+  position: absolute;
+  inset: -10px 10px auto;
+  height: 12px;
+  border-radius: 6px 6px 2px 2px;
+  background: #d05b3f;
+  opacity: var(--formed);
+}
+
+.hole {
+  position: absolute;
+  top: 12px;
+  width: 10px;
+  height: 10px;
+  border-radius: 50%;
+  background: #253743;
+  opacity: var(--drilled);
+}
+
+.hole-a {
+  left: 16px;
+}
+
+.hole-b {
+  right: 16px;
+}
+
+.check {
+  position: absolute;
+  right: -9px;
+  bottom: -9px;
+  display: grid;
+  width: 22px;
+  height: 22px;
+  place-items: center;
+  border-radius: 50%;
+  background: #0f7a5f;
+  color: white;
+  font-size: 14px;
+  font-weight: 900;
+  opacity: var(--checked);
+}
+
+.check::before {
+  content: "✓";
+}
+
+.step-list {
+  display: grid;
+  grid-template-columns: repeat(5, minmax(0, 1fr));
+  gap: 10px;
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+
+.step-list li {
+  display: grid;
+  gap: 5px;
+  min-width: 0;
+  border: 1px solid #d7dee4;
+  border-radius: 8px;
+  background: #ffffff;
+  padding: 12px;
+}
+
+.step-list strong {
+  color: #182027;
+  font-size: 0.92rem;
+}
+
+.step-list span {
+  color: #5d6a75;
+  font-size: 0.82rem;
+  line-height: 1.35;
+}
+
+.outro p {
+  max-width: 620px;
+  font-size: clamp(1.5rem, 4vw, 3.5rem);
+  font-weight: 800;
+  line-height: 1;
+}
+
+@media (max-width: 760px) {
+  h1 {
+    font-size: clamp(2.5rem, 16vw, 4.5rem);
+  }
+
+  .machine-sticky {
+    grid-template-rows: auto minmax(330px, 52svh) auto;
+    padding: 16px;
+  }
+
+  .stations {
+    inset: 54px 12px 116px;
+    gap: 6px;
+  }
+
+  .station {
+    border-radius: 6px;
+  }
+
+  .station span {
+    font-size: 0.58rem;
+  }
+
+  .conveyor {
+    right: 12px;
+    left: 12px;
+  }
+
+  .part {
+    left: 14px;
+    width: 54px;
+    height: 36px;
+  }
+
+  .step-list {
+    grid-template-columns: 1fr;
+  }
+
+  .step-list span {
+    font-size: 0.8rem;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .scroll-scene {
+    min-height: auto;
+  }
+
+  .machine-sticky {
+    position: static;
+    min-height: auto;
+  }
+
+  .station,
+  .press b,
+  .drill b,
+  .tray,
+  .part,
+  .progress-track span {
+    transform: none;
+  }
+
+  .progress-track span {
+    transform: scaleX(1);
+  }
+
+  .part {
+    left: 50%;
+    transform: translateX(-50%);
+  }
+}
