-body { margin: 0; font-family: system-ui, sans-serif; }
+/* =========================================================
+   Civic Slot — design tokens
+   Colours are chosen to meet WCAG 2.2 AA contrast on their
+   intended backgrounds (body text >= 7:1, large/UI >= 3:1).
+   ========================================================= */
+:root {
+  --ink: #1b1b1b; /* primary text on light surfaces  ~16:1 */
+  --ink-2: #41464b; /* secondary text on light        ~8.9:1 */
+  --ink-3: #565c64; /* muted meta text on light        ~7:1 */
+
+  --primary: #1a4480; /* brand navy                     ~9.5:1 on white */
+  --primary-dark: #16335f;
+  --primary-darker: #102542;
+  --primary-tint: #eaf0f8;
+  --primary-tint-2: #dbe6f4;
+
+  --page: #ffffff;
+  --surface: #f3f6fa; /* alternating section background */
+  --surface-2: #e9eef5;
+
+  --border: #c3ccd6; /* decorative borders */
+  --border-strong: #5f6b78; /* form control borders ~4.6:1 on white */
+
+  --focus: #1b1b1b; /* focus ring on light backgrounds */
+  --focus-invert: #ffcc4d; /* focus ring on dark backgrounds */
+
+  --success-bg: #e7f2ea;
+  --success-border: #2e7d49;
+  --success-ink: #14401f;
+
+  --info-bg: #eaf0f8;
+  --info-border: #1a4480;
+
+  --warning-bg: #fdf3e3;
+  --warning-border: #8a5a00; /* ~4.7:1 on its tint */
+  --warning-ink: #5a3d00;
+
+  --radius: 10px;
+  --radius-sm: 6px;
+  --shadow: 0 1px 2px rgba(16, 37, 66, 0.08), 0 8px 24px rgba(16, 37, 66, 0.08);
+  --shadow-sm: 0 1px 2px rgba(16, 37, 66, 0.1);
+
+  --container: 1120px;
+  --font: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
+}
+
+/* =========================================================
+   Reset & base
+   ========================================================= */
+*,
+*::before,
+*::after {
+  box-sizing: border-box;
+}
+
+html {
+  scroll-padding-top: 6rem; /* keep anchor targets clear of the sticky header */
+}
+
+@media (prefers-reduced-motion: no-preference) {
+  html {
+    scroll-behavior: smooth;
+  }
+}
+
+body {
+  margin: 0;
+  font-family: var(--font);
+  font-size: 1.0625rem; /* 17px base for readability */
+  line-height: 1.6;
+  color: var(--ink);
+  background: var(--page);
+  -webkit-font-smoothing: antialiased;
+}
+
+h1,
+h2,
+h3,
+h4 {
+  color: var(--primary-darker);
+  line-height: 1.2;
+  margin: 0 0 0.5rem;
+  text-wrap: balance;
+}
+
+h1 {
+  font-size: clamp(2rem, 5vw, 2.85rem);
+  letter-spacing: -0.01em;
+}
+
+h2 {
+  font-size: clamp(1.6rem, 3.5vw, 2.1rem);
+}
+
+h3 {
+  font-size: 1.2rem;
+}
+
+p {
+  margin: 0 0 1rem;
+}
+
+a {
+  color: var(--primary);
+  text-underline-offset: 0.18em;
+}
+
+a:hover {
+  color: var(--primary-dark);
+}
+
+img,
+svg {
+  max-width: 100%;
+}
+
+ul {
+  margin: 0;
+  padding: 0;
+}
+
+:where(ul[role="list"]) {
+  list-style: none;
+}
+
+/* =========================================================
+   Visible focus — applies to every interactive element.
+   ========================================================= */
+:focus-visible {
+  outline: 3px solid var(--focus);
+  outline-offset: 2px;
+  border-radius: 3px;
+}
+
+/* On dark surfaces, switch to a high-contrast gold ring. */
+.btn--primary:focus-visible,
+.slot:focus-visible,
+.site-footer a:focus-visible,
+.skip-link:focus {
+  outline-color: var(--focus-invert);
+  outline-offset: 3px;
+}
+
+/* =========================================================
+   Layout helpers
+   ========================================================= */
+.container {
+  width: 100%;
+  max-width: var(--container);
+  margin-inline: auto;
+  padding-inline: 1.25rem;
+}
+
+.section {
+  padding-block: clamp(2.75rem, 6vw, 4.5rem);
+}
+
+.section--alt {
+  background: var(--surface);
+  border-block: 1px solid var(--border);
+}
+
+.section__head {
+  max-width: 60ch;
+  margin-bottom: 2rem;
+}
+
+.section__lead {
+  font-size: 1.125rem;
+  color: var(--ink-2);
+  margin-bottom: 0;
+}
+
+/* =========================================================
+   Skip link
+   ========================================================= */
+.skip-link {
+  position: absolute;
+  left: 1rem;
+  top: -100px;
+  z-index: 100;
+  background: var(--page);
+  color: var(--primary-darker);
+  padding: 0.75rem 1rem;
+  border-radius: var(--radius-sm);
+  border: 2px solid var(--primary);
+  font-weight: 600;
+  text-decoration: none;
+  transition: top 0.15s ease;
+}
+
+.skip-link:focus {
+  top: 0.75rem;
+}
+
+/* =========================================================
+   Buttons
+   ========================================================= */
+.btn {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 0.5rem;
+  min-height: 2.875rem;
+  padding: 0.7rem 1.25rem;
+  border-radius: var(--radius-sm);
+  border: 2px solid transparent;
+  font: inherit;
+  font-weight: 600;
+  text-decoration: none;
+  cursor: pointer;
+  line-height: 1.2;
+}
+
+.btn svg {
+  width: 1.15em;
+  height: 1.15em;
+  flex: none;
+}
+
+.btn--primary {
+  background: var(--primary);
+  color: #ffffff;
+  border-color: var(--primary);
+}
+
+.btn--primary:hover {
+  background: var(--primary-dark);
+  border-color: var(--primary-dark);
+  color: #ffffff;
+}
+
+.btn--primary:active {
+  background: var(--primary-darker);
+}
+
+.btn--quiet {
+  background: transparent;
+  color: var(--primary);
+  border-color: transparent;
+  padding-inline: 0.5rem;
+}
+
+.btn--quiet:hover {
+  background: var(--primary-tint);
+  color: var(--primary-dark);
+}
+
+.btn--block {
+  width: 100%;
+}
+
+/* =========================================================
+   Header & primary navigation
+   ========================================================= */
+.site-header {
+  position: sticky;
+  top: 0;
+  z-index: 50;
+  background: var(--page);
+  border-bottom: 1px solid var(--border);
+}
+
+.site-header__inner {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: 0.75rem 1.5rem;
+  padding-block: 0.85rem;
+}
+
+.brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.6rem;
+  text-decoration: none;
+  color: var(--primary-darker);
+}
+
+.brand__icon {
+  width: 2rem;
+  height: 2rem;
+  color: var(--primary);
+  flex: none;
+}
+
+.brand__text {
+  display: flex;
+  flex-direction: column;
+  line-height: 1.15;
+}
+
+.brand__name {
+  font-size: 1.3rem;
+  font-weight: 700;
+}
+
+.brand__tagline {
+  font-size: 0.8rem;
+  color: var(--ink-3);
+  font-weight: 500;
+}
+
+.site-nav {
+  margin-left: auto;
+}
+
+.site-nav__list {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.25rem;
+  list-style: none;
+}
+
+.site-nav__list a {
+  display: inline-block;
+  padding: 0.5rem 0.75rem;
+  border-radius: var(--radius-sm);
+  color: var(--ink);
+  text-decoration: none;
+  font-weight: 600;
+}
+
+.site-nav__list a:hover {
+  background: var(--primary-tint);
+  color: var(--primary-dark);
+}
+
+.site-header__cta {
+  flex: none;
+}
+
+/* =========================================================
+   Hero & booking panel
+   ========================================================= */
+.hero {
+  background: linear-gradient(180deg, var(--primary-tint) 0%, var(--page) 100%);
+  border-bottom: 1px solid var(--border);
+}
+
+.hero__inner {
+  display: grid;
+  gap: 2.5rem;
+  padding-block: clamp(2.5rem, 6vw, 4.5rem);
+  align-items: start;
+}
+
+@media (min-width: 60rem) {
+  .hero__inner {
+    grid-template-columns: 1.05fr 0.95fr;
+    gap: 3.5rem;
+  }
+}
+
+.hero__eyebrow {
+  display: inline-block;
+  font-weight: 700;
+  font-size: 0.9rem;
+  letter-spacing: 0.02em;
+  text-transform: uppercase;
+  color: var(--primary-dark);
+  background: var(--primary-tint-2);
+  padding: 0.35rem 0.7rem;
+  border-radius: 999px;
+  margin-bottom: 1rem;
+}
+
+.hero__lead {
+  font-size: 1.2rem;
+  color: var(--ink-2);
+  max-width: 42ch;
+}
+
+.hero__points {
+  list-style: none;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.5rem 1.5rem;
+  margin-top: 1.5rem;
+  font-weight: 600;
+}
+
+.hero__points li {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.45rem;
+}
+
+.hero__points svg {
+  width: 1.2rem;
+  height: 1.2rem;
+  color: var(--success-border);
+  flex: none;
+}
+
+.booking {
+  background: var(--page);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  box-shadow: var(--shadow);
+}
+
+.booking__panel {
+  padding: clamp(1.25rem, 3vw, 1.75rem);
+}
+
+.booking__title {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  font-size: 1.35rem;
+  margin-bottom: 1.25rem;
+}
+
+.booking__title svg {
+  width: 1.4rem;
+  height: 1.4rem;
+  color: var(--primary);
+  flex: none;
+}
+
+.booking__title:focus-visible {
+  outline-offset: 4px;
+}
+
+.booking__summary {
+  color: var(--ink-2);
+}
+
+.booking__note {
+  display: flex;
+  gap: 0.5rem;
+  align-items: flex-start;
+  font-size: 0.95rem;
+  color: var(--ink-2);
+  background: var(--info-bg);
+  border: 1px solid var(--primary-tint-2);
+  border-left: 4px solid var(--info-border);
+  border-radius: var(--radius-sm);
+  padding: 0.75rem 0.9rem;
+  margin-block: 1rem;
+}
+
+.booking__note svg {
+  width: 1.2rem;
+  height: 1.2rem;
+  color: var(--info-border);
+  flex: none;
+  margin-top: 0.1rem;
+}
+
+.booking__panel--confirmed {
+  border-top: 4px solid var(--success-border);
+  border-radius: var(--radius);
+}
+
+.booking__panel--confirmed .booking__title svg {
+  color: var(--success-border);
+}
+
+/* Booking time slots */
+.slots {
+  list-style: none;
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(8.5rem, 1fr));
+  gap: 0.75rem;
+  margin-block: 1rem;
+}
+
+.slot {
+  width: 100%;
+  display: flex;
+  flex-direction: column;
+  align-items: flex-start;
+  gap: 0.1rem;
+  padding: 0.65rem 0.9rem;
+  background: var(--page);
+  border: 2px solid var(--primary);
+  border-radius: var(--radius-sm);
+  color: var(--primary-dark);
+  font: inherit;
+  cursor: pointer;
+  text-align: left;
+}
+
+.slot:hover {
+  background: var(--primary);
+  color: #ffffff;
+}
+
+.slot__time {
+  font-weight: 700;
+  font-size: 1.05rem;
+}
+
+.slot__meta {
+  font-size: 0.8rem;
+  color: inherit;
+  opacity: 0.85;
+}
+
+/* =========================================================
+   Section heads & cards (services)
+   ========================================================= */
+.card-grid {
+  list-style: none;
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(min(100%, 17rem), 1fr));
+  gap: 1.25rem;
+}
+
+.card {
+  display: flex;
+  flex-direction: column;
+  background: var(--page);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 1.5rem;
+  box-shadow: var(--shadow-sm);
+}
+
+.card__icon {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 2.75rem;
+  height: 2.75rem;
+  border-radius: var(--radius-sm);
+  background: var(--primary-tint);
+  color: var(--primary);
+  margin-bottom: 1rem;
+}
+
+.card__icon svg {
+  width: 1.5rem;
+  height: 1.5rem;
+}
+
+.card__title {
+  margin-bottom: 0.35rem;
+}
+
+.card__text {
+  color: var(--ink-2);
+  margin-bottom: 1rem;
+}
+
+.card__list {
+  list-style: none;
+  margin-top: auto;
+  display: flex;
+  flex-direction: column;
+  gap: 0.35rem;
+  border-top: 1px solid var(--border);
+  padding-top: 0.9rem;
+}
+
+.card__list li {
+  position: relative;
+  padding-left: 1.4rem;
+  color: var(--ink-2);
+  font-size: 0.95rem;
+}
+
+.card__list li::before {
+  content: "";
+  position: absolute;
+  left: 0;
+  top: 0.55em;
+  width: 0.55rem;
+  height: 0.55rem;
+  border-radius: 50%;
+  background: var(--primary);
+}
+
+/* =========================================================
+   Availability steps & help cards
+   ========================================================= */
+.steps {
+  list-style: none;
+  display: grid;
+  gap: 1rem;
+  counter-reset: none;
+  margin-bottom: 2.5rem;
+}
+
+@media (min-width: 48rem) {
+  .steps {
+    grid-template-columns: repeat(2, 1fr);
+    gap: 1.25rem 2rem;
+  }
+}
+
+.step {
+  display: flex;
+  gap: 1rem;
+  align-items: flex-start;
+}
+
+.step__number {
+  flex: none;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 2.5rem;
+  height: 2.5rem;
+  border-radius: 50%;
+  background: var(--primary);
+  color: #ffffff;
+  font-weight: 700;
+  font-size: 1.1rem;
+}
+
+.step__title {
+  margin-bottom: 0.25rem;
+}
+
+.step__count {
+  color: var(--ink-3);
+  font-weight: 600;
+}
+
+.step__body p {
+  color: var(--ink-2);
+  margin-bottom: 0;
+}
+
+.help-grid {
+  display: grid;
+  gap: 1.25rem;
+  grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
+}
+
+.help-card {
+  background: var(--page);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 1.25rem 1.4rem;
+}
+
+.help-card__icon {
+  display: inline-flex;
+  color: var(--primary);
+  margin-bottom: 0.6rem;
+}
+
+.help-card__icon svg {
+  width: 1.6rem;
+  height: 1.6rem;
+}
+
+.help-card__title {
+  margin-bottom: 0.3rem;
+}
+
+.help-card p {
+  color: var(--ink-2);
+  margin-bottom: 0;
+}
+
+/* =========================================================
+   Accessibility commitments
+   ========================================================= */
+.card-grid--commitments {
+  grid-template-columns: repeat(auto-fill, minmax(min(100%, 19rem), 1fr));
+}
+
+.commitment {
+  display: flex;
+  gap: 1rem;
+  align-items: flex-start;
+  background: var(--page);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 1.4rem;
+}
+
+.commitment__icon {
+  flex: none;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 2.75rem;
+  height: 2.75rem;
+  border-radius: 50%;
+  background: var(--primary-tint);
+  color: var(--primary);
+}
+
+.commitment__icon svg {
+  width: 1.5rem;
+  height: 1.5rem;
+}
+
+.commitment__title {
+  margin-bottom: 0.3rem;
+}
+
+.commitment p {
+  color: var(--ink-2);
+  margin-bottom: 0;
+}
+
+/* =========================================================
+   Callouts
+   ========================================================= */
+.callout {
+  border-radius: var(--radius);
+  padding: 1rem 1.25rem;
+  margin-top: 2rem;
+  overflow-wrap: break-word;
+}
+
+.callout__icon {
+  flex: none;
+  display: inline-flex;
+}
+
+.callout__icon svg {
+  width: 1.4rem;
+  height: 1.4rem;
+}
+
+.callout--info {
+  background: var(--info-bg);
+  border: 1px solid var(--primary-tint-2);
+  border-left: 4px solid var(--info-border);
+  color: var(--ink);
+}
+
+.callout--warning {
+  display: flex;
+  gap: 0.75rem;
+  align-items: flex-start;
+  background: var(--warning-bg);
+  border: 1px solid #f0d9a8;
+  border-left: 4px solid var(--warning-border);
+  color: var(--warning-ink);
+  margin-top: 1.5rem;
+}
+
+.callout--warning .callout__icon {
+  color: var(--warning-border);
+}
+
+/* =========================================================
+   Support & forms
+   ========================================================= */
+.support {
+  display: grid;
+  gap: 2rem;
+}
+
+@media (min-width: 56rem) {
+  .support {
+    grid-template-columns: 1fr 1.2fr;
+    gap: 3rem;
+  }
+}
+
+.support__subheading {
+  font-size: 1.25rem;
+  margin-bottom: 1rem;
+}
+
+.contact-list {
+  list-style: none;
+  display: flex;
+  flex-direction: column;
+  gap: 1.25rem;
+  margin-bottom: 1.5rem;
+}
+
+.contact-list li {
+  display: flex;
+  gap: 0.85rem;
+  align-items: flex-start;
+}
+
+.contact-list__icon {
+  flex: none;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  width: 2.5rem;
+  height: 2.5rem;
+  border-radius: 50%;
+  background: var(--primary-tint);
+  color: var(--primary);
+}
+
+.contact-list__icon svg {
+  width: 1.4rem;
+  height: 1.4rem;
+}
+
+.contact-list li > span:last-child {
+  display: flex;
+  flex-direction: column;
+}
+
+.contact-list__label {
+  font-weight: 700;
+  color: var(--ink);
+}
+
+.contact-list__note {
+  font-size: 0.9rem;
+  color: var(--ink-3);
+}
+
+.support__form-wrap {
+  background: var(--page);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: clamp(1.25rem, 3vw, 1.75rem);
+  box-shadow: var(--shadow-sm);
+}
+
+.section--alt .support__form-wrap,
+.section--alt .help-card {
+  /* keep cards readable when a section uses the alt background */
+  border-color: var(--border);
+}
+
+.form {
+  display: flex;
+  flex-direction: column;
+  gap: 1.25rem;
+}
+
+/* Form fields (shared by booking and support) */
+.field {
+  display: flex;
+  flex-direction: column;
+}
+
+.field label {
+  font-weight: 700;
+  color: var(--ink);
+  margin-bottom: 0.15rem;
+}
+
+.field__optional,
+.field__hint {
+  font-weight: 400;
+  color: var(--ink-3);
+}
+
+.field__hint {
+  font-size: 0.95rem;
+  margin: 0 0 0.5rem;
+}
+
+.field input,
+.field select,
+.field textarea {
+  font: inherit;
+  font-size: 1.0625rem;
+  color: var(--ink);
+  background: var(--page);
+  border: 2px solid var(--border-strong);
+  border-radius: var(--radius-sm);
+  padding: 0.6rem 0.7rem;
+  min-height: 2.875rem;
+  width: 100%;
+}
+
+.field textarea {
+  resize: vertical;
+  min-height: 7rem;
+  line-height: 1.5;
+}
+
+.field input:hover,
+.field select:hover,
+.field textarea:hover {
+  border-color: var(--primary);
+}
+
+.field input:focus-visible,
+.field select:focus-visible,
+.field textarea:focus-visible {
+  border-color: var(--primary);
+  outline: 3px solid var(--focus);
+  outline-offset: 1px;
+}
+
+.booking__panel .field + button,
+.booking__panel .field + .field {
+  margin-top: 0;
+}
+
+.booking__panel .field {
+  margin-bottom: 1.1rem;
+}
+
+/* Confirmation panel after sending a message */
+.form-confirmation {
+  border: 1px solid var(--success-border);
+  border-top: 4px solid var(--success-border);
+  background: var(--success-bg);
+  border-radius: var(--radius);
+  padding: 1.5rem;
+  color: var(--success-ink);
+}
+
+.form-confirmation__title {
+  color: var(--success-ink);
+  font-size: 1.2rem;
+  margin-bottom: 0.5rem;
+}
+
+.form-confirmation p {
+  color: var(--success-ink);
+}
+
+/* =========================================================
+   Footer
+   ========================================================= */
+.site-footer {
+  background: var(--primary-darker);
+  color: #e7ecf3;
+  margin-top: 0;
+}
+
+.site-footer__inner {
+  display: grid;
+  gap: 2rem;
+  padding-block: 3rem;
+}
+
+@media (min-width: 48rem) {
+  .site-footer__inner {
+    grid-template-columns: 1.4fr 1fr;
+  }
+}
+
+.brand--footer {
+  color: #ffffff;
+}
+
+.brand--footer .brand__icon {
+  color: #9fc0ec;
+}
+
+.brand--footer .brand__name {
+  color: #ffffff;
+}
+
+.site-footer__about {
+  margin-top: 0.75rem;
+  color: #c6d2e3;
+  max-width: 46ch;
+}
+
+.site-footer__heading {
+  color: #ffffff;
+  font-size: 1.05rem;
+  margin-bottom: 0.75rem;
+}
+
+.site-footer__nav ul {
+  list-style: none;
+  display: flex;
+  flex-direction: column;
+  gap: 0.35rem;
+}
+
+.site-footer a {
+  color: #d7e1f0;
+  text-decoration: underline;
+}
+
+.site-footer a:hover {
+  color: #ffffff;
+}
+
+.site-footer__legal {
+  border-top: 1px solid rgba(255, 255, 255, 0.18);
+  padding-block: 1.25rem;
+}
+
+.site-footer__legal p {
+  margin: 0;
+  color: #b8c5da;
+  font-size: 0.95rem;
+}
+
+/* =========================================================
+   Motion preferences
+   ========================================================= */
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    animation-duration: 0.001ms !important;
+    transition-duration: 0.001ms !important;
+    scroll-behavior: auto !important;
+  }
+}
