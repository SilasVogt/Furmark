-import React from "react";
+import React, { useEffect, useRef, useState } from "react";
 import { createRoot } from "react-dom/client";
 import "./style.css";
+import { orbitXY, repulse, type Pt } from "./field";
 
-function App() {
-  return <main><h1>Furmark task workspace</h1></main>;
+type Particle = { rFrac: number; angle: number; speed: number; size: number; hue: number };
+
+function makeParticles(n: number): Particle[] {
+  return Array.from({ length: n }, () => {
+    const rFrac = 0.06 + Math.random() ** 0.7 * 0.42; // fraction of the half-min-dimension
+    return {
+      rFrac,
+      angle: Math.random() * Math.PI * 2,
+      speed: 0.25 + (1 - rFrac) * 0.6, // inner orbits sweep faster
+      size: 1 + Math.random() * 2.5,
+      hue: 200 + (1 - rFrac) * 140,
+    };
+  });
+}
+
+const REDUCED_QUERY = "(prefers-reduced-motion: reduce)";
+
+function OrbitField() {
+  const canvasRef = useRef<HTMLCanvasElement>(null);
+  const particles = useRef<Particle[] | null>(null);
+  const pointer = useRef<Pt | null>(null);
+  const size = useRef({ w: 0, h: 0 });
+
+  const [paused, setPaused] = useState(false);
+  const [reduced, setReduced] = useState(() => window.matchMedia(REDUCED_QUERY).matches);
+
+  // Track the OS reduced-motion preference live.
+  useEffect(() => {
+    const mq = window.matchMedia(REDUCED_QUERY);
+    const on = () => setReduced(mq.matches);
+    mq.addEventListener("change", on);
+    return () => mq.removeEventListener("change", on);
+  }, []);
+
+  useEffect(() => {
+    const canvas = canvasRef.current!;
+    const ctx = canvas.getContext("2d")!;
+    if (!particles.current) particles.current = makeParticles(90);
+
+    function resize() {
+      const dpr = window.devicePixelRatio || 1;
+      const rect = canvas.getBoundingClientRect();
+      canvas.width = Math.round(rect.width * dpr);
+      canvas.height = Math.round(rect.height * dpr);
+      ctx.setTransform(dpr, 0, 0, dpr, 0, 0); // draw in CSS pixels, stay crisp on HiDPI
+      size.current = { w: rect.width, h: rect.height };
+      draw();
+    }
+
+    function draw() {
+      const { w, h } = size.current;
+      ctx.fillStyle = "#0b0e16";
+      ctx.fillRect(0, 0, w, h);
+      const cx = w / 2;
+      const cy = h / 2;
+      const rad = Math.min(w, h) / 2;
+      const p = pointer.current;
+      ctx.globalCompositeOperation = "lighter";
+      for (const s of particles.current!) {
+        const base = orbitXY(cx, cy, s.rFrac * rad, s.angle);
+        const { x, y } = repulse(base.x, base.y, p);
+        ctx.beginPath();
+        ctx.arc(x, y, s.size, 0, Math.PI * 2);
+        ctx.fillStyle = `hsl(${s.hue} 85% 62%)`;
+        ctx.fill();
+      }
+      ctx.globalCompositeOperation = "source-over";
+    }
+
+    let raf = 0;
+    let last: number | null = null;
+    function tick(now: number) {
+      raf = requestAnimationFrame(tick);
+      if (last == null) last = now;
+      const dt = Math.min((now - last) / 1000, 0.05); // clamp so a backgrounded tab doesn't lurch
+      last = now;
+      for (const s of particles.current!) s.angle += s.speed * dt;
+      draw();
+    }
+
+    resize();
+    const running = !paused && !reduced;
+    if (running) raf = requestAnimationFrame(tick);
+
+    // With the loop off for reduced-motion, the pointer still parts the field
+    // (user-driven, not automatic) — but a deliberate pause stays frozen.
+    const liveStatic = reduced && !paused;
+    function onMove(e: PointerEvent) {
+      const rect = canvas.getBoundingClientRect();
+      pointer.current = { x: e.clientX - rect.left, y: e.clientY - rect.top };
+      if (!running && liveStatic) draw();
+    }
+    function onLeave() {
+      pointer.current = null;
+      if (!running && liveStatic) draw();
+    }
+
+    canvas.addEventListener("pointermove", onMove);
+    canvas.addEventListener("pointerleave", onLeave);
+    window.addEventListener("resize", resize);
+    return () => {
+      cancelAnimationFrame(raf);
+      canvas.removeEventListener("pointermove", onMove);
+      canvas.removeEventListener("pointerleave", onLeave);
+      window.removeEventListener("resize", resize);
+    };
+  }, [paused, reduced]);
+
+  return (
+    <main>
+      <canvas
+        ref={canvasRef}
+        className="field"
+        role="img"
+        aria-label="A field of satellites orbiting the center. Move the pointer to part the field."
+      />
+      <button className="toggle" aria-pressed={paused} onClick={() => setPaused((p) => !p)}>
+        {paused ? "Resume" : "Pause"} motion
+      </button>
+      {reduced && (
+        <p className="hint" role="status">
+          Reduced motion is on — orbits are held still; move the pointer to interact.
+        </p>
+      )}
+    </main>
+  );
 }
 
-createRoot(document.getElementById("root")!).render(<App />);
+createRoot(document.getElementById("root")!).render(<OrbitField />);
