-import React from "react";
+import React, { useEffect, useRef, useState } from "react";
 import { createRoot } from "react-dom/client";
+import { Boxes, Scissors, PaintBucket, Cog, Package, Truck, Settings } from "lucide-react";
+import { progress } from "./progress";
 import "./style.css";
 
+const STATIONS = [
+  { title: "Intake", desc: "Raw stock is loaded onto the belt.", color: "#64748b", Icon: Boxes },
+  { title: "Cut", desc: "Blanks are cut to size.", color: "#f59e0b", Icon: Scissors },
+  { title: "Paint", desc: "A surface coat is sprayed on.", color: "#3b82f6", Icon: PaintBucket },
+  { title: "Assemble", desc: "Components are joined together.", color: "#8b5cf6", Icon: Cog },
+  { title: "Package", desc: "The finished unit is boxed.", color: "#ec4899", Icon: Package },
+  { title: "Ship", desc: "The crate rolls out to the dock.", color: "#14b8a6", Icon: Truck },
+];
+const N = STATIONS.length;
+
+function usePrefersReducedMotion() {
+  const q = "(prefers-reduced-motion: reduce)";
+  const [reduced, setReduced] = useState(() => window.matchMedia(q).matches);
+  useEffect(() => {
+    const m = window.matchMedia(q);
+    const on = () => setReduced(m.matches);
+    m.addEventListener("change", on);
+    return () => m.removeEventListener("change", on);
+  }, []);
+  return reduced;
+}
+
+// Scroll drives a single CSS variable on the section — no React state, so no
+// re-render loop. CSS calc() reads --p to move everything. rAF coalesces bursts.
+function useScrollProgress(ref: React.RefObject<HTMLDivElement | null>) {
+  useEffect(() => {
+    const el = ref.current;
+    if (!el) return;
+    let raf = 0;
+    const update = () => {
+      raf = 0;
+      const r = el.getBoundingClientRect();
+      el.style.setProperty("--p", progress(r.top, r.height, window.innerHeight).toFixed(4));
+    };
+    const onScroll = () => { if (!raf) raf = requestAnimationFrame(update); };
+    update();
+    window.addEventListener("scroll", onScroll, { passive: true });
+    window.addEventListener("resize", onScroll, { passive: true });
+    return () => {
+      window.removeEventListener("scroll", onScroll);
+      window.removeEventListener("resize", onScroll);
+      if (raf) cancelAnimationFrame(raf);
+    };
+  }, [ref]);
+}
+
+function Machine() {
+  const scene = useRef<HTMLDivElement>(null);
+  useScrollProgress(scene);
+  return (
+    <div className="scene" ref={scene}>
+      <div className="stage">
+        <div className="panel">
+          <header className="head">
+            <h1>Assembly Line</h1>
+            <p>Scroll to drive a part through every station.</p>
+          </header>
+          <div className="machine">
+            <div className="gears" aria-hidden>
+              <Cog className="gear" size={52} />
+              <Settings className="gear gear--rev" size={36} />
+            </div>
+            <div className="band">
+              {STATIONS.map((s, i) => (
+                <div
+                  key={s.title}
+                  className="station"
+                  style={{ left: `${(i / (N - 1)) * 100}%`, "--accent": s.color } as React.CSSProperties}
+                >
+                  <div className="chip"><s.Icon size={22} /></div>
+                  <div className="lbl">{s.title}</div>
+                </div>
+              ))}
+              <div className="belt" aria-hidden />
+              <div className="roller roller--l" aria-hidden />
+              <div className="roller roller--r" aria-hidden />
+              <div className="spot" aria-hidden />
+              <div className="part" aria-hidden />
+            </div>
+            <div className="track" role="progressbar" aria-label="Assembly progress">
+              <div className="fill" />
+            </div>
+          </div>
+          <p className="hint">Keep scrolling ↓</p>
+        </div>
+      </div>
+    </div>
+  );
+}
+
+// Reduced-motion: same sequence as a readable, static list. No sticky scroll,
+// no transforms, no continuous animation.
+function StaticLine() {
+  return (
+    <main className="static">
+      <header className="head">
+        <h1>Assembly Line</h1>
+        <p>The full station sequence, shown without motion.</p>
+      </header>
+      <ol className="cards">
+        {STATIONS.map((s, i) => (
+          <li key={s.title} className="card" style={{ "--accent": s.color } as React.CSSProperties}>
+            <div className="chip"><s.Icon size={22} /></div>
+            <div>
+              <h2>{i + 1}. {s.title}</h2>
+              <p>{s.desc}</p>
+            </div>
+          </li>
+        ))}
+      </ol>
+    </main>
+  );
+}
+
 function App() {
-  return <main><h1>Furmark task workspace</h1></main>;
+  return usePrefersReducedMotion() ? <StaticLine /> : <Machine />;
 }
 
 createRoot(document.getElementById("root")!).render(<App />);
diff --git a/src/style.css b/src/style.css
index 6a6f6bd..516825b 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,154 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root { color-scheme: dark; }
+* { box-sizing: border-box; }
+body {
+  margin: 0;
+  font-family: system-ui, sans-serif;
+  background: radial-gradient(120% 120% at 50% 0%, #1a2030 0%, #0d111a 60%);
+  color: #e7ecf3;
+}
+h1 { margin: 0; font-size: clamp(1.6rem, 4vw, 2.4rem); }
+.head p { margin: 0.4rem 0 0; color: #9aa4b2; }
+
+/* ---------- scroll-driven machine ---------- */
+.scene { height: 500vh; position: relative; }
+.stage {
+  position: sticky;
+  top: 0;
+  height: 100vh;
+  display: grid;
+  place-items: center;
+  padding: 16px;
+}
+.panel {
+  width: min(920px, 94vw);
+  background: linear-gradient(180deg, #161b27, #11151f);
+  border: 1px solid #262d3d;
+  border-radius: 18px;
+  padding: clamp(18px, 4vw, 34px);
+  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
+}
+.head { text-align: center; }
+
+.machine { position: relative; margin-top: 22px; }
+.gears { position: absolute; top: -30px; right: 8px; display: flex; color: #39425a; }
+.gear { transform: rotate(calc(var(--p, 0) * 1440deg)); }
+.gear--rev { transform: rotate(calc(var(--p, 0) * -1800deg)); margin-left: -6px; }
+
+.band {
+  position: relative;
+  height: 180px;
+  margin: 18px 30px 8px;
+}
+.belt {
+  position: absolute;
+  left: 0; right: 0; bottom: 30px;
+  height: 34px;
+  border-radius: 8px;
+  background: repeating-linear-gradient(45deg, #232a38 0 12px, #2c3446 12px 24px);
+  background-size: 34px 34px;
+  background-position-x: calc(var(--p, 0) * -1400px);
+  box-shadow: inset 0 0 0 2px #39425a;
+}
+.roller {
+  position: absolute;
+  bottom: 24px;
+  width: 46px; height: 46px;
+  border-radius: 50%;
+  background: radial-gradient(circle at 35% 35%, #5b6680, #232a38 70%);
+  border: 3px solid #39425a;
+  transform: rotate(calc(var(--p, 0) * 2400deg));
+}
+.roller::before {
+  content: ""; position: absolute; inset: 18px;
+  border-left: 3px solid #8b97b5; border-radius: 50%;
+}
+.roller--l { left: -23px; }
+.roller--r { right: -23px; }
+
+.station {
+  position: absolute;
+  top: 0;
+  transform: translateX(-50%);
+  width: 90px;
+  text-align: center;
+}
+.chip {
+  width: 46px; height: 46px;
+  margin: 0 auto;
+  display: grid; place-items: center;
+  border-radius: 12px;
+  background: #1b2233;
+  border: 1px solid #2c3446;
+  color: var(--accent, #9aa4b2);
+}
+.lbl { margin-top: 7px; font-size: 12px; color: #aeb7c6; }
+
+.spot {
+  position: absolute;
+  bottom: 18px;
+  left: calc(var(--p, 0) * 100%);
+  transform: translateX(-50%);
+  width: 100px; height: 100px;
+  pointer-events: none;
+  background: radial-gradient(circle, rgba(20, 184, 166, 0.4), transparent 68%);
+}
+.part {
+  position: absolute;
+  bottom: 64px;
+  left: calc(var(--p, 0) * 100%);
+  transform: translateX(-50%);
+  width: 26px; height: 26px;
+  border-radius: calc(3px + var(--p, 0) * 9px);
+  background: color-mix(in oklab, #64748b, #14b8a6 calc(var(--p, 0) * 100%));
+  box-shadow: 0 6px 14px rgba(0, 0, 0, 0.5);
+}
+
+.track {
+  height: 9px;
+  margin: 8px 4px 0;
+  background: #1b2233;
+  border-radius: 99px;
+  overflow: hidden;
+}
+.fill {
+  height: 100%;
+  width: calc(var(--p, 0) * 100%);
+  background: linear-gradient(90deg, #10b981, #14b8a6);
+}
+.hint { text-align: center; color: #6b7689; font-size: 13px; margin: 14px 0 0; }
+
+/* ---------- reduced-motion static view ---------- */
+.static {
+  width: min(920px, 94vw);
+  margin: 0 auto;
+  padding: 6vh 0 8vh;
+}
+.cards {
+  list-style: none;
+  margin: 26px 0 0;
+  padding: 0;
+  display: grid;
+  gap: 14px;
+  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
+}
+.card {
+  display: flex;
+  gap: 14px;
+  align-items: flex-start;
+  background: #161b27;
+  border: 1px solid #262d3d;
+  border-left: 3px solid var(--accent, #39425a);
+  border-radius: 12px;
+  padding: 16px;
+}
+.card h2 { margin: 0 0 4px; font-size: 1rem; }
+.card p { margin: 0; color: #9aa4b2; font-size: 0.9rem; }
+
+/* ---------- mobile ---------- */
+@media (max-width: 560px) {
+  .band { margin: 18px 16px 8px; height: 168px; }
+  .station { width: 52px; }
+  .chip { width: 38px; height: 38px; }
+  .lbl { display: none; }
+  .gears { top: -24px; }
+}
