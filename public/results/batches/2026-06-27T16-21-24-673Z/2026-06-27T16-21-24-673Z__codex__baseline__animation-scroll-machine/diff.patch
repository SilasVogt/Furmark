+  top: 0;
+  left: 20%;
+  right: 20%;
+  height: 28%;
+  border-radius: 6px;
+  background: #334a58;
+  box-shadow: inset 0 -0.35rem 0 rgba(0, 0, 0, 0.22);
+}
+
+.scan-beam {
+  position: absolute;
+  top: 27%;
+  left: 50%;
+  width: var(--scan-width);
+  height: 65%;
+  clip-path: polygon(50% 0, 100% 100%, 0 100%);
+  background: linear-gradient(180deg, rgba(47, 178, 127, 0.52), rgba(47, 178, 127, 0));
+  opacity: var(--inspect-action);
+  transform: translateX(-50%);
+}
+
+.pass-light {
+  position: absolute;
+  right: 10%;
+  bottom: 0;
+  width: 1.1rem;
+  height: 1.1rem;
+  border-radius: 50%;
+  background: #7f8780;
+}
+
+.scroll-stage[data-active="inspect"] .pass-light {
+  background: #2fb27f;
+  box-shadow: 0 0 0 0.45rem rgba(47, 178, 127, 0.18);
+}
+
+.conveyor {
+  position: absolute;
+  z-index: 10;
+  left: 5%;
+  right: 5%;
+  bottom: 20%;
+  height: clamp(4.8rem, 11vw, 6rem);
+  overflow: hidden;
+  border: 4px solid #3f4240;
+  border-radius: 8px;
+  background: #2f3130;
+  box-shadow: 0 0.9rem 0 rgba(43, 45, 42, 0.2);
+}
+
+.belt-stripes {
+  position: absolute;
+  inset: 0.55rem;
+  border-radius: 5px;
+  background:
+    repeating-linear-gradient(
+      90deg,
+      #3e4445 0,
+      #3e4445 1.2rem,
+      #6a716e 1.2rem,
+      #6a716e 2rem
+    ),
+    #3d4241;
+  transform: translateX(var(--belt-offset));
+}
+
+.roller-row {
+  position: absolute;
+  left: 1rem;
+  right: 1rem;
+  bottom: 0.55rem;
+  display: grid;
+  grid-template-columns: repeat(12, 1fr);
+  gap: 0.5rem;
+}
+
+.roller {
+  aspect-ratio: 1;
+  min-width: 0.65rem;
+  border: 2px solid #252725;
+  border-radius: 50%;
+  background: linear-gradient(135deg, #e7e0d1, #808980);
+}
+
+.part-carrier {
+  position: absolute;
+  z-index: 20;
+  left: 5%;
+  bottom: calc(20% + clamp(3.65rem, 8vw, 4.75rem));
+  width: clamp(5.2rem, 8vw, 7rem);
+  height: clamp(3.6rem, 5.8vw, 4.7rem);
+  transform: translateX(var(--part-x)) translateY(var(--feed-y));
+}
+
+.part-core {
+  position: relative;
+  z-index: 2;
+  width: 100%;
+  height: 74%;
+  border: 3px solid #3d413e;
+  border-radius: 8px 8px 14px 14px;
+  background: #c8cdd0;
+  box-shadow:
+    inset 0 -0.5rem 0 rgba(66, 68, 66, 0.14),
+    0 0.75rem 1rem rgba(45, 44, 40, 0.15);
+}
+
+.part-core::before {
+  position: absolute;
+  inset: 19% 13%;
+  border: 2px solid rgba(53, 56, 54, 0.36);
+  border-radius: 5px;
+  content: "";
+  opacity: 0.28;
+}
+
+.part-window {
+  position: absolute;
+  top: 20%;
+  left: 50%;
+  width: 28%;
+  height: 28%;
+  border-radius: 3px;
+  background: #708a93;
+  opacity: 0;
+  transform: translateX(-50%);
+}
+
+.part-rivet {
+  position: absolute;
+  bottom: 18%;
+  width: 0.58rem;
+  height: 0.58rem;
+  border-radius: 50%;
+  background: #f2dba7;
+  opacity: 0;
+}
+
+.part-rivet--left {
+  left: 25%;
+}
+
+.part-rivet--right {
+  right: 25%;
+}
+
+.part-check {
+  position: absolute;
+  right: 13%;
+  bottom: 18%;
+  width: 1.3rem;
+  height: 0.7rem;
+  border-bottom: 0.22rem solid #f7fbf6;
+  border-left: 0.22rem solid #f7fbf6;
+  opacity: 0;
+  transform: rotate(-45deg);
+}
+
+.part-shadow {
+  position: absolute;
+  left: 8%;
+  right: 8%;
+  bottom: 0.1rem;
+  height: 0.65rem;
+  border-radius: 50%;
+  background: rgba(42, 41, 37, 0.26);
+  filter: blur(4px);
+}
+
+.scroll-stage[data-active="press"] .part-core {
+  border-radius: 14px 14px 9px 9px;
+  background: #d9dde0;
+  transform: scaleY(0.88);
+}
+
+.scroll-stage[data-active="press"] .part-core::before,
+.scroll-stage[data-active="fasten"] .part-core::before,
+.scroll-stage[data-active="paint"] .part-core::before,
+.scroll-stage[data-active="inspect"] .part-core::before {
+  opacity: 1;
+}
+
+.scroll-stage[data-active="fasten"] .part-core {
+  background: #d4d8da;
+}
+
+.scroll-stage[data-active="fasten"] .part-rivet,
+.scroll-stage[data-active="paint"] .part-rivet,
+.scroll-stage[data-active="inspect"] .part-rivet {
+  opacity: 1;
+}
+
+.scroll-stage[data-active="paint"] .part-core {
+  background: #d95f4e;
+}
+
+.scroll-stage[data-active="paint"] .part-window,
+.scroll-stage[data-active="inspect"] .part-window {
+  opacity: 1;
+}
+
+.scroll-stage[data-active="inspect"] .part-core {
+  background: #2f9c78;
+}
+
+.scroll-stage[data-active="inspect"] .part-check {
+  opacity: 1;
+}
+
+.station-list {
+  display: grid;
+  gap: 0.65rem;
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+
+.station-card {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 0.7rem;
+  min-height: 6.7rem;
+  padding: 0.85rem;
+  border: 1px solid #c6c1b6;
+  border-radius: 8px;
+  background: rgba(255, 255, 255, 0.66);
+  color: #3e403c;
+  box-shadow: 0 0.75rem 1.4rem rgba(61, 59, 52, 0.05);
+}
+
+.station-card__icon {
+  display: grid;
+  width: 2rem;
+  height: 2rem;
+  place-items: center;
+  border: 1px solid #bab4a7;
+  border-radius: 6px;
+  background: #f5f2ea;
+  color: #416b5d;
+}
+
+.station-card__top {
+  display: flex;
+  justify-content: space-between;
+  gap: 0.8rem;
+  color: #676960;
+  font-size: 0.73rem;
+  font-weight: 900;
+  text-transform: uppercase;
+}
+
+.station-card__top strong {
+  color: #2e302d;
+}
+
+.station-card h2 {
+  margin: 0.3rem 0 0.25rem;
+  color: #1c1d1a;
+  font-size: 1rem;
+  line-height: 1.15;
+}
+
+.station-card p {
+  margin: 0;
+  color: #5b5d55;
+  font-size: 0.86rem;
+  line-height: 1.35;
+}
+
+.scroll-stage[data-active="feed"] .station-card--feed,
+.scroll-stage[data-active="press"] .station-card--press,
+.scroll-stage[data-active="fasten"] .station-card--fasten,
+.scroll-stage[data-active="paint"] .station-card--paint,
+.scroll-stage[data-active="inspect"] .station-card--inspect {
+  border-color: #2b8973;
+  background: #fffdf8;
+  box-shadow: 0 1rem 2rem rgba(52, 73, 63, 0.13);
+  transform: translateX(-0.25rem);
+}
+
+.sequence-summary {
+  padding: clamp(3rem, 8vw, 6rem) clamp(1rem, 3vw, 2.5rem);
+  background: #fbfaf5;
+}
+
+.sequence-summary__inner {
+  width: min(1180px, 100%);
+  margin: 0 auto;
+}
+
+.sequence-summary h2 {
+  max-width: 760px;
+  font-size: clamp(2rem, 4.8vw, 4rem);
+}
+
+.summary-grid {
+  display: grid;
+  grid-template-columns: repeat(5, minmax(0, 1fr));
+  gap: 0.75rem;
+  margin-top: 1.5rem;
+}
+
+.summary-step {
+  min-height: 13rem;
+  padding: 1rem;
+  border: 1px solid #d1ccc0;
+  border-radius: 8px;
+  background: #f4f0e7;
+}
+
+.summary-step span {
+  color: #416b5d;
+  font-size: 0.74rem;
+  font-weight: 900;
+  text-transform: uppercase;
+}
+
+.summary-step h3 {
+  margin: 0.7rem 0 0.45rem;
+  font-size: 1.05rem;
+  line-height: 1.15;
+}
+
+.summary-step p {
+  margin: 0;
+  color: #55564f;
+  font-size: 0.92rem;
+  line-height: 1.45;
+}
+
+.summary-step strong {
+  display: inline-flex;
+  margin-top: 1rem;
+  padding: 0.35rem 0.5rem;
+  border-radius: 6px;
+  background: #ffffff;
+  color: #171614;
+  font-size: 0.78rem;
+}
+
+@media (max-width: 1040px) {
+  .machine-header,
+  .factory-layout {
+    grid-template-columns: 1fr;
+  }
+
+  .line-meter {
+    min-height: 5.25rem;
+  }
+
+  .station-list {
+    grid-auto-columns: minmax(190px, 31vw);
+    grid-auto-flow: column;
+    overflow-x: auto;
+    padding-bottom: 0.3rem;
+    scrollbar-width: thin;
+  }
+
+  .station-card {
+    min-height: 8rem;
+  }
+
+  .summary-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 720px) {
+  .machine-sticky {
+    align-items: start;
+    padding: 0.75rem;
+  }
+
+  .machine-shell {
+    width: 100%;
+  }
+
+  .machine-header {
+    gap: 0.75rem;
+    margin-bottom: 0.75rem;
+  }
+
+  .machine-title h1 {
+    font-size: clamp(2.35rem, 13vw, 3.8rem);
+  }
+
+  .machine-title p {
+    margin-top: 0.75rem;
+    font-size: 0.96rem;
+  }
+
+  .line-meter {
+    padding: 0.8rem;
+  }
+
+  .factory-layout {
+    gap: 0.75rem;
+  }
+
+  .machine-scene {
+    min-height: 385px;
+  }
+
+  .station-markers {
+    top: 3.4rem;
+    left: 0.55rem;
+    right: 0.55rem;
+    gap: 0.25rem;
+  }
+
+  .station-marker {
+    min-height: 2rem;
+    padding: 0 0.2rem;
+    font-size: clamp(0.48rem, 1.9vw, 0.62rem);
+  }
+
+  .feed-hopper {
+    left: 2.5%;
+  }
+
+  .press-station {
+    left: 23%;
+  }
+
+  .rivet-station {
+    left: 43%;
+  }
+
+  .paint-station {
+    left: 60%;
+  }
+
+  .inspect-station {
+    right: 2.5%;
+  }
+
+  .station-list {
+    grid-auto-columns: minmax(190px, 78vw);
+  }
+
+  .summary-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .summary-step {
+    min-height: 0;
+  }
+}
+
+@media (max-height: 720px) and (max-width: 900px) {
+  .machine-scene {
+    min-height: 330px;
+  }
+
+  .station-card {
+    min-height: 7rem;
+  }
+
+  .station-card p {
+    font-size: 0.81rem;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    animation-duration: 0.001ms !important;
+    animation-iteration-count: 1 !important;
+    scroll-behavior: auto !important;
+    transition-duration: 0.001ms !important;
+  }
+
+  .scroll-stage {
+    height: auto;
+    padding: clamp(1rem, 3vw, 2rem) 0;
+  }
+
+  .machine-sticky {
+    position: relative;
+    top: auto;
+    min-height: auto;
+  }
+
+  .machine-scene {
+    min-height: 380px;
+  }
+
+  .line-meter__fill {
+    width: 100%;
+  }
+
+  .station-list {
+    overflow: visible;
+  }
+
+  .scroll-stage[data-motion="reduced"] .station-card {
+    transform: none;
+  }
+}
