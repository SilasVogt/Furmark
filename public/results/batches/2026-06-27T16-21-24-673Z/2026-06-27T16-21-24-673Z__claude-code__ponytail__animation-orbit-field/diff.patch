-body { margin: 0; font-family: system-ui, sans-serif; }
+body { margin: 0; font-family: system-ui, sans-serif; background: #0b0e16; }
+
+.field { position: fixed; inset: 0; width: 100%; height: 100%; display: block; }
+
+.toggle {
+  position: fixed; top: 16px; left: 16px; z-index: 1;
+  font: inherit; padding: 8px 14px; border-radius: 999px;
+  border: 1px solid #ffffff44; background: #ffffff14; color: #fff;
+  cursor: pointer; backdrop-filter: blur(4px);
+}
+.toggle:hover { background: #ffffff24; }
+.toggle:focus-visible { outline: 2px solid #7cc4ff; outline-offset: 2px; }
+
+.hint {
+  position: fixed; bottom: 12px; left: 16px; right: 16px; z-index: 1;
+  margin: 0; color: #cdd6f4; font-size: 13px; opacity: .85;
+}
