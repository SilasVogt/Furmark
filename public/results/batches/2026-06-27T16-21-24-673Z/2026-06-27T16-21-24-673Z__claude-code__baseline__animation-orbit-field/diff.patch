diff --git a/src/style.css b/src/style.css
index 6a6f6bd..2840d39 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,105 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  color-scheme: dark;
+}
+
+html,
+body {
+  height: 100%;
+}
+
+body {
+  margin: 0;
+  background: #05060f;
+  color: #e8ecff;
+  font-family: system-ui, sans-serif;
+}
+
+.orbit-app {
+  position: fixed;
+  inset: 0;
+  overflow: hidden;
+}
+
+.orbit-canvas {
+  display: block;
+  width: 100%;
+  height: 100%;
+  touch-action: none; /* let the canvas receive pointer gestures on touch */
+}
+
+.orbit-hint {
+  position: absolute;
+  top: clamp(14px, 3vh, 28px);
+  left: 50%;
+  transform: translateX(-50%);
+  margin: 0;
+  max-width: min(90vw, 520px);
+  text-align: center;
+  font-size: 13px;
+  letter-spacing: 0.02em;
+  color: rgba(200, 210, 255, 0.72);
+  pointer-events: none;
+}
+
+.orbit-controls {
+  position: absolute;
+  left: 50%;
+  bottom: clamp(16px, 4vh, 40px);
+  transform: translateX(-50%);
+  display: flex;
+  gap: 12px;
+  align-items: center;
+}
+
+.orbit-toggle {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  padding: 10px 20px;
+  border-radius: 999px;
+  border: 1px solid rgba(160, 190, 255, 0.35);
+  background: rgba(15, 20, 45, 0.6);
+  -webkit-backdrop-filter: blur(8px);
+  backdrop-filter: blur(8px);
+  color: #e8ecff;
+  font: inherit;
+  font-size: 15px;
+  font-weight: 600;
+  cursor: pointer;
+  transition:
+    background 0.2s ease,
+    border-color 0.2s ease,
+    transform 0.1s ease;
+}
+
+.orbit-toggle:hover {
+  background: rgba(35, 45, 90, 0.7);
+  border-color: rgba(160, 190, 255, 0.6);
+}
+
+.orbit-toggle:active {
+  transform: scale(0.97);
+}
+
+.orbit-toggle:focus-visible {
+  outline: 3px solid #7aa2ff;
+  outline-offset: 3px;
+}
+
+.visually-hidden {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0 0 0 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .orbit-toggle {
+    transition: none;
+  }
+}
