+  margin-bottom: 4px;
+  color: var(--muted);
+  font-size: 0.88rem;
+}
+
+.product-bar strong {
+  display: block;
+  color: var(--ink);
+  font-size: clamp(1rem, 2vw, 1.25rem);
+}
+
+.section {
+  padding-block: clamp(72px, 11vw, 132px);
+}
+
+.section-copy {
+  max-width: 720px;
+  margin-bottom: clamp(28px, 5vw, 52px);
+}
+
+.section-copy.compact {
+  max-width: 560px;
+}
+
+.section-copy h2,
+.purchase-strip h2 {
+  margin-bottom: 16px;
+  font-size: clamp(2.15rem, 5vw, 4.65rem);
+  font-weight: 780;
+  line-height: 1.02;
+}
+
+.section-copy p,
+.purchase-strip p,
+.detail-list p,
+.spec-tile p,
+.panel-note {
+  color: var(--muted);
+}
+
+.details-layout {
+  display: grid;
+  grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
+  gap: clamp(24px, 5vw, 70px);
+  align-items: center;
+}
+
+.components-media {
+  aspect-ratio: 1.32;
+}
+
+.detail-list {
+  display: grid;
+  gap: 0;
+}
+
+.detail-list article {
+  display: grid;
+  grid-template-columns: 44px minmax(0, 1fr);
+  gap: 18px;
+  padding-block: 24px;
+  border-top: 1px solid var(--line);
+}
+
+.detail-list article:last-child {
+  border-bottom: 1px solid var(--line);
+}
+
+.detail-icon {
+  display: grid;
+  width: 44px;
+  height: 44px;
+  place-items: center;
+  border-radius: var(--radius-card);
+  background: var(--accent-soft);
+  color: var(--accent);
+}
+
+.detail-list h3,
+.order-panel h3 {
+  margin-bottom: 7px;
+  font-size: 1.2rem;
+}
+
+.configure-section {
+  border-block: 1px solid var(--line);
+}
+
+.configure-layout {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(310px, 0.42fr);
+  gap: clamp(24px, 5vw, 56px);
+  align-items: start;
+}
+
+.configurator {
+  display: grid;
+  gap: 28px;
+}
+
+.option-group {
+  margin: 0;
+  padding: 0;
+  border: 0;
+}
+
+.option-group legend {
+  margin-bottom: 12px;
+  font-size: 1rem;
+  font-weight: 780;
+}
+
+.option-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 12px;
+}
+
+.option-card {
+  position: relative;
+  min-width: 0;
+  min-height: 142px;
+  overflow: hidden;
+  border: 1px solid var(--line);
+  border-radius: var(--radius-card);
+  background: color-mix(in srgb, var(--surface) 88%, transparent);
+  cursor: pointer;
+  transition:
+    transform 180ms ease,
+    border-color 180ms ease,
+    background 180ms ease;
+}
+
+.option-card input {
+  position: absolute;
+  inset: 0;
+  cursor: pointer;
+  opacity: 0;
+}
+
+.option-inner {
+  position: relative;
+  display: grid;
+  min-height: 142px;
+  gap: 10px;
+  align-content: start;
+  padding: 16px;
+  pointer-events: none;
+}
+
+.option-topline {
+  display: flex;
+  min-width: 0;
+  align-items: center;
+  gap: 9px;
+  color: var(--ink);
+}
+
+.option-title {
+  min-width: 0;
+  overflow-wrap: anywhere;
+  font-weight: 760;
+}
+
+.option-detail {
+  color: var(--muted);
+  font-size: 0.94rem;
+}
+
+.option-meta {
+  align-self: end;
+  color: var(--accent);
+  font-size: 0.86rem;
+  font-weight: 750;
+}
+
+.swatch {
+  width: 18px;
+  height: 18px;
+  flex: 0 0 auto;
+  border: 1px solid var(--line);
+  border-radius: 50%;
+  box-shadow: inset 0 0 0 2px rgba(244, 248, 251, 0.26);
+}
+
+.option-card.is-selected {
+  border-color: var(--accent);
+  background: var(--accent-soft);
+}
+
+.option-card:has(input:focus-visible) {
+  outline: 3px solid var(--accent);
+  outline-offset: 3px;
+}
+
+.order-panel {
+  position: sticky;
+  top: 96px;
+  display: grid;
+  gap: 20px;
+  border: 1px solid var(--line);
+  border-radius: var(--radius-card);
+  background: color-mix(in srgb, var(--surface) 88%, transparent);
+  padding: clamp(20px, 3vw, 28px);
+  box-shadow: var(--shadow);
+}
+
+.order-panel dl {
+  display: grid;
+  gap: 12px;
+  margin: 0;
+}
+
+.order-panel dl div,
+.total-row {
+  display: flex;
+  justify-content: space-between;
+  gap: 18px;
+}
+
+.order-panel dt,
+.total-row span {
+  color: var(--muted);
+}
+
+.order-panel dd {
+  margin: 0;
+  color: var(--ink);
+  font-weight: 760;
+  text-align: right;
+}
+
+.panel-note {
+  margin: 0;
+  border-top: 1px solid var(--line);
+  padding-top: 18px;
+  font-size: 0.95rem;
+}
+
+.total-row {
+  align-items: end;
+  border-top: 1px solid var(--line);
+  padding-top: 18px;
+}
+
+.total-row strong {
+  color: var(--ink);
+  font-size: clamp(2rem, 4vw, 3rem);
+  line-height: 1;
+}
+
+.spec-grid {
+  display: grid;
+  grid-template-columns: 1.15fr 0.85fr 0.85fr;
+  gap: 14px;
+}
+
+.spec-tile {
+  display: grid;
+  min-height: 176px;
+  align-content: space-between;
+  gap: 18px;
+  border: 1px solid var(--line);
+  border-radius: var(--radius-card);
+  background: color-mix(in srgb, var(--surface) 86%, transparent);
+  padding: clamp(18px, 3vw, 26px);
+}
+
+.spec-tile.featured {
+  grid-row: span 2;
+  background:
+    linear-gradient(145deg, color-mix(in srgb, var(--ink) 92%, var(--accent)), var(--ink-soft));
+  color: var(--button-text);
+}
+
+.spec-tile.featured p,
+.spec-tile.featured span {
+  color: color-mix(in srgb, var(--button-text) 70%, transparent);
+}
+
+.spec-tile svg {
+  color: var(--accent);
+}
+
+.spec-tile span {
+  display: block;
+  margin-bottom: 6px;
+  color: var(--muted);
+  font-size: 0.9rem;
+  font-weight: 720;
+}
+
+.spec-tile strong {
+  display: block;
+  color: inherit;
+  font-size: clamp(1.65rem, 3vw, 2.55rem);
+  line-height: 1.05;
+}
+
+.spec-tile p {
+  margin-bottom: 0;
+}
+
+.purchase-strip {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  align-items: center;
+  gap: 26px;
+  border-top: 1px solid var(--line);
+  padding-block: clamp(44px, 7vw, 74px);
+}
+
+.purchase-strip h2 {
+  max-width: 740px;
+}
+
+.purchase-strip p {
+  max-width: 610px;
+  margin-bottom: 0;
+}
+
+.site-footer {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+  border-top: 1px solid var(--line);
+  padding-block: 28px;
+  color: var(--muted);
+}
+
+.site-footer div {
+  display: grid;
+  gap: 3px;
+}
+
+.site-footer strong {
+  color: var(--ink);
+}
+
+.site-footer nav {
+  gap: 22px;
+  font-size: 0.94rem;
+}
+
+@media (prefers-reduced-motion: no-preference) {
+  .hero-copy,
+  .hero-media,
+  .product-bar {
+    animation: rise-in 650ms cubic-bezier(0.16, 1, 0.3, 1) both;
+  }
+
+  .hero-media {
+    animation-delay: 90ms;
+  }
+
+  .product-bar {
+    animation-delay: 150ms;
+  }
+
+  .option-card:hover {
+    transform: translateY(-2px);
+  }
+}
+
+@keyframes rise-in {
+  from {
+    opacity: 0;
+    transform: translateY(18px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+@media (max-width: 940px) {
+  .header-inner {
+    grid-template-columns: auto 1fr auto;
+  }
+
+  .site-header nav {
+    display: none;
+  }
+
+  .hero-section,
+  .details-layout,
+  .configure-layout,
+  .purchase-strip {
+    grid-template-columns: 1fr;
+  }
+
+  .hero-section {
+    min-height: 0;
+  }
+
+  .hero-copy {
+    max-width: 680px;
+  }
+
+  .hero-media {
+    aspect-ratio: 1.25;
+  }
+
+  .order-panel {
+    position: static;
+  }
+
+  .spec-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .spec-tile.featured {
+    grid-row: auto;
+    grid-column: 1 / -1;
+  }
+
+  .purchase-strip .button {
+    justify-self: start;
+  }
+}
+
+@media (max-width: 700px) {
+  .header-inner,
+  .hero-section,
+  .product-bar,
+  .section,
+  .purchase-strip,
+  .site-footer {
+    width: min(100% - 28px, 1180px);
+  }
+
+  .header-inner {
+    min-height: 66px;
+    gap: 12px;
+  }
+
+  .brand span {
+    font-size: 0.98rem;
+  }
+
+  .button {
+    min-height: 44px;
+    padding-inline: 15px;
+  }
+
+  .button-small {
+    min-height: 38px;
+  }
+
+  .hero-section {
+    padding-top: 28px;
+  }
+
+  h1 span:first-child {
+    font-size: clamp(3.8rem, 17vw, 5.6rem);
+  }
+
+  h1 span:last-child {
+    font-size: clamp(1.9rem, 8vw, 3rem);
+  }
+
+  .product-bar {
+    grid-template-columns: 1fr;
+  }
+
+  .product-bar div + div {
+    border-left: 0;
+    border-top: 1px solid var(--line);
+  }
+
+  .option-grid,
+  .spec-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .option-card,
+  .option-inner {
+    min-height: 124px;
+  }
+
+  .detail-list article {
+    grid-template-columns: 38px minmax(0, 1fr);
+    gap: 14px;
+  }
+
+  .detail-icon {
+    width: 38px;
+    height: 38px;
+  }
+
+  .site-footer {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .site-footer nav {
+    flex-wrap: wrap;
+  }
+}
+
+@media (max-width: 430px) {
+  .site-header .button span {
+    display: none;
+  }
+
+  .hero-actions .button,
+  .purchase-strip .button {
+    width: 100%;
+  }
+
+  .hero-media {
+    aspect-ratio: 1;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    animation-duration: 0.001ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.001ms !important;
+  }
+}
