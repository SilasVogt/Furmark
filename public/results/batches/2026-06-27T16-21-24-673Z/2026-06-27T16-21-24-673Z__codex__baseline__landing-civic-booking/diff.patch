+  background: var(--surface-raised);
+  padding: 1.25rem 1.25rem 1.25rem 4.25rem;
+  counter-increment: availability;
+}
+
+.availability-list li::before {
+  position: absolute;
+  left: 1.25rem;
+  top: 1.25rem;
+  width: 2rem;
+  height: 2rem;
+  display: grid;
+  place-items: center;
+  border-radius: var(--radius);
+  background: var(--accent);
+  color: var(--accent-text);
+  content: counter(availability);
+  font-weight: 900;
+}
+
+.availability-list p {
+  margin-bottom: 0;
+}
+
+.accessibility-layout {
+  display: grid;
+  grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
+  gap: 2rem;
+  align-items: start;
+}
+
+.commitment-list {
+  display: grid;
+  gap: 0.9rem;
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+
+.commitment-list li {
+  display: grid;
+  grid-template-columns: auto 1fr;
+  gap: 0.75rem;
+  align-items: start;
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  background: var(--surface-raised);
+  padding: 1rem;
+}
+
+.commitment-list svg {
+  width: 1.4rem;
+  height: 1.4rem;
+  margin-top: 0.1rem;
+  color: var(--accent);
+}
+
+.section--support {
+  background: var(--surface-muted);
+}
+
+.support-layout {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 1rem;
+}
+
+.support-card {
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  background: var(--surface-raised);
+  padding: 1.25rem;
+}
+
+.support-card--main {
+  grid-column: span 2;
+  grid-row: span 2;
+  display: flex;
+  min-height: 18rem;
+  flex-direction: column;
+  justify-content: flex-end;
+}
+
+.support-card > svg {
+  margin-bottom: 1rem;
+}
+
+.support-card p {
+  margin-bottom: 0;
+}
+
+.site-footer {
+  border-top: 1px solid var(--border);
+  background: var(--surface-raised);
+}
+
+.site-footer__inner {
+  min-height: 86px;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1.25rem 0;
+}
+
+.site-footer p {
+  margin-bottom: 0;
+}
+
+.site-footer a {
+  border-radius: var(--radius);
+  color: var(--accent);
+  font-weight: 800;
+  padding: 0.4rem;
+}
+
+@media (max-width: 900px) {
+  .site-header__inner {
+    align-items: flex-start;
+    flex-direction: column;
+    gap: 0.4rem;
+    padding: 0.9rem 0;
+  }
+
+  .site-nav {
+    width: 100%;
+    overflow-x: auto;
+    padding-bottom: 0.15rem;
+  }
+
+  .hero {
+    min-height: auto;
+    padding-top: 2rem;
+  }
+
+  .hero__content,
+  .availability-layout,
+  .accessibility-layout {
+    grid-template-columns: 1fr;
+  }
+
+  .booking-panel {
+    max-width: 42rem;
+  }
+
+  .availability-summary {
+    position: static;
+  }
+
+  .support-layout {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 700px) {
+  .site-header__inner,
+  .section__inner,
+  .site-footer__inner,
+  .hero {
+    width: min(1120px, calc(100% - 1rem));
+  }
+
+  .site-nav a {
+    padding-inline: 0.65rem;
+  }
+
+  .section-kicker {
+    font-size: 0.76rem;
+  }
+
+  h1 {
+    max-width: 13ch;
+    font-size: clamp(2.25rem, 13vw, 3.4rem);
+  }
+
+  .field-grid,
+  .category-grid,
+  .support-layout {
+    grid-template-columns: 1fr;
+  }
+
+  .category-item {
+    min-height: auto;
+  }
+
+  .support-card--main {
+    grid-column: auto;
+    grid-row: auto;
+    min-height: auto;
+  }
+
+  .hero__actions,
+  .site-footer__inner {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .hero__actions .button {
+    width: 100%;
+  }
+}
