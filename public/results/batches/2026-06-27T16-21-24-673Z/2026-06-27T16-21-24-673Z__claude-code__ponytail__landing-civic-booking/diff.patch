diff --git a/src/style.css b/src/style.css
index 6a6f6bd..d89967f 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,199 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  --ink: #1f2937;        /* body text on white: ~12.6:1 */
+  --muted: #475569;      /* helper text on white: ~7.4:1 */
+  --brand: #1d4ed8;      /* links / primary: white text ~5.2:1 */
+  --brand-dark: #1e40af; /* hover */
+  --line: #94a3b8;
+  --band: #f1f5f9;
+  --hero: #eff6ff;
+  --footer: #0f2540;
+}
+
+* { box-sizing: border-box; }
+
+body {
+  margin: 0;
+  font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
+  color: var(--ink);
+  line-height: 1.55;
+  background: #fff;
+}
+
+h1, h2, h3 { line-height: 1.2; color: var(--ink); }
+h1 { font-size: clamp(1.7rem, 4vw, 2.5rem); }
+h2 { font-size: clamp(1.4rem, 3vw, 1.9rem); }
+
+p { margin: 0.5rem 0; }
+a { color: var(--brand); }
+a:hover { color: var(--brand-dark); }
+
+/* Visible focus everywhere, on light and dark backgrounds. */
+:focus-visible {
+  outline: 3px solid var(--brand);
+  outline-offset: 2px;
+  border-radius: 4px;
+}
+
+.container { width: 100%; max-width: 1080px; margin: 0 auto; padding: 0 1.25rem; }
+.narrow { max-width: 760px; }
+
+/* Skip link */
+.skip-link {
+  position: absolute;
+  left: 0.75rem;
+  top: -3rem;
+  z-index: 100;
+  background: var(--brand);
+  color: #fff;
+  padding: 0.6rem 1rem;
+  border-radius: 0 0 6px 6px;
+  text-decoration: none;
+  transition: top 0.15s ease;
+}
+.skip-link:focus { top: 0; }
+
+/* Header */
+header {
+  position: sticky;
+  top: 0;
+  z-index: 50;
+  background: #fff;
+  border-bottom: 1px solid #e2e8f0;
+}
+.header-inner {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  justify-content: space-between;
+  gap: 0.5rem 1rem;
+  padding-top: 0.75rem;
+  padding-bottom: 0.75rem;
+}
+.brand { font-size: 1.25rem; font-weight: 700; color: var(--ink); text-decoration: none; }
+header nav ul {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.25rem 1.25rem;
+  list-style: none;
+  margin: 0;
+  padding: 0;
+}
+header nav a { text-decoration: none; padding: 0.25rem 0; }
+header nav a:hover { text-decoration: underline; }
+
+/* Sections */
+section { padding: 2.75rem 0; }
+.band { background: var(--band); }
+.hero { background: var(--hero); }
+.lead { color: var(--muted); max-width: 65ch; }
+
+/* Hero layout */
+.hero-grid { display: grid; gap: 2rem; }
+.hero-copy p { max-width: 60ch; }
+
+/* Lists with clear markers */
+.checklist { list-style: none; margin: 1rem 0 0; padding: 0; }
+.checklist li {
+  position: relative;
+  padding-left: 1.9rem;
+  margin: 0.6rem 0;
+  max-width: 62ch;
+}
+.checklist li::before {
+  content: "";
+  position: absolute;
+  left: 0;
+  top: 0.45em;
+  width: 0.7rem;
+  height: 0.4rem;
+  border-left: 3px solid var(--brand);
+  border-bottom: 3px solid var(--brand);
+  transform: rotate(-45deg);
+}
+
+/* Cards / categories */
+.card {
+  background: #fff;
+  border: 1px solid #cbd5e1;
+  border-radius: 10px;
+  padding: 1.25rem;
+}
+.cards {
+  list-style: none;
+  margin: 1.5rem 0 0;
+  padding: 0;
+  display: grid;
+  gap: 1rem;
+  grid-template-columns: 1fr;
+}
+.category h3 { margin: 0 0 0.35rem; font-size: 1.1rem; }
+.category p { margin: 0; color: var(--muted); }
+
+/* Booking form */
+.booking { box-shadow: 0 1px 3px rgba(15, 37, 64, 0.12); }
+.booking h2 { margin-top: 0; }
+.field { margin: 1.1rem 0; }
+.field label { display: block; font-weight: 600; margin-bottom: 0.15rem; }
+.help { margin: 0 0 0.4rem; color: var(--muted); font-size: 0.9rem; }
+.field input,
+.field select {
+  width: 100%;
+  padding: 0.6rem 0.7rem;
+  font-size: 1rem;
+  color: var(--ink);
+  background: #fff;
+  border: 1px solid var(--line);
+  border-radius: 6px;
+}
+.field input:focus-visible,
+.field select:focus-visible { border-color: var(--brand); }
+
+.btn {
+  display: inline-block;
+  width: 100%;
+  margin-top: 0.5rem;
+  padding: 0.7rem 1.2rem;
+  font-size: 1rem;
+  font-weight: 600;
+  color: #fff;
+  background: var(--brand);
+  border: 1px solid var(--brand);
+  border-radius: 6px;
+  cursor: pointer;
+}
+.btn:hover { background: var(--brand-dark); border-color: var(--brand-dark); }
+
+.note { color: var(--muted); font-size: 0.85rem; margin-top: 0.75rem; }
+.summary:not(:empty) {
+  margin-top: 0.75rem;
+  padding: 0.75rem;
+  background: #ecfdf5;
+  border: 1px solid #047857;
+  border-radius: 6px;
+  color: #064e3b;
+}
+
+/* Contact list */
+.contact { margin: 1.5rem 0 0; padding: 0; display: grid; gap: 1rem; }
+.contact dt { font-weight: 700; }
+.contact dd { margin: 0.15rem 0 0; color: var(--ink); }
+
+/* Footer */
+footer { background: var(--footer); color: #e6eef7; padding: 2rem 0; }
+.footer-inner p { margin: 0.35rem 0; max-width: 65ch; }
+footer a { color: #cfe2ff; }
+footer a:hover { color: #fff; }
+footer :focus-visible { outline-color: #fff; }
+
+/* Responsive */
+@media (min-width: 640px) {
+  .cards { grid-template-columns: repeat(2, 1fr); }
+}
+@media (min-width: 880px) {
+  .hero-grid { grid-template-columns: 1.1fr 0.9fr; align-items: start; }
+  .cards { grid-template-columns: repeat(3, 1fr); }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  * { transition: none !important; }
+}
