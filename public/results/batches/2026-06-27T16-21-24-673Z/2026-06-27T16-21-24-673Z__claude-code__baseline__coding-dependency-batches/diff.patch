+/**
+ * Group the nodes of a dependency graph into batches that can run in parallel.
+ *
+ * Each returned batch may execute concurrently, but only once every earlier
+ * batch has completed (a node always appears in a later batch than all of its
+ * dependencies). Within a batch nodes are sorted alphabetically so the result
+ * is deterministic regardless of input ordering. Dependencies that are only
+ * referenced — never declared as a key — are treated as leaf nodes and included
+ * in the output.
+ *
+ * @throws {DependencyCycleError} if the graph contains a cycle.
+ */
 export function dependencyBatches(graph: DependencyGraph): string[][] {
+  // Collect every node, including dependencies that are only referenced.
