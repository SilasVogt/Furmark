+  background-clip: text;
+  -webkit-text-fill-color: transparent;
+}
+.lede {
+  font-size: 18px;
+  color: var(--muted);
+  max-width: 540px;
+  margin: 0 0 30px;
+}
+.hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 38px; }
+
+.hero-stats {
+  display: flex;
+  gap: 36px;
+  list-style: none;
+  margin: 0; padding: 24px 0 0;
+  border-top: 1px solid var(--line);
+}
+.hero-stats li { display: flex; flex-direction: column; }
+.hero-stats strong {
+  font-size: 22px;
+  font-family: var(--mono);
+  color: var(--text);
+}
+.hero-stats span { font-size: 13px; color: var(--muted-2); }
+
+/* ---------- Console mock ---------- */
+.hero-visual { position: relative; }
+.console {
+  background: var(--panel);
+  border: 1px solid var(--line-2);
+  border-radius: 14px;
+  overflow: hidden;
+  box-shadow: 0 40px 80px -30px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(92, 242, 196, 0.04);
+  font-size: 13px;
+}
+.console-bar {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 11px 14px;
+  background: var(--bg-2);
+  border-bottom: 1px solid var(--line);
+}
+.dot { width: 11px; height: 11px; border-radius: 50%; }
+.dot.red { background: #ff5f57; }
+.dot.amber { background: #febc2e; }
+.dot.green { background: #28c840; }
+.console-title {
+  margin-left: 10px;
+  font-family: var(--mono);
+  font-size: 12px;
+  color: var(--muted);
+}
+.console-status {
+  margin-left: auto;
+  font-family: var(--mono);
+  font-size: 11px;
+  color: var(--ok);
+  letter-spacing: 0.04em;
+}
+
+.console-body { display: grid; grid-template-columns: 168px 1fr; }
+
+.console-side {
+  border-right: 1px solid var(--line);
+  padding: 14px;
+  background: var(--bg-2);
+}
+.side-search {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  color: var(--muted-2);
+  font-size: 12px;
+  padding: 7px 9px;
+  border: 1px solid var(--line);
+  border-radius: 7px;
+  margin-bottom: 14px;
+}
+.side-filters { list-style: none; margin: 0 0 18px; padding: 0; }
+.side-filters li {
+  display: flex;
+  justify-content: space-between;
+  padding: 6px 8px;
+  font-size: 12.5px;
+  color: var(--muted);
+  border-radius: 6px;
+  cursor: default;
+}
+.side-filters li.active { background: var(--panel-2); color: var(--text); }
+.side-filters li span { font-family: var(--mono); color: var(--muted-2); }
+.side-filters li.active span { color: var(--accent); }
+
+.side-graph {
+  border-top: 1px solid var(--line);
+  padding-top: 14px;
+}
+.side-graph svg { width: 100%; height: 48px; display: block; }
+.graph-label {
+  display: block;
+  font-family: var(--mono);
+  font-size: 10.5px;
+  color: var(--muted-2);
+  margin-top: 6px;
+}
+
+.console-main { padding: 14px; min-width: 0; }
+.console-meta {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+  margin-bottom: 14px;
+}
+.chip {
+  display: inline-flex;
+  align-items: center;
+  gap: 5px;
+  font-size: 11px;
+  padding: 4px 9px;
+  border-radius: 6px;
+  background: var(--panel-2);
+  color: var(--muted);
+  border: 1px solid var(--line);
+}
+.chip-red { color: var(--danger); border-color: rgba(255, 107, 107, 0.3); background: rgba(255, 107, 107, 0.08); }
+.chip-mono { font-family: var(--mono); }
+.chip-time { font-family: var(--mono); color: var(--muted-2); border: none; background: none; }
+
+.timeline { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
+.tl-row {
+  display: grid;
+  grid-template-columns: 62px 18px 56px 1fr auto;
+  align-items: center;
+  gap: 10px;
+  padding: 9px 4px;
+  border-bottom: 1px dashed var(--line);
+  font-size: 12.5px;
+}
+.tl-time { font-family: var(--mono); color: var(--muted-2); font-size: 11px; }
+.tl-dot {
+  display: grid;
+  place-items: center;
+  width: 18px; height: 18px;
+  border-radius: 50%;
+  background: var(--panel-2);
+  color: var(--muted);
+}
+.tl-kind {
+  font-family: var(--mono);
+  font-size: 10.5px;
+  text-transform: uppercase;
+  letter-spacing: 0.05em;
+  color: var(--muted-2);
+}
+.tl-title { color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.tl-meta { font-family: var(--mono); font-size: 11px; color: var(--muted-2); }
+
+.tl-deploy .tl-dot { background: rgba(78, 162, 255, 0.15); color: var(--accent-2); }
+.tl-deploy .tl-kind { color: var(--accent-2); }
+.tl-error .tl-dot { background: rgba(255, 107, 107, 0.15); color: var(--danger); }
+.tl-error .tl-kind { color: var(--danger); }
+.tl-error .tl-meta { color: var(--danger); }
+.tl-warn .tl-dot { background: rgba(255, 180, 84, 0.15); color: var(--warn); }
+.tl-warn .tl-kind { color: var(--warn); }
+.tl-trace .tl-dot { background: rgba(92, 242, 196, 0.1); color: var(--accent); }
+.tl-trace .tl-kind { color: var(--accent); }
+.tl-ok .tl-dot { background: rgba(92, 242, 196, 0.15); color: var(--ok); }
+.tl-ok .tl-kind { color: var(--ok); }
+
+.console-foot {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 10px;
+  margin-top: 12px;
+  padding-top: 12px;
+  border-top: 1px solid var(--line);
+  font-size: 12px;
+  color: var(--muted);
+}
+.console-foot span { display: inline-flex; align-items: center; gap: 6px; }
+.foot-link { color: var(--accent); font-weight: 600; }
+
+/* ---------- Logos ---------- */
+.logos {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 14px;
+  padding: 40px 0;
+  border-top: 1px solid var(--line);
+  text-align: center;
+}
+.logos > span { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted-2); }
+.logo-row { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 18px; color: var(--muted); font-weight: 600; letter-spacing: 0.02em; }
+
+/* ---------- Features ---------- */
+.feature-grid {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 1px;
+  background: var(--line);
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  overflow: hidden;
+}
+.feature {
+  background: var(--bg);
+  padding: 28px 26px;
+  transition: background 0.15s;
+}
+.feature:hover { background: var(--panel); }
+.feature-icon {
+  display: inline-grid;
+  place-items: center;
+  width: 38px; height: 38px;
+  border-radius: 9px;
+  background: linear-gradient(135deg, rgba(92, 242, 196, 0.14), rgba(78, 162, 255, 0.14));
+  color: var(--accent);
+  margin-bottom: 16px;
+}
+.feature h3 { font-size: 17px; margin: 0 0 8px; letter-spacing: -0.01em; }
+.feature p { margin: 0; color: var(--muted); font-size: 14.5px; }
+
+/* ---------- Workflow ---------- */
+.workflow-grid {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  grid-template-columns: repeat(4, 1fr);
+  gap: 16px;
+}
+.step {
+  position: relative;
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  padding: 24px;
+}
+.step-n {
+  font-family: var(--mono);
+  font-size: 12px;
+  color: var(--accent);
+  letter-spacing: 0.05em;
+}
+.step-body h3 { font-size: 17px; margin: 10px 0 8px; }
+.step-body p { margin: 0; color: var(--muted); font-size: 14px; }
+.step-arrow {
+  position: absolute;
+  right: -14px;
+  top: 50%;
+  transform: translateY(-50%);
+  color: var(--line-2);
+  z-index: 2;
+  background: var(--bg);
+  border-radius: 50%;
+}
+
+/* ---------- CTA ---------- */
+.cta { border-top: 1px solid var(--line); }
+.cta-card {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 28px;
+  background: linear-gradient(135deg, rgba(92, 242, 196, 0.08), rgba(78, 162, 255, 0.06));
+  border: 1px solid var(--line-2);
+  border-radius: 18px;
+  padding: 40px 44px;
+}
+.cta-card h2 { font-size: clamp(22px, 3vw, 30px); margin: 0 0 8px; letter-spacing: -0.02em; }
+.cta-card p { margin: 0; color: var(--muted); }
+.cta-actions { display: flex; gap: 10px; flex-shrink: 0; }
+
+/* ---------- Footer ---------- */
+.footer {
+  border-top: 1px solid var(--line);
+  background: var(--bg-2);
+  padding: 56px 28px 28px;
+  color: var(--muted);
+}
+.footer-grid {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  display: grid;
+  grid-template-columns: 1.6fr repeat(3, 1fr);
+  gap: 36px;
+}
+.footer-brand p { margin: 14px 0 18px; font-size: 14px; max-width: 280px; }
+.social { display: flex; gap: 10px; }
+.social a {
+  display: grid; place-items: center;
+  width: 32px; height: 32px;
+  border: 1px solid var(--line-2);
+  border-radius: 8px;
+  color: var(--muted);
+}
+.social a:hover { color: var(--accent); border-color: var(--accent); }
+.footer h4 { font-size: 13px; color: var(--text); margin: 0 0 14px; letter-spacing: 0.02em; }
+.footer-grid a { display: block; padding: 5px 0; font-size: 14px; color: var(--muted); }
+.footer-grid a:hover { color: var(--text); }
+.footer-bottom {
+  max-width: var(--maxw);
+  margin: 40px auto 0;
+  padding-top: 22px;
+  border-top: 1px solid var(--line);
+  display: flex;
+  justify-content: space-between;
+  flex-wrap: wrap;
+  gap: 12px;
+  font-size: 13px;
+  color: var(--muted-2);
+}
+.footer-legal { display: flex; gap: 18px; }
+
+/* ---------- Responsive ---------- */
+@media (max-width: 960px) {
+  .hero { grid-template-columns: 1fr; gap: 40px; padding: 48px 0; }
+  .feature-grid { grid-template-columns: repeat(2, 1fr); }
+  .workflow-grid { grid-template-columns: repeat(2, 1fr); }
+  .step-arrow { display: none; }
+  .footer-grid { grid-template-columns: 1fr 1fr; }
+}
+
+@media (max-width: 760px) {
+  .nav-links { display: none; }
+  .link-login { display: none; }
+  .nav-cta .btn-sm { display: none; }
+  .nav-toggle { display: flex; }
+  .nav { padding: 12px 18px; }
+  .nav-mobile { display: flex; }
+  main { padding: 0 18px; }
+  .section { padding: 64px 0; }
+  .console-body { grid-template-columns: 1fr; }
+  .console-side { display: none; }
+  .cta-card { flex-direction: column; align-items: flex-start; padding: 30px 26px; }
+}
+
+@media (max-width: 560px) {
+  .feature-grid { grid-template-columns: 1fr; }
+  .workflow-grid { grid-template-columns: 1fr; }
+  .footer-grid { grid-template-columns: 1fr 1fr; gap: 28px; }
+  .hero-stats { gap: 22px; }
+  .hero-stats strong { font-size: 18px; }
+  .tl-row { grid-template-columns: 50px 16px 1fr; }
+  .tl-row .tl-kind { display: none; }
+  .tl-row .tl-meta { display: none; }
+  .console-meta { gap: 5px; }
+  .chip-time { display: none; }
+  .console-title { font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
+  .console-bar { min-width: 0; }
+  .console-status { font-size: 10px; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *, *::before, *::after {
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.01ms !important;
+    scroll-behavior: auto !important;
+  }
+}
