+.choice.is-selected {
+  background: #ffffff;
+  border-color: #0a1010;
+}
+
+.choice input {
+  inset: 0;
+  opacity: 0;
+  position: absolute;
+}
+
+.choice-icon,
+.finish-swatch {
+  align-items: center;
+  border-radius: 50%;
+  display: inline-flex;
+  flex: 0 0 auto;
+  height: 28px;
+  justify-content: center;
+  width: 28px;
+}
+
+.choice-icon {
+  background: #dfe7e5;
+  color: #0e5e64;
+}
+
+.choice.is-selected .choice-icon {
+  background: #081010;
+  color: #ffffff;
+}
+
+.finish-swatch {
+  border: 1px solid rgba(7, 12, 12, 0.25);
+  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.52);
+}
+
+.choice.is-selected .finish-swatch {
+  outline: 3px solid rgba(68, 227, 238, 0.62);
+  outline-offset: 2px;
+}
+
+.choice strong,
+.choice small {
+  display: block;
+}
+
+.choice strong {
+  font-size: 0.98rem;
+  line-height: 1.2;
+}
+
+.choice small {
+  color: #586462;
+  font-size: 0.85rem;
+  line-height: 1.35;
+  margin-top: 5px;
+}
+
+.order-panel {
+  align-items: center;
+  border-top: 1px solid var(--line-dark);
+  display: flex;
+  gap: 18px;
+  justify-content: space-between;
+  margin-top: 6px;
+  padding-top: 22px;
+}
+
+.order-panel div {
+  display: grid;
+  gap: 3px;
+}
+
+.order-panel strong {
+  font-size: 2.3rem;
+  line-height: 1;
+}
+
+.specs-section {
+  background: var(--paper-2);
+  padding-top: 18px;
+}
+
+.spec-grid {
+  display: grid;
+  gap: 14px;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+}
+
+.spec-tile {
+  min-height: 222px;
+  padding: 24px;
+}
+
+.spec-tile strong {
+  display: block;
+  font-size: 2.35rem;
+  line-height: 1;
+  margin: 20px 0 18px;
+}
+
+.spec-tile p {
+  color: #53605f;
+  line-height: 1.52;
+  margin: 0;
+}
+
+.reserve-section {
+  align-items: center;
+  background:
+    linear-gradient(100deg, rgba(68, 227, 238, 0.2), transparent 30%),
+    #070909;
+  color: #f7fafa;
+  display: grid;
+  gap: 32px;
+  grid-template-columns: minmax(0, 1fr) auto;
+  padding: 72px 64px;
+}
+
+.reserve-section h2 {
+  font-size: 3rem;
+}
+
+.reserve-section p {
+  color: #b8c2c0;
+  line-height: 1.58;
+  margin-bottom: 0;
+  max-width: 62ch;
+}
+
+.reserve-buy {
+  justify-content: flex-end;
+}
+
+.reserve-buy span {
+  color: #d4dddd;
+  font-weight: 740;
+}
+
+@media (max-width: 1180px) {
+  .topbar,
+  .hero,
+  .system-strip,
+  .config-section,
+  .specs-section {
+    padding-left: 36px;
+    padding-right: 36px;
+  }
+
+  h1 {
+    font-size: 4.6rem;
+  }
+
+  h2 {
+    font-size: 2.8rem;
+  }
+
+  .choice-row,
+  .spec-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 920px) {
+  .hero {
+    gap: 30px;
+    grid-template-columns: 1fr;
+    min-height: auto;
+    padding-bottom: 48px;
+  }
+
+  .hero-copy {
+    max-width: 720px;
+  }
+
+  h1 {
+    font-size: 4rem;
+    max-width: 12ch;
+  }
+
+  .hero-visual {
+    aspect-ratio: 16 / 9;
+  }
+
+  .system-strip,
+  .config-layout {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .config-preview {
+    min-height: 460px;
+  }
+
+  .reserve-section {
+    grid-template-columns: 1fr;
+  }
+
+  .reserve-buy {
+    justify-content: flex-start;
+  }
+}
+
+@media (max-width: 720px) {
+  .topbar {
+    gap: 16px;
+    height: 64px;
+    padding-left: 20px;
+    padding-right: 20px;
+  }
+
+  .topbar nav {
+    display: none;
+  }
+
+  .hero,
+  .config-section,
+  .specs-section {
+    padding-left: 20px;
+    padding-right: 20px;
+  }
+
+  .hero {
+    padding-top: 18px;
+  }
+
+  h1 {
+    font-size: 3.15rem;
+    line-height: 0.98;
+    max-width: 10ch;
+  }
+
+  h2,
+  .reserve-section h2 {
+    font-size: 2.25rem;
+    line-height: 1.04;
+  }
+
+  .hero-text {
+    font-size: 1rem;
+  }
+
+  .system-strip,
+  .config-layout,
+  .choice-row,
+  .spec-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .system-strip {
+    padding: 0 20px;
+  }
+
+  .system-part {
+    border-left: 0;
+    border-top: 1px solid var(--line-dark);
+  }
+
+  .system-part:first-child {
+    border-top: 0;
+  }
+
+  .system-part:last-child {
+    border-right: 0;
+  }
+
+  .config-section,
+  .specs-section {
+    padding-bottom: 64px;
+    padding-top: 64px;
+  }
+
+  .config-preview,
+  .configurator {
+    padding: 20px;
+  }
+
+  .config-preview {
+    min-height: 390px;
+  }
+
+  .order-panel {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .order-panel .button {
+    width: 100%;
+  }
+
+  .reserve-section {
+    margin: 0;
+    padding: 56px 20px;
+  }
+}
+
+@media (max-width: 460px) {
+  .hero-actions,
+  .reserve-buy {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .hero-actions .button,
+  .reserve-buy .button,
+  .nav-cta {
+    width: 100%;
+  }
+
+  .topbar {
+    align-items: stretch;
+    height: auto;
+    padding-bottom: 14px;
+    padding-top: 14px;
+  }
+
+  .brand {
+    flex: 1;
+  }
+
+  h1 {
+    font-size: 2.65rem;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    transition-duration: 0.01ms !important;
+  }
+}
