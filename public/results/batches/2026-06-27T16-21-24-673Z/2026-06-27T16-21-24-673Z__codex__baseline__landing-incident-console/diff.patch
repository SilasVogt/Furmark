+.workflow-card p,
+.assurance-item p {
+  margin: 10px 0 0;
+  color: var(--muted);
+}
+
+.detail-list {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  margin: auto 0 0;
+  padding: 24px 0 0;
+  list-style: none;
+}
+
+.detail-list li {
+  border: 1px solid rgb(255 255 255 / 0.09);
+  border-radius: var(--radius);
+  background: rgb(0 0 0 / 0.18);
+  color: var(--muted);
+  padding: 7px 9px;
+  font-size: 0.86rem;
+}
+
+.workflow-section {
+  background:
+    linear-gradient(180deg, transparent, rgb(85 214 170 / 0.04) 40%, transparent),
+    var(--bg);
+}
+
+.workflow-layout {
+  display: grid;
+  grid-template-columns: minmax(260px, 0.74fr) minmax(0, 1.26fr);
+  gap: 34px;
+  align-items: start;
+}
+
+.workflow-intro {
+  position: sticky;
+  top: 92px;
+  color: var(--accent-strong);
+}
+
+.workflow-intro h2,
+.workflow-intro p {
+  color: var(--text);
+}
+
+.workflow-intro p {
+  color: var(--muted);
+}
+
+.workflow-track {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 14px;
+}
+
+.workflow-card {
+  min-height: 210px;
+  padding: 22px;
+  color: var(--accent-strong);
+}
+
+.workflow-card p {
+  color: var(--muted);
+}
+
+.split-section {
+  padding-top: 86px;
+}
+
+.split-layout {
+  display: grid;
+  grid-template-columns: minmax(0, 0.86fr) minmax(380px, 1.14fr);
+  gap: clamp(28px, 6vw, 74px);
+  align-items: start;
+}
+
+.assurance-copy {
+  max-width: 560px;
+}
+
+.text-link {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  margin-top: 24px;
+  border-bottom: 1px solid rgb(85 214 170 / 0.5);
+  color: var(--accent-strong);
+  font-weight: 740;
+  padding-bottom: 4px;
+}
+
+.text-link:hover {
+  color: var(--text);
+}
+
+.assurance-panel {
+  display: grid;
+  gap: 12px;
+}
+
+.assurance-item {
+  display: grid;
+  grid-template-columns: auto 1fr;
+  gap: 16px;
+  align-items: start;
+  padding: 20px;
+}
+
+.assurance-item h3 {
+  margin-top: 0;
+}
+
+.cta-section {
+  padding: 74px 0;
+}
+
+.cta-layout {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 30px;
+  align-items: center;
+  border: 1px solid rgb(85 214 170 / 0.28);
+  border-radius: var(--radius);
+  background:
+    linear-gradient(135deg, rgb(85 214 170 / 0.13), rgb(255 255 255 / 0.035) 52%, rgb(241 173 61 / 0.05)),
+    var(--surface-strong);
+  padding: clamp(24px, 5vw, 44px);
+}
+
+.site-footer {
+  border-top: 1px solid var(--line);
+  padding: 28px 0;
+}
+
+.footer-layout {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+}
+
+.footer-links {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  justify-content: flex-end;
+  gap: 4px;
+}
+
+@media (prefers-reduced-motion: no-preference) {
+  .hero-copy > *,
+  .hero-visual {
+    animation: enter-up 520ms cubic-bezier(0.16, 1, 0.3, 1) both;
+  }
+
+  .hero-copy p {
+    animation-delay: 80ms;
+  }
+
+  .hero-actions {
+    animation-delay: 140ms;
+  }
+
+  .hero-visual {
+    animation-delay: 180ms;
+  }
+}
+
+@keyframes enter-up {
+  from {
+    opacity: 0;
+    transform: translateY(18px);
+  }
+
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+@media (max-width: 980px) {
+  .hero-section {
+    align-items: start;
+    min-height: auto;
+    padding-top: 34px;
+  }
+
+  .hero-grid,
+  .signal-layout,
+  .workflow-layout,
+  .split-layout,
+  .cta-layout {
+    grid-template-columns: 1fr;
+  }
+
+  .hero-copy h1 {
+    max-width: 11ch;
+  }
+
+  .workflow-intro {
+    position: static;
+  }
+
+  .cta-layout {
+    justify-items: start;
+  }
+}
+
+@media (max-width: 760px) {
+  .container,
+  .nav-shell {
+    width: min(100% - 32px, 1180px);
+  }
+
+  .site-header {
+    backdrop-filter: blur(12px);
+  }
+
+  .nav-shell {
+    height: 64px;
+    gap: 12px;
+  }
+
+  .nav-links {
+    display: none;
+  }
+
+  .brand {
+    font-size: 0.98rem;
+  }
+
+  .brand-mark {
+    width: 32px;
+    height: 32px;
+  }
+
+  .button {
+    min-height: 44px;
+    padding-inline: 15px;
+  }
+
+  .button--small {
+    min-height: 38px;
+    padding-inline: 12px;
+  }
+
+  .hero-section {
+    padding: 28px 0 22px;
+  }
+
+  .hero-grid {
+    gap: 26px;
+  }
+
+  .hero-copy h1 {
+    max-width: 10ch;
+    font-size: clamp(2.75rem, 13vw, 4.05rem);
+    line-height: 1;
+  }
+
+  .hero-copy p {
+    margin-top: 18px;
+    font-size: 1rem;
+  }
+
+  .hero-actions {
+    margin-top: 22px;
+  }
+
+  .hero-actions .button {
+    flex: 1 1 160px;
+  }
+
+  .signal-section {
+    padding-bottom: 48px;
+  }
+
+  .source-matrix,
+  .feature-grid,
+  .workflow-track {
+    grid-template-columns: 1fr;
+  }
+
+  .feature-card--large,
+  .feature-card--wide {
+    grid-column: auto;
+  }
+
+  .feature-card,
+  .workflow-card {
+    min-height: auto;
+  }
+
+  .section {
+    padding: 54px 0;
+  }
+
+  .section-header {
+    margin-bottom: 24px;
+  }
+
+  .section-header h2,
+  .workflow-intro h2,
+  .assurance-copy h2,
+  .cta-layout h2 {
+    font-size: clamp(2rem, 10vw, 3rem);
+  }
+
+  .assurance-item {
+    grid-template-columns: 1fr;
+  }
+
+  .footer-layout {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .footer-links {
+    justify-content: flex-start;
+  }
+}
+
+@media (max-width: 430px) {
+  .container,
+  .nav-shell {
+    width: min(100% - 28px, 1180px);
+  }
+
+  .nav-shell .button svg {
+    display: none;
+  }
+
+  .source-matrix span {
+    min-height: 44px;
+  }
+
+  .feature-card,
+  .workflow-card,
+  .assurance-item {
+    padding: 18px;
+  }
+
+  .cta-layout {
+    padding: 22px;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.01ms !important;
+  }
+}
