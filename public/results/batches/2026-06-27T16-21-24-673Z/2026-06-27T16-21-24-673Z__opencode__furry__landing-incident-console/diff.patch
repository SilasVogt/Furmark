+
+.feature p {
+  color: var(--text-dim);
+  font-size: 14.5px;
+}
+
+.feature .tag {
+  margin-top: 16px;
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  font-family: var(--mono);
+  font-size: 11px;
+  color: var(--text-faint);
+}
+
+.feature .tag code {
+  background: var(--bg-3);
+  border: 1px solid var(--border);
+  padding: 2px 6px;
+  border-radius: 4px;
+  color: var(--text-dim);
+}
+
+/* large feature */
+.feature.wide {
+  grid-column: span 3;
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 28px;
+  align-items: center;
+}
+
+/* ---------- Workflow ---------- */
+.workflow {
+  display: grid;
+  grid-template-columns: repeat(4, 1fr);
+  gap: 0;
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  overflow: hidden;
+  background: var(--bg-1);
+}
+
+.step {
+  padding: 28px 24px;
+  border-right: 1px solid var(--border);
+  position: relative;
+  min-width: 0;
+}
+
+.step:last-child {
+  border-right: none;
+}
+
+.step .num {
+  font-family: var(--mono);
+  font-size: 12px;
+  color: var(--brand);
+  letter-spacing: 0.1em;
+}
+
+.step h3 {
+  margin: 12px 0 8px;
+  font-size: 17px;
+}
+
+.step p {
+  color: var(--text-dim);
+  font-size: 14px;
+}
+
+.step .conn {
+  position: absolute;
+  top: 40px;
+  right: -10px;
+  color: var(--border-2);
+  z-index: 2;
+  background: var(--bg-1);
+}
+
+/* ---------- Metrics ---------- */
+.metrics {
+  display: grid;
+  grid-template-columns: repeat(4, 1fr);
+  gap: 1px;
+  background: var(--border);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  overflow: hidden;
+}
+
+.metric {
+  background: var(--bg-1);
+  padding: 30px 24px;
+}
+
+.metric .big {
+  font-family: var(--mono);
+  font-size: clamp(28px, 3.4vw, 38px);
+  font-weight: 700;
+  letter-spacing: -0.02em;
+  background: linear-gradient(180deg, #fff, var(--text-dim));
+  -webkit-background-clip: text;
+  background-clip: text;
+  color: transparent;
+}
+
+.metric .big.brand {
+  background: linear-gradient(180deg, var(--brand), var(--brand-2));
+  -webkit-background-clip: text;
+  background-clip: text;
+}
+
+.metric .desc {
+  margin-top: 8px;
+  color: var(--text-dim);
+  font-size: 13.5px;
+}
+
+/* ---------- CTA ---------- */
+.cta-card {
+  position: relative;
+  border-radius: 16px;
+  border: 1px solid var(--border-2);
+  background:
+    radial-gradient(600px 300px at 80% -20%, rgba(255, 138, 61, 0.18), transparent 60%),
+    linear-gradient(180deg, #0d121b, #090d14);
+  padding: 56px 40px;
+  text-align: center;
+  overflow: hidden;
+}
+
+.cta-card::before {
+  content: "";
+  position: absolute;
+  inset: 0;
+  background-image:
+    linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
+    linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
+  background-size: 40px 40px;
+  -webkit-mask-image: radial-gradient(500px 280px at 50% 0%, #000, transparent 70%);
+  mask-image: radial-gradient(500px 280px at 50% 0%, #000, transparent 70%);
+}
+
+.cta-card > * {
+  position: relative;
+}
+
+.cta-card h2 {
+  font-size: clamp(26px, 3.6vw, 40px);
+}
+
+.cta-card p {
+  margin: 14px auto 0;
+  max-width: 52ch;
+  color: var(--text-dim);
+}
+
+.cta-card .hero-ctas {
+  justify-content: center;
+}
+
+/* ---------- Footer ---------- */
+footer {
+  border-top: 1px solid var(--border);
+  padding: 48px 0 32px;
+  background: var(--bg-1);
+}
+
+.foot-grid {
+  display: grid;
+  grid-template-columns: 1.6fr repeat(3, 1fr);
+  gap: 36px;
+}
+
+.foot-about p {
+  color: var(--text-dim);
+  font-size: 13.5px;
+  margin-top: 14px;
+  max-width: 34ch;
+}
+
+.foot-col h4 {
+  font-family: var(--mono);
+  font-size: 11px;
+  letter-spacing: 0.1em;
+  text-transform: uppercase;
+  color: var(--text-faint);
+  margin-bottom: 14px;
+}
+
+.foot-col a {
+  display: block;
+  color: var(--text-dim);
+  font-size: 14px;
+  padding: 5px 0;
+}
+
+.foot-col a:hover {
+  color: var(--text);
+}
+
+.foot-bottom {
+  margin-top: 40px;
+  padding-top: 20px;
+  border-top: 1px solid var(--border);
+  display: flex;
+  justify-content: space-between;
+  gap: 14px;
+  flex-wrap: wrap;
+  font-family: var(--mono);
+  font-size: 12px;
+  color: var(--text-faint);
+}
+
+/* ---------- Responsive ---------- */
+@media (max-width: 980px) {
+  .hero-grid {
+    grid-template-columns: 1fr;
+    gap: 40px;
+  }
+  .feature.wide {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (max-width: 860px) {
+  .nav-links,
+  .nav-cta .btn-ghost,
+  .nav-cta .btn-primary span.signin {
+    display: none;
+  }
+  .nav-toggle {
+    display: inline-flex;
+  }
+  .nav-cta .btn-primary {
+    padding: 9px 14px;
+  }
+  .feature-grid {
+    grid-template-columns: repeat(2, 1fr);
+  }
+  .feature.wide {
+    grid-column: span 2;
+  }
+  .workflow {
+    grid-template-columns: repeat(2, 1fr);
+  }
+  .step:nth-child(2) {
+    border-right: none;
+  }
+  .step:nth-child(-n + 2) {
+    border-bottom: 1px solid var(--border);
+  }
+  .step .conn {
+    display: none;
+  }
+  .metrics {
+    grid-template-columns: repeat(2, 1fr);
+  }
+  .foot-grid {
+    grid-template-columns: 1fr 1fr;
+  }
+  .foot-about {
+    grid-column: 1 / -1;
+  }
+}
+
+@media (max-width: 560px) {
+.skip-link {
+  position: absolute;
+  left: -999px;
+  top: 8px;
+  z-index: 100;
+  background: var(--brand);
+  color: #1a1206;
+  padding: 10px 16px;
+  border-radius: 6px;
+  font-weight: 600;
+  font-size: 14px;
+}
+
+.skip-link:focus {
+  left: 12px;
+}
+
+.wrap {
+    padding-inline: 18px;
+  }
+  .hero {
+    padding: 40px 0 40px;
+  }
+  section.block {
+    padding: 64px 0;
+  }
+  .feature-grid {
+    grid-template-columns: 1fr;
+  }
+  .feature.wide {
+    grid-column: span 1;
+  }
+  .workflow {
+    grid-template-columns: 1fr;
+  }
+  .step {
+    border-right: none;
+    border-bottom: 1px solid var(--border);
+  }
+  .step:last-child {
+    border-bottom: none;
+  }
+  .metrics {
+    grid-template-columns: 1fr 1fr;
+  }
+  .cta-card {
+    padding: 40px 22px;
+  }
+  .foot-grid {
+    grid-template-columns: 1fr;
+  }
+  .lanes {
+    grid-template-columns: 78px 1fr;
+  }
+  .lane-label {
+    font-size: 9.5px;
+    padding: 9px 6px;
+    gap: 5px;
+  }
+  .kpis {
+    gap: 14px;
+  }
+  .console-bar {
+    padding: 10px 12px;
+    gap: 8px;
+  }
+  .console-title {
+    font-size: 11px;
+    gap: 7px;
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+  .console-body {
+    padding: 14px 12px 16px;
+  }
+  .tl-axis {
+    font-size: 9px;
+    padding: 5px 8px 6px;
+  }
+  .marker .tag {
+    font-size: 8.5px;
+    padding: 1px 3px;
+  }
+  .pill {
+    font-size: 9px;
+    padding: 2px 5px;
+  }
+  .kpi-val {
+    font-size: 16px;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  * {
+    transition: none !important;
+    animation: none !important;
+    scroll-behavior: auto !important;
+  }
+}
