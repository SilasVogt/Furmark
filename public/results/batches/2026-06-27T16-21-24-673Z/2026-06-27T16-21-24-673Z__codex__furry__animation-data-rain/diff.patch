+function createMetricBar(sequence: number, now: number): MetricBar {
+  const metric = METRICS[Math.floor(Math.random() * METRICS.length)];
+  const intensity = Math.random();
+  const value = metric.min + (metric.max - metric.min) * intensity;
+  const height = Math.round(54 + intensity * 102);
+
+  return {
+    id: `${Math.round(now)}-${sequence}`,
+    kind: metric.kind,
+    name: metric.name,
+    short: metric.short,
+    valueText: metric.format(value),
+    lane: Math.floor(Math.random() * LANE_COUNT),
+    height,
+    y: -height - 12,
+    velocity: 90 + Math.random() * 70,
+    settled: false,
+    createdAt: now,
+    settledAt: 0,
+  };
+}
+
+function compactSettledBars(bars: MetricBar[], stageHeight: number) {
+  const maxStackHeight = Math.max(180, stageHeight - 32);
+  const settledByLane = new Map<number, MetricBar[]>();
+
+  for (const bar of bars) {
+    if (!bar.settled) continue;
+    const laneBars = settledByLane.get(bar.lane) ?? [];
+    laneBars.push(bar);
+    settledByLane.set(bar.lane, laneBars);
+  }
+
+  const adjusted = new Map<string, MetricBar>();
+
+  for (let lane = 0; lane < LANE_COUNT; lane += 1) {
+    const laneBars = (settledByLane.get(lane) ?? []).sort(
+      (a, b) => b.settledAt - a.settledAt,
+    );
+    const keptNewest: MetricBar[] = [];
+    let usedHeight = 0;
+
+    for (const bar of laneBars) {
+      const gap = keptNewest.length === 0 ? 0 : STACK_GAP;
+      const nextHeight = usedHeight + gap + bar.height;
+      if (nextHeight > maxStackHeight && keptNewest.length > 0) break;
+      keptNewest.push(bar);
+      usedHeight = nextHeight;
+    }
+
+    let stackHeight = 0;
+    for (const bar of keptNewest.reverse()) {
+      const y = Math.max(8, stageHeight - stackHeight - bar.height);
+      adjusted.set(bar.id, { ...bar, y });
+      stackHeight += bar.height + STACK_GAP;
+    }
+  }
+
+  return bars
+    .filter((bar) => !bar.settled || adjusted.has(bar.id))
+    .map((bar) => adjusted.get(bar.id) ?? bar);
+}
+
+function getLaneStacks(bars: MetricBar[]) {
