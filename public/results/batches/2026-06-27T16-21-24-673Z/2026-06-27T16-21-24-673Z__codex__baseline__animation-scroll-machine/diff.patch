+          </div>
+        </div>
+      </section>
+
+      <section className="sequence-summary" aria-labelledby="sequence-heading">
+        <div className="sequence-summary__inner">
+          <p className="eyebrow">
+            <PackageCheck aria-hidden="true" size={18} />
+            Final route sheet
+          </p>
+          <h2 id="sequence-heading">The same build steps, listed plainly</h2>
+          <div className="summary-grid">
+            {stations.map(({ id, title, action, detail, metric }) => (
+              <article className="summary-step" key={id}>
+                <span>{title}</span>
+                <h3>{action}</h3>
+                <p>{detail}</p>
+                <strong>{metric}</strong>
+              </article>
+            ))}
+          </div>
+        </div>
+      </section>
+    </main>
+  );
+}
+
+function MachineScene() {
+  return (
+    <div className="machine-scene" aria-hidden="true">
+      <div className="overhead-rail">
