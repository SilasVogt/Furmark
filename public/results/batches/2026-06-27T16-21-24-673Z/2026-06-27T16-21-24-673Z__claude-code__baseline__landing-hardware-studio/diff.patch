-body { margin: 0; font-family: system-ui, sans-serif; }
+/* ============================================================
+   Arcwell — modular desk lamp landing page
+   Dark, cinematic product studio. No beige, no brass.
+   ============================================================ */
+
+@import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap");
+
+:root {
+  --bg: #0a0b0e;
+  --bg-2: #0c0e12;
+  --surface: #14171d;
+  --surface-2: #1a1e26;
+  --line: rgba(255, 255, 255, 0.09);
+  --line-soft: rgba(255, 255, 255, 0.05);
+
+  --ink: #f2f4f8;
+  --ink-2: #aab1bd;
+  --ink-3: #6c7280;
+
+  --glow: #fff3da; /* overridden per lens via JS */
+
+  --font-display: "Space Grotesk", system-ui, -apple-system, sans-serif;
+  --font-sans: "Inter", system-ui, -apple-system, sans-serif;
+  --font-mono: "Space Mono", ui-monospace, "SFMono-Regular", monospace;
+
+  --maxw: 1240px;
+  --pad: clamp(20px, 5vw, 64px);
+  --radius: 14px;
+
+  --ease: cubic-bezier(0.22, 1, 0.36, 1);
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html,
+body {
+  margin: 0;
+  max-width: 100%;
+  overflow-x: hidden;
+}
+
+body {
+  background: var(--bg);
+  color: var(--ink);
+  font-family: var(--font-sans);
+  font-size: 16px;
+  line-height: 1.6;
+  -webkit-font-smoothing: antialiased;
+  text-rendering: optimizeLegibility;
+}
+
+/* Ambient field — subtle grid + a single glow that tracks the lamp's light */
+body::before {
+  content: "";
+  position: fixed;
+  inset: 0;
+  z-index: 0;
+  pointer-events: none;
+  background-image:
+    linear-gradient(var(--line-soft) 1px, transparent 1px),
+    linear-gradient(90deg, var(--line-soft) 1px, transparent 1px);
+  background-size: 64px 64px;
+  -webkit-mask-image: radial-gradient(120% 80% at 50% 0%, #000 30%, transparent 75%);
+  mask-image: radial-gradient(120% 80% at 50% 0%, #000 30%, transparent 75%);
+  opacity: 0.5;
+}
+
+h1,
+h2,
+h3 {
+  font-family: var(--font-display);
+  font-weight: 500;
+  letter-spacing: -0.02em;
+  line-height: 1.04;
+  margin: 0;
+}
+
+p {
+  margin: 0;
+}
+
+a {
+  color: inherit;
+  text-decoration: none;
+}
+
+button {
+  font-family: inherit;
+  cursor: pointer;
+}
+
+img,
+svg {
+  display: block;
+}
+
+.shell {
+  position: relative;
+  z-index: 1;
+  width: 100%;
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding-inline: var(--pad);
+}
+
+.eyebrow {
+  font-family: var(--font-mono);
+  font-size: 0.72rem;
+  letter-spacing: 0.22em;
+  text-transform: uppercase;
+  color: var(--ink-3);
+  display: inline-flex;
+  align-items: center;
+  gap: 0.6em;
+}
+.eyebrow::before {
+  content: "";
+  width: 26px;
+  height: 1px;
+  background: var(--ink-3);
+}
+
+/* ---------------------------------------------------------- nav */
+.nav {
+  position: sticky;
+  top: 0;
+  z-index: 50;
+  backdrop-filter: blur(14px);
+  background: color-mix(in srgb, var(--bg) 72%, transparent);
+  border-bottom: 1px solid var(--line-soft);
+}
+.nav-inner {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  height: 64px;
+}
+.brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  font-family: var(--font-display);
+  font-weight: 600;
+  letter-spacing: 0.04em;
+  font-size: 1.02rem;
+}
+.brand .mark {
+  color: var(--ink);
+}
+.nav-links {
+  display: flex;
+  gap: 30px;
+  font-size: 0.9rem;
+  color: var(--ink-2);
+}
+.nav-links a {
+  transition: color 0.2s;
+}
+.nav-links a:hover {
+  color: var(--ink);
+}
+.nav-cta {
+  display: inline-flex;
+  align-items: center;
+  gap: 14px;
+  font-family: var(--font-mono);
+  font-size: 0.8rem;
+}
+.nav-price {
+  color: var(--ink-2);
+}
+
+/* ---------------------------------------------------------- buttons */
+.btn {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 0.55em;
+  border: 1px solid transparent;
+  border-radius: 999px;
+  padding: 0.85em 1.4em;
+  font-size: 0.92rem;
+  font-weight: 500;
+  letter-spacing: 0.01em;
+  transition: transform 0.25s var(--ease), background 0.25s, border-color 0.25s, opacity 0.25s;
+  white-space: nowrap;
+}
+.btn:active {
+  transform: translateY(1px);
+}
+.btn-primary {
+  background: var(--ink);
+  color: #0a0b0e;
+}
+.btn-primary:hover {
+  background: #fff;
+}
+.btn-ghost {
+  background: transparent;
+  color: var(--ink);
+  border-color: var(--line);
+}
+.btn-ghost:hover {
+  border-color: var(--ink-2);
+  background: rgba(255, 255, 255, 0.03);
+}
+.btn-sm {
+  padding: 0.6em 1.05em;
+  font-size: 0.82rem;
+}
+
+/* ---------------------------------------------------------- hero */
+.hero {
+  position: relative;
+  padding-top: clamp(36px, 6vw, 72px);
+  padding-bottom: clamp(48px, 7vw, 96px);
+}
+.hero-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 0.84fr) minmax(0, 1.16fr);
+  gap: clamp(28px, 4vw, 64px);
+  align-items: center;
+}
+.hero-copy {
+  max-width: 30ch;
+}
+.hero h1 {
+  font-size: clamp(2.7rem, 6vw, 4.7rem);
+  margin: 0.5em 0 0;
+}
+.hero h1 .soft {
+  color: var(--ink-3);
+}
+.hero-sub {
+  color: var(--ink-2);
+  font-size: clamp(1rem, 1.3vw, 1.12rem);
+  margin-top: 1.3em;
+  max-width: 42ch;
+}
+.stats {
+  display: flex;
+  flex-wrap: wrap;
+  gap: clamp(20px, 3vw, 40px);
+  margin-top: 2.4em;
+}
+.stat .num {
+  font-family: var(--font-display);
+  font-size: 1.7rem;
+  font-weight: 500;
+  letter-spacing: -0.01em;
+}
+.stat .lbl {
+  font-family: var(--font-mono);
+  font-size: 0.68rem;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+  color: var(--ink-3);
+  margin-top: 0.2em;
+}
+
+/* ---------------------------------------------------------- stage + lamp */
+.stage-wrap {
+  min-width: 0;
+}
+.stage {
+  position: relative;
+  border: 1px solid var(--line);
+  border-radius: 20px;
+  background:
+    radial-gradient(120% 90% at 64% 26%, color-mix(in srgb, var(--glow) 16%, transparent), transparent 60%),
+    linear-gradient(180deg, var(--surface-2), var(--bg-2));
+  overflow: hidden;
+  transition: background 0.6s ease;
+}
+.stage::after {
+  /* desk reflection band */
+  content: "";
+  position: absolute;
+  left: 0;
+  right: 0;
+  bottom: 0;
+  height: 34%;
+  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.45));
+  pointer-events: none;
+}
+.stage-tag {
+  position: absolute;
+  top: 16px;
+  left: 18px;
+  z-index: 2;
+  font-family: var(--font-mono);
+  font-size: 0.68rem;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+  color: var(--ink-3);
+  display: flex;
+  align-items: center;
+  gap: 8px;
+}
+.stage-tag .dot {
+  width: 6px;
+  height: 6px;
+  border-radius: 50%;
+  background: var(--glow);
+  box-shadow: 0 0 10px var(--glow);
+  transition: background 0.5s, box-shadow 0.5s;
+}
+.lamp-svg {
+  position: relative;
+  z-index: 1;
+  width: 100%;
+  height: auto;
+  display: block;
+}
+.lamp-body {
+  animation: rise 0.7s var(--ease) both;
+}
+@keyframes rise {
+  from {
+    opacity: 0;
+    transform: translateY(10px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+/* finish colour glides; arm geometry snaps (a module swap) */
+.metal {
+  transition: fill 0.5s ease, stroke 0.5s ease;
+}
+.glow-fill {
+  transition: fill 0.5s ease, opacity 0.5s ease;
+}
+
+/* configurator */
+.config {
+  margin-top: 22px;
+  display: grid;
+  gap: 18px;
+}
+.config-row {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr);
+  gap: 10px;
+}
+.config-head {
+  display: flex;
+  align-items: baseline;
+  justify-content: space-between;
+  gap: 12px;
+}
+.config-head .label {
+  display: inline-flex;
+  align-items: center;
+  gap: 9px;
+  font-family: var(--font-mono);
+  font-size: 0.72rem;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+  color: var(--ink-2);
+}
+.config-head .label svg {
+  color: var(--ink-3);
+}
+.config-head .pick {
+  font-size: 0.82rem;
+  color: var(--ink-3);
+}
+.config-head .pick b {
+  color: var(--ink);
+  font-weight: 500;
+}
+.opts {
+  display: grid;
+  grid-auto-flow: column;
+  grid-auto-columns: 1fr;
+  gap: 8px;
+}
+.opt {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  text-align: left;
+  padding: 11px 12px;
+  border-radius: 11px;
+  border: 1px solid var(--line);
+  background: rgba(255, 255, 255, 0.015);
+  color: var(--ink-2);
+  transition: border-color 0.2s, background 0.2s, color 0.2s;
+  min-width: 0;
+}
+.opt:hover {
+  border-color: var(--ink-3);
+  color: var(--ink);
+}
+.opt[aria-pressed="true"] {
+  border-color: color-mix(in srgb, var(--ink) 60%, transparent);
+  background: rgba(255, 255, 255, 0.06);
+  color: var(--ink);
+}
+.opt .opt-name {
+  font-size: 0.9rem;
+  font-weight: 500;
+  display: flex;
+  align-items: center;
+  gap: 7px;
+}
+.opt .opt-meta {
+  font-family: var(--font-mono);
+  font-size: 0.66rem;
+  letter-spacing: 0.04em;
+  color: var(--ink-3);
+}
+.opt .swatch {
+  width: 13px;
+  height: 13px;
+  border-radius: 4px;
+  border: 1px solid rgba(255, 255, 255, 0.25);
+  flex: none;
+}
+.opt .check {
+  position: absolute;
+  top: 9px;
+  right: 9px;
+  opacity: 0;
+  color: var(--ink);
+  transition: opacity 0.2s;
+}
+.opt[aria-pressed="true"] .check {
+  opacity: 1;
+}
+
+/* price + buy dock */
+.buy-dock {
+  margin-top: 22px;
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: 16px 22px;
+  padding-top: 22px;
+  border-top: 1px solid var(--line);
+}
+.price {
+  display: flex;
+  flex-direction: column;
+}
+.price .amt {
+  font-family: var(--font-display);
+  font-size: 2rem;
+  font-weight: 500;
+  line-height: 1;
+  font-variant-numeric: tabular-nums;
+}
+.price .note {
+  font-family: var(--font-mono);
+  font-size: 0.66rem;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+  color: var(--ink-3);
+  margin-top: 0.55em;
+}
+.buy-dock .actions {
+  display: flex;
+  gap: 10px;
+  margin-left: auto;
+  flex-wrap: wrap;
+}
+
+/* ---------------------------------------------------------- section frame */
+.section {
+  padding-block: clamp(64px, 9vw, 128px);
+  border-top: 1px solid var(--line-soft);
+}
+.section-head {
+  display: flex;
+  align-items: flex-end;
+  justify-content: space-between;
+  gap: 24px;
+  flex-wrap: wrap;
+  margin-bottom: clamp(36px, 5vw, 64px);
+}
+.section-head h2 {
+  font-size: clamp(1.9rem, 4vw, 3rem);
+  max-width: 18ch;
+}
+.section-head p {
+  color: var(--ink-2);
+  max-width: 38ch;
+}
+
+/* specs */
+.spec-grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  column-gap: clamp(40px, 7vw, 96px);
+}
+.spec-row {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  align-items: baseline;
+  gap: 16px;
+  padding: 17px 0;
+  border-bottom: 1px solid var(--line-soft);
+}
+.spec-row .k {
+  color: var(--ink-2);
+  font-size: 0.95rem;
+}
+.spec-row .v {
+  font-family: var(--font-mono);
+  font-size: 0.9rem;
+  color: var(--ink);
+  text-align: right;
+}
+
+/* modular system */
+.modules {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: clamp(16px, 2.5vw, 28px);
+}
+.module {
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  background: linear-gradient(180deg, var(--surface), var(--bg-2));
+  padding: 22px;
+  display: flex;
+  flex-direction: column;
+  gap: 14px;
+  transition: border-color 0.25s, transform 0.25s var(--ease);
+}
+.module:hover {
+  border-color: var(--ink-3);
+  transform: translateY(-3px);
+}
+.module-thumb {
+  border-radius: 10px;
+  background: radial-gradient(90% 80% at 50% 30%, rgba(255, 255, 255, 0.05), transparent 70%),
+    var(--bg-2);
+  border: 1px solid var(--line-soft);
+  aspect-ratio: 16 / 10;
+  display: grid;
+  place-items: center;
+  overflow: hidden;
+}
+.module-thumb svg {
+  width: 100%;
+  height: 100%;
+}
+.module-ix {
+  font-family: var(--font-mono);
+  font-size: 0.7rem;
+  letter-spacing: 0.14em;
+  color: var(--ink-3);
+  display: flex;
+  justify-content: space-between;
+}
+.module h3 {
+  font-size: 1.25rem;
+  font-weight: 500;
+}
+.module p {
+  color: var(--ink-2);
+  font-size: 0.92rem;
+}
+.module .tokens {
+  margin-top: auto;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+}
+.token {
+  font-family: var(--font-mono);
+  font-size: 0.68rem;
+  color: var(--ink-2);
+  border: 1px solid var(--line);
+  border-radius: 6px;
+  padding: 3px 8px;
+}
+
+/* closing buy band */
+.closer {
+  text-align: center;
+  border-top: 1px solid var(--line-soft);
+  padding-block: clamp(72px, 10vw, 140px);
+  position: relative;
+  overflow: hidden;
+}
+.closer::before {
+  content: "";
+  position: absolute;
+  left: 50%;
+  top: -10%;
+  width: 720px;
+  max-width: 120%;
+  aspect-ratio: 1;
+  transform: translateX(-50%);
+  background: radial-gradient(circle, color-mix(in srgb, var(--glow) 18%, transparent), transparent 62%);
+  pointer-events: none;
+  transition: background 0.6s ease;
+}
+.closer .inner {
+  position: relative;
+}
+.closer h2 {
+  font-size: clamp(2.2rem, 5.5vw, 4rem);
+  margin-bottom: 0.4em;
+}
+.closer .lead {
+  color: var(--ink-2);
+  max-width: 46ch;
+  margin: 0 auto 2em;
+  font-size: 1.05rem;
+}
+.summary {
+  display: inline-flex;
+  flex-wrap: wrap;
+  justify-content: center;
+  align-items: center;
+  gap: 10px 14px;
+  font-family: var(--font-mono);
+  font-size: 0.8rem;
+  color: var(--ink-2);
+  border: 1px solid var(--line);
+  border-radius: 999px;
+  padding: 10px 20px;
+  margin-bottom: 26px;
+}
+.summary .sep {
+  color: var(--ink-3);
+}
+.summary b {
+  color: var(--ink);
+  font-weight: 400;
+}
+.closer-actions {
+  display: flex;
+  gap: 12px;
+  justify-content: center;
+  flex-wrap: wrap;
+}
+.reassure {
+  display: flex;
+  gap: clamp(20px, 4vw, 48px);
+  justify-content: center;
+  flex-wrap: wrap;
+  margin-top: 44px;
+  font-size: 0.86rem;
+  color: var(--ink-2);
+}
+.reassure span {
+  display: inline-flex;
+  align-items: center;
+  gap: 9px;
+}
+.reassure svg {
+  color: var(--ink-3);
+}
+
+/* footer */
+.footer {
+  border-top: 1px solid var(--line-soft);
+  padding-block: 40px 56px;
+  color: var(--ink-3);
+}
+.footer-inner {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 20px;
+  flex-wrap: wrap;
+  font-size: 0.85rem;
+}
+.footer .brand {
+  color: var(--ink-2);
+}
+.footer-links {
+  display: flex;
+  gap: 22px;
+  flex-wrap: wrap;
+}
+.footer-links a:hover {
+  color: var(--ink);
+}
+
+/* ---------------------------------------------------------- responsive */
+@media (max-width: 960px) {
+  .hero-grid {
+    grid-template-columns: minmax(0, 1fr);
+  }
+  .hero-copy {
+    max-width: 100%;
+  }
+  .nav-links {
+    display: none;
+  }
+  .spec-grid {
+    grid-template-columns: minmax(0, 1fr);
+  }
+  .modules {
+    grid-template-columns: minmax(0, 1fr);
+  }
+}
+
+@media (max-width: 560px) {
+  .opts {
+    grid-auto-flow: row;
+  }
+  .buy-dock .actions {
+    width: 100%;
+  }
+  .buy-dock .actions .btn {
+    flex: 1;
+  }
+  .stat .num {
+    font-size: 1.45rem;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  * {
+    animation-duration: 0.001ms !important;
+    transition-duration: 0.001ms !important;
+  }
+}
