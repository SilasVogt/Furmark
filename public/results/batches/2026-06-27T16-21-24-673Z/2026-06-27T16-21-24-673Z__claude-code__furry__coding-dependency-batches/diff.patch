 }
 
+// Walks the unresolved subgraph to extract a concrete cycle, naming only its
+// members rather than every node stranded behind it. After the batching loop,
+// each unprocessed node's remaining deps are themselves unprocessed, so
+// following the alphabetically smallest dep is guaranteed to revisit a node.
+function findCycle(remainingDeps: Map<string, Set<string>>, processed: Set<string>): string[] {
+  const start = [...remainingDeps.keys()].filter((node) => !processed.has(node)).sort()[0];
+
+  const path: string[] = [];
+  const onPath = new Set<string>();
+  let node = start;
+  while (!onPath.has(node)) {
+    onPath.add(node);
+    path.push(node);
+    node = [...remainingDeps.get(node)!].sort()[0];
+  }
+
+  // Drop the lead-in tail, then rotate so the cycle starts at its smallest
+  // member for a deterministic representation.
+  const cycle = path.slice(path.indexOf(node));
+  const offset = cycle.indexOf([...cycle].sort()[0]);
+  return [...cycle.slice(offset), ...cycle.slice(0, offset)];
+}
