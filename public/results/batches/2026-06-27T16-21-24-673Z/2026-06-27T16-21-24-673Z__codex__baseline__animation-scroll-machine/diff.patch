+
+              <ol className="station-list" aria-label="Assembly stations">
+                {stations.map(({ id, title, action, detail, metric, Icon }) => (
+                  <li className={`station-card station-card--${id}`} key={id}>
+                    <div className="station-card__icon" aria-hidden="true">
+                      <Icon size={18} />
