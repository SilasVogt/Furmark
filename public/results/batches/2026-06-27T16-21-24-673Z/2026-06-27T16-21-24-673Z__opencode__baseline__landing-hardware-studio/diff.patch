diff --git a/src/style.css b/src/style.css
index 6a6f6bd..90613a5 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,661 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  --ink: #08090b;
+  --ink-2: #0d0e12;
+  --surface: #131419;
+  --surface-2: #181a20;
+  --surface-3: #1e2027;
+  --line: #26282f;
+  --line-soft: #1c1e24;
+  --text: #f3f3f5;
+  --muted: #9b9ca6;
+  --dim: #64656e;
+  --amber: #ffb547;
+  --amber-soft: #ffd89b;
+  --ember: #ff8a3d;
+  --radius: 16px;
+  --radius-sm: 10px;
+  --maxw: 1240px;
+  --shadow-soft: 0 24px 60px -28px rgba(0, 0, 0, 0.7);
+}
+
+* { box-sizing: border-box; }
+
+html, body {
+  margin: 0;
+  padding: 0;
+  background: var(--ink);
+  color: var(--text);
+  font-family: "Inter", system-ui, -apple-system, "Segoe UI", sans-serif;
+  font-feature-settings: "ss01", "cv11";
+  -webkit-font-smoothing: antialiased;
+  text-rendering: optimizeLegibility;
+  overflow-x: hidden;
+}
+
+body {
+  background:
+    radial-gradient(1200px 600px at 80% -10%, rgba(255, 181, 71, 0.08), transparent 60%),
+    radial-gradient(900px 500px at -10% 20%, rgba(80, 120, 255, 0.05), transparent 60%),
+    var(--ink);
+}
+
+a { color: inherit; text-decoration: none; }
+button { font-family: inherit; }
+
+.page { min-height: 100vh; }
+
+/* ---------- NAV ---------- */
+.nav {
+  position: sticky;
+  top: 0;
+  z-index: 50;
+  display: flex;
+  align-items: center;
+  gap: 24px;
+  padding: 18px clamp(20px, 5vw, 56px);
+  background: rgba(8, 9, 11, 0.72);
+  backdrop-filter: blur(18px) saturate(140%);
+  -webkit-backdrop-filter: blur(18px) saturate(140%);
+  border-bottom: 1px solid var(--line-soft);
+}
+
+.brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  font-weight: 600;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  font-size: 14px;
+}
+
+.brand-mark {
+  width: 18px;
+  height: 18px;
+  border-radius: 5px;
+  background: linear-gradient(135deg, var(--amber) 0%, var(--ember) 100%);
+  box-shadow: 0 0 18px rgba(255, 181, 71, 0.6);
+}
+
+.brand-name { color: var(--text); }
+
+.nav-links {
+  display: flex;
+  gap: 28px;
+  margin-left: auto;
+  font-size: 14px;
+  color: var(--muted);
+}
+.nav-links a { transition: color 0.2s ease; }
+.nav-links a:hover { color: var(--text); }
+
+.nav-cta {
+  padding: 9px 16px;
+  border-radius: 999px;
+  border: 1px solid var(--line);
+  background: var(--surface-2);
+  font-size: 13px;
+  font-weight: 500;
+  transition: border-color 0.2s ease, background 0.2s ease;
+}
+.nav-cta:hover { border-color: var(--amber); background: var(--surface-3); }
+
+@media (max-width: 720px) {
+  .nav-links { display: none; }
+  .nav-cta { margin-left: auto; }
+}
+
+/* ---------- HERO ---------- */
+.hero {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: clamp(48px, 8vw, 104px) clamp(20px, 5vw, 56px) clamp(40px, 6vw, 80px);
+  display: grid;
+  grid-template-columns: 1.05fr 1fr;
+  gap: clamp(32px, 5vw, 72px);
+  align-items: center;
+  min-height: min(860px, 92vh);
+}
+
+.eyebrow {
+  display: inline-block;
+  font-size: 12px;
+  letter-spacing: 0.22em;
+  text-transform: uppercase;
+  color: var(--amber);
+  font-weight: 500;
+  margin-bottom: 22px;
+}
+
+.hero-title {
+  margin: 0;
+  font-size: clamp(44px, 6.6vw, 88px);
+  line-height: 0.98;
+  letter-spacing: -0.03em;
+  font-weight: 600;
+  color: var(--text);
+}
+.title-accent {
+  background: linear-gradient(120deg, var(--amber-soft) 0%, var(--amber) 60%, var(--ember) 100%);
+  -webkit-background-clip: text;
+  background-clip: text;
+  color: transparent;
+}
+
+.hero-lede {
+  margin: 26px 0 0;
+  max-width: 46ch;
+  font-size: clamp(16px, 1.4vw, 18px);
+  line-height: 1.6;
+  color: var(--muted);
+}
+
+.hero-actions {
+  margin-top: 34px;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 14px;
+}
+
+.btn-primary {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  padding: 14px 22px;
+  border-radius: 999px;
+  background: var(--text);
+  color: var(--ink);
+  font-weight: 600;
+  font-size: 15px;
+  border: 1px solid transparent;
+  transition: transform 0.18s ease, box-shadow 0.2s ease, background 0.2s ease;
+}
+.btn-primary:hover {
+  transform: translateY(-1px);
+  box-shadow: 0 14px 30px -12px rgba(255, 181, 71, 0.5);
+}
+.btn-large { padding: 18px 30px; font-size: 16px; }
+
+.btn-ghost {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  padding: 14px 22px;
+  border-radius: 999px;
+  border: 1px solid var(--line);
+  color: var(--text);
+  font-weight: 500;
+  font-size: 15px;
+  background: transparent;
+  transition: border-color 0.2s ease, background 0.2s ease;
+}
+.btn-ghost:hover { border-color: var(--muted); background: var(--surface); }
+
+.hero-stats {
+  margin: 48px 0 0;
+  display: flex;
+  gap: clamp(24px, 4vw, 56px);
+  padding: 0;
+}
+.hero-stats div { display: flex; flex-direction: column; gap: 4px; }
+.hero-stats dt {
+  font-size: 11px;
+  letter-spacing: 0.18em;
+  text-transform: uppercase;
+  color: var(--dim);
+  order: 2;
+}
+.hero-stats dd {
+  margin: 0;
+  font-size: clamp(22px, 2.4vw, 28px);
+  font-weight: 600;
+  letter-spacing: -0.02em;
+  color: var(--text);
+  order: 1;
+}
+
+/* hero visual */
+.hero-visual {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  min-height: 460px;
+}
+.halo {
+  position: absolute;
+  inset: 8% 6% 18%;
+  background: radial-gradient(closest-side, rgba(255, 181, 71, 0.22), rgba(255, 138, 61, 0.05) 55%, transparent 72%);
+  filter: blur(8px);
+  z-index: 0;
+}
+.hero-lamp {
+  position: relative;
+  z-index: 1;
+  width: min(440px, 90%);
+  height: auto;
+  filter: drop-shadow(0 40px 50px rgba(0, 0, 0, 0.6));
+}
+.hero-caption {
+  position: relative;
+  z-index: 1;
+  margin-top: 18px;
+  display: inline-flex;
+  align-items: center;
+  gap: 9px;
+  font-size: 12px;
+  letter-spacing: 0.08em;
+  color: var(--muted);
+  padding: 7px 14px;
+  border-radius: 999px;
+  background: rgba(20, 21, 26, 0.6);
+  border: 1px solid var(--line-soft);
+}
+.caption-dot {
+  width: 7px; height: 7px; border-radius: 50%;
+  background: var(--amber);
+  box-shadow: 0 0 10px var(--amber);
+}
+
+@media (max-width: 900px) {
+  .hero { grid-template-columns: 1fr; min-height: auto; }
+  .hero-visual { order: -1; min-height: 380px; }
+  .hero-lamp { width: min(360px, 80%); }
+}
+
+/* ---------- SECTION SHELL ---------- */
+.section {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: clamp(64px, 9vw, 120px) clamp(20px, 5vw, 56px);
+}
+.section-head { max-width: 720px; margin-bottom: clamp(36px, 5vw, 64px); }
+.section-title {
+  margin: 0;
+  font-size: clamp(30px, 4vw, 48px);
+  line-height: 1.05;
+  letter-spacing: -0.025em;
+  font-weight: 600;
+}
+.section-lede {
+  margin: 20px 0 0;
+  font-size: clamp(15px, 1.3vw, 17px);
+  line-height: 1.65;
+  color: var(--muted);
+  max-width: 58ch;
+}
+
+/* ---------- CONFIGURATOR ---------- */
+.section-configure {
+  background:
+    linear-gradient(180deg, transparent 0%, rgba(20, 21, 26, 0.6) 18%, rgba(20, 21, 26, 0.6) 82%, transparent 100%);
+}
+.configurator {
+  display: grid;
+  grid-template-columns: 1.1fr 0.9fr;
+  gap: clamp(24px, 4vw, 48px);
+  background: var(--ink-2);
+  border: 1px solid var(--line);
+  border-radius: 24px;
+  overflow: hidden;
+  box-shadow: var(--shadow-soft);
+}
+
+.config-stage {
+  position: relative;
+  min-height: 520px;
+  background:
+    radial-gradient(120% 80% at 70% 30%, rgba(255, 181, 71, 0.12), transparent 55%),
+    linear-gradient(180deg, #15161b 0%, #0b0c0f 100%);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  padding: 24px;
+  border-right: 1px solid var(--line);
+}
+.stage-grid {
+  position: absolute;
+  inset: 0;
+  background-image:
+    linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
+    linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
+  background-size: 32px 32px;
+  mask-image: radial-gradient(closest-side, #000 40%, transparent 80%);
+  -webkit-mask-image: radial-gradient(closest-side, #000 40%, transparent 80%);
+}
+.stage-lamp {
+  position: relative;
+  width: min(420px, 92%);
+  height: auto;
+  filter: drop-shadow(0 30px 40px rgba(0, 0, 0, 0.55));
+}
+
+.config-panel {
+  padding: clamp(24px, 3vw, 36px);
+  display: flex;
+  flex-direction: column;
+  gap: 26px;
+}
+
+.config-price {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  padding-bottom: 24px;
+  border-bottom: 1px solid var(--line-soft);
+}
+.price-label {
+  font-size: 11px;
+  letter-spacing: 0.18em;
+  text-transform: uppercase;
+  color: var(--dim);
+}
+.price-value {
+  font-size: clamp(34px, 4vw, 42px);
+  font-weight: 600;
+  letter-spacing: -0.03em;
+  line-height: 1;
+  margin-top: 4px;
+}
+.price-sub { font-size: 13px; color: var(--muted); margin-top: 6px; }
+
+/* option groups */
+.option-group {
+  border: none;
+  padding: 0;
+  margin: 0;
+}
+.option-legend {
+  font-size: 12px;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+  color: var(--muted);
+  margin-bottom: 12px;
+  padding: 0;
+}
+.option-row {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 10px;
+}
+.option-chip {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  text-align: left;
+  padding: 14px 14px 16px;
+  border-radius: var(--radius-sm);
+  background: var(--surface);
+  border: 1px solid var(--line);
+  color: var(--text);
+  cursor: pointer;
+  transition: border-color 0.18s ease, background 0.18s ease, transform 0.18s ease;
+}
+.option-chip:hover { border-color: var(--dim); background: var(--surface-2); }
+.option-chip.is-selected {
+  border-color: var(--amber);
+  background: linear-gradient(180deg, rgba(255, 181, 71, 0.08), transparent), var(--surface-2);
+}
+.chip-label { font-size: 14px; font-weight: 600; letter-spacing: -0.01em; }
+.chip-hint { font-size: 11px; color: var(--muted); line-height: 1.3; }
+.chip-delta { font-size: 11px; color: var(--dim); margin-top: 2px; }
+.option-chip.is-selected .chip-delta { color: var(--amber-soft); }
+.chip-mark {
+  position: absolute;
+  top: 10px;
+  right: 10px;
+  width: 18px;
+  height: 18px;
+  border-radius: 50%;
+  background: var(--amber);
+  color: var(--ink);
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+}
+
+/* finish */
+.finish-row {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 10px;
+}
+.finish-chip {
+  display: flex;
+  flex-direction: column;
+  gap: 10px;
+  align-items: flex-start;
+  padding: 14px;
+  border-radius: var(--radius-sm);
+  background: var(--surface);
+  border: 1px solid var(--line);
+  cursor: pointer;
+  transition: border-color 0.18s ease, background 0.18s ease;
+  text-align: left;
+}
+.finish-chip:hover { border-color: var(--dim); background: var(--surface-2); }
+.finish-chip.is-selected {
+  border-color: var(--amber);
+  background: linear-gradient(180deg, rgba(255, 181, 71, 0.08), transparent), var(--surface-2);
+}
+.finish-swatch {
+  width: 100%;
+  height: 46px;
+  border-radius: 7px;
+}
+.finish-meta { display: flex; flex-direction: column; gap: 2px; }
+
+/* buy cta */
+.buy-cta {
+  margin-top: 6px;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 10px;
+  padding: 16px 22px;
+  border-radius: 999px;
+  background: linear-gradient(120deg, var(--amber-soft) 0%, var(--amber) 55%, var(--ember) 100%);
+  color: #1a0f00;
+  font-weight: 600;
+  font-size: 15px;
+  border: none;
+  cursor: pointer;
+  transition: transform 0.18s ease, box-shadow 0.2s ease;
+}
+.buy-cta:hover {
+  transform: translateY(-1px);
+  box-shadow: 0 18px 38px -14px rgba(255, 138, 61, 0.6);
+}
+.cta-note { margin: 4px 0 0; font-size: 12px; color: var(--dim); text-align: center; }
+
+@media (max-width: 900px) {
+  .configurator { grid-template-columns: 1fr; }
+  .config-stage { min-height: 420px; border-right: none; border-bottom: 1px solid var(--line); }
+}
+@media (max-width: 460px) {
+  .option-row, .finish-row { grid-template-columns: 1fr; }
+}
+
+/* ---------- MODULES ---------- */
+.module-grid {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 16px;
+}
+.module-card {
+  display: flex;
+  flex-direction: column;
+  gap: 14px;
+  padding: 30px 28px;
+  background: linear-gradient(180deg, var(--surface) 0%, var(--ink-2) 100%);
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  transition: border-color 0.2s ease, transform 0.2s ease;
+}
+.module-card:hover { border-color: var(--dim); transform: translateY(-2px); }
+.module-icon {
+  width: 44px; height: 44px;
+  border-radius: 12px;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  background: var(--surface-3);
+  border: 1px solid var(--line);
+  color: var(--amber);
+}
+.module-title { margin: 0; font-size: 22px; font-weight: 600; letter-spacing: -0.02em; }
+.module-body { margin: 0; font-size: 14px; line-height: 1.6; color: var(--muted); }
+.module-tags {
+  list-style: none;
+  margin: auto 0 0;
+  padding: 16px 0 0;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+  border-top: 1px solid var(--line-soft);
+}
+.module-tags li {
+  font-size: 11px;
+  letter-spacing: 0.04em;
+  color: var(--muted);
+  padding: 4px 9px;
+  border-radius: 999px;
+  background: var(--surface-3);
+  border: 1px solid var(--line-soft);
+}
+@media (max-width: 820px) { .module-grid { grid-template-columns: 1fr; } }
+
+/* ---------- SPECS ---------- */
+.section-specs { border-top: 1px solid var(--line-soft); }
+.specs-grid {
+  display: grid;
+  grid-template-columns: repeat(4, 1fr);
+  border-top: 1px solid var(--line);
+  border-left: 1px solid var(--line);
+}
+.spec {
+  padding: 26px 24px;
+  border-right: 1px solid var(--line);
+  border-bottom: 1px solid var(--line);
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+.spec dt {
+  font-size: 11px;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+  color: var(--dim);
+}
+.spec dd {
+  margin: 0;
+  font-size: 19px;
+  font-weight: 500;
+  letter-spacing: -0.01em;
+  color: var(--text);
+}
+@media (max-width: 900px) { .specs-grid { grid-template-columns: repeat(2, 1fr); } }
+@media (max-width: 480px) { .specs-grid { grid-template-columns: 1fr; } }
+
+.specs-foot {
+  margin-top: 24px;
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  font-size: 13px;
+  color: var(--muted);
+  padding: 12px 18px;
+  border-radius: 999px;
+  background: var(--surface);
+  border: 1px solid var(--line);
+}
+
+/* ---------- CLOSE CTA ---------- */
+.section-close { padding-top: clamp(48px, 7vw, 80px); }
+.close-card {
+  position: relative;
+  overflow: hidden;
+  text-align: center;
+  padding: clamp(56px, 9vw, 110px) clamp(24px, 5vw, 64px);
+  border-radius: 28px;
+  background:
+    radial-gradient(80% 120% at 50% 0%, rgba(255, 181, 71, 0.16), transparent 55%),
+    linear-gradient(180deg, #15161b 0%, #0a0b0e 100%);
+  border: 1px solid var(--line);
+}
+.close-glow {
+  position: absolute;
+  top: -40%;
+  left: 50%;
+  transform: translateX(-50%);
+  width: 520px;
+  height: 320px;
+  background: radial-gradient(closest-side, rgba(255, 138, 61, 0.4), transparent 70%);
+  filter: blur(20px);
+  pointer-events: none;
+}
+.close-title {
+  position: relative;
+  margin: 0 auto;
+  max-width: 16ch;
+  font-size: clamp(30px, 4.4vw, 54px);
+  line-height: 1.04;
+  letter-spacing: -0.03em;
+  font-weight: 600;
+}
+.close-lede {
+  position: relative;
+  margin: 22px auto 32px;
+  color: var(--muted);
+  font-size: clamp(15px, 1.4vw, 17px);
+  max-width: 48ch;
+}
+.close-card .btn-primary { position: relative; margin: 0 auto; }
+
+/* ---------- FOOTER ---------- */
+.footer {
+  border-top: 1px solid var(--line-soft);
+  padding: 40px clamp(20px, 5vw, 56px);
+  background: var(--ink-2);
+}
+.footer-inner {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  display: flex;
+  flex-direction: column;
+  gap: 12px;
+  align-items: center;
+  text-align: center;
+}
+.footer-brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  font-size: 13px;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+  color: var(--text);
+}
+.footer-meta { margin: 0; font-size: 13px; color: var(--muted); }
+.footer-copy { margin: 0; font-size: 12px; color: var(--dim); }
+
+/* ---------- FOCUS / A11Y ---------- */
+:focus-visible {
+  outline: 2px solid var(--amber);
+  outline-offset: 3px;
+  border-radius: 4px;
+}
+.option-chip:focus-visible,
+.finish-chip:focus-visible,
+.buy-cta:focus-visible,
+.btn-primary:focus-visible,
+.btn-ghost:focus-visible,
+.nav-cta:focus-visible {
+  outline-offset: 4px;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  * { transition: none !important; animation: none !important; }
+}
