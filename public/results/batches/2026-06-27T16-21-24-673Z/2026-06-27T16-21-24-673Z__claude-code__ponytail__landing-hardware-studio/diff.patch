+  letter-spacing: 0.16em;
+  color: var(--muted);
+  margin-bottom: 10px;
+}
+.control-opts { display: flex; flex-wrap: wrap; gap: 10px; }
+
+.opt { position: relative; cursor: pointer; }
+.opt input {
+  position: absolute;
+  opacity: 0;
+  width: 0;
+  height: 0;
+}
+.opt:has(input:focus-visible) { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 12px; }
+
+/* segmented pill (arm + lens) */
+.pill {
+  display: flex;
+  flex-direction: column;
+  gap: 1px;
+  padding: 10px 15px;
+  border: 1px solid var(--line-strong);
+  border-radius: 12px;
+  background: var(--surface-2);
+  transition: border-color 0.15s ease, background 0.15s ease;
+}
+.pill-label { font-weight: 600; font-size: 0.92rem; }
+.pill-sub { font-size: 0.74rem; color: var(--muted); }
+.opt:hover .pill { border-color: var(--muted-2); }
+.opt.is-sel .pill {
+  border-color: var(--accent);
+  background: rgba(110, 124, 255, 0.12);
+}
+
+/* finish swatch */
+.swatch-wrap { display: flex; align-items: center; gap: 10px; padding: 7px 14px 7px 7px; border: 1px solid var(--line-strong); border-radius: 999px; background: var(--surface-2); transition: border-color 0.15s ease; }
+.swatch {
+  display: grid;
+  place-items: center;
+  width: 30px;
+  height: 30px;
+  border-radius: 999px;
+  color: #fff;
+  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.18);
+}
+.swatch-label { font-size: 0.9rem; font-weight: 500; }
+.opt:hover .swatch-wrap { border-color: var(--muted-2); }
+.opt.is-sel .swatch-wrap { border-color: var(--accent); }
+
+/* ---------- Buy ---------- */
+.buy {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  flex-wrap: wrap;
+  padding-top: 6px;
+  border-top: 1px solid var(--line);
+  margin-top: 2px;
+}
+.buy-price { display: flex; flex-direction: column; }
+.price { font-size: 1.7rem; font-weight: 600; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
+.price-note { font-size: 0.76rem; color: var(--muted); }
+.buy .btn-primary { padding: 13px 24px; }
+.buy-meta { font-size: 0.8rem; color: var(--muted-2); margin-top: -4px; }
+
+/* ---------- Sections ---------- */
+.section-head { max-width: 38rem; margin-bottom: clamp(28px, 4vw, 48px); }
+.section-head h2 { font-size: clamp(1.8rem, 3.6vw, 2.7rem); margin-top: 14px; }
+.section-lede { color: var(--muted); margin-top: 16px; font-size: 1.05rem; }
+
+.specs, .system { padding: clamp(56px, 8vw, 110px) 0; scroll-margin-top: 72px; }
+.specs { border-top: 1px solid var(--line); }
+
+/* stats — spec-sheet rows, not feature cards */
+.stats {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 1px;
+  background: var(--line);
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  overflow: hidden;
+}
+.stat { background: var(--bg); padding: clamp(20px, 2.6vw, 30px); }
+.stat-value { font-size: clamp(1.7rem, 3vw, 2.3rem); font-weight: 600; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
+.stat-unit { font-size: 0.9rem; color: var(--accent); margin-left: 5px; font-weight: 600; letter-spacing: 0; }
+.stat-label { color: var(--muted); font-size: 0.9rem; margin-top: 6px; }
+
+.specsheet { margin: 28px 0 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 clamp(28px, 4vw, 64px); }
+.specrow { display: flex; justify-content: space-between; gap: 18px; padding: 16px 0; border-top: 1px solid var(--line); }
+.specrow dt { color: var(--muted); font-size: 0.92rem; flex: 0 0 auto; }
+.specrow dd { margin: 0; text-align: right; font-size: 0.92rem; }
+
+/* system */
+.system { border-top: 1px solid var(--line); }
+.system-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(20px, 3vw, 40px); }
+.layer h3 { font-size: 1.25rem; }
+.layer > p { color: var(--muted); margin: 10px 0 20px; font-size: 0.95rem; }
+.arm-row { display: flex; gap: 12px; }
+.arm-card { margin: 0; flex: 1; min-width: 0; border: 1px solid var(--line); border-radius: 14px; background: var(--surface); padding: 6px; text-align: center; color: var(--muted); }
+.arm-icon { width: 100%; height: auto; display: block; color: var(--text); aspect-ratio: 1 / 1; }
+.arm-card figcaption { font-size: 0.8rem; padding-bottom: 4px; }
+.chip-row { display: flex; flex-wrap: wrap; gap: 10px; }
+.chip {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  padding: 8px 14px;
+  border: 1px solid var(--line);
+  border-radius: 999px;
+  font-size: 0.86rem;
+  background: var(--surface);
+}
+.chip-dot { width: 12px; height: 12px; border-radius: 999px; box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.2); }
+
+/* ---------- Closing CTA ---------- */
+.cta { border-top: 1px solid var(--line); }
+.cta-inner {
+  text-align: center;
+  padding: clamp(64px, 9vw, 120px) 0;
+  display: grid;
+  justify-items: center;
+  gap: 18px;
+}
+.cta h2 { font-size: clamp(2rem, 5vw, 3.4rem); }
+.cta p { color: var(--muted); max-width: 32rem; }
+.cta .btn { margin-top: 8px; }
+
+/* ---------- Footer ---------- */
+.footer { border-top: 1px solid var(--line); }
+.footer-inner {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  flex-wrap: wrap;
+  gap: 12px;
+  padding: 30px 0;
+}
+.footer-note { color: var(--muted-2); font-size: 0.85rem; }
+
+/* ---------- Responsive ---------- */
+@media (max-width: 900px) {
+  .hero { grid-template-columns: 1fr; }
+  .hero-copy { max-width: none; order: 1; }
+  .config { order: 2; }
+  .specsheet { grid-template-columns: 1fr; }
+  .system-grid { grid-template-columns: 1fr; gap: 36px; }
+}
+
+@media (max-width: 620px) {
+  .nav-links { gap: 16px; }
+  .nav-links a:not(.nav-cta) { display: none; }
+  .stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+  .buy { gap: 14px; }
+  .buy .btn-primary { width: 100%; justify-content: center; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  html { scroll-behavior: auto; }
+  * { transition: none !important; }
+}
