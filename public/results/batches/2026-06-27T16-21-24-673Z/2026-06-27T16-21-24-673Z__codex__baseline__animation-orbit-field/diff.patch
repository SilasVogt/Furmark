+        const y =
+          centerY +
+          Math.sin(angle + satellite.phase * 0.12) * orbitRadius * tilt +
+          Math.cos(angle * 0.7 + satellite.phase) * baseRadius * 0.014;
+        const pointerDistance = Math.hypot(pointerX - x, pointerY - y);
+        const pointerPull = pointer.active
+          ? Math.max(0, 1 - pointerDistance / Math.max(150, baseRadius * 0.62)) ** 2
+          : 0;
+        const pulledX = x + (pointerX - x) * pointerPull * 0.26;
