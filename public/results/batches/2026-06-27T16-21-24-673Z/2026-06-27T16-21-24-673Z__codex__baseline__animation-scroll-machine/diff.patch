+            {station.title}
+          </span>
+        ))}
+      </div>
+
+      <div className="feed-hopper">
+        <div className="hopper-bin" />
+        <div className="hopper-gate" />
+      </div>
+
+      <div className="press-station">
+        <div className="press-column" />
+        <div className="press-head" />
