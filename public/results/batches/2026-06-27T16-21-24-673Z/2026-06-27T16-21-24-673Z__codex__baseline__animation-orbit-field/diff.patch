diff --git a/src/style.css b/src/style.css
index 6a6f6bd..e898c69 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,167 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  color-scheme: dark;
+  font-family:
+    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
+    sans-serif;
+  font-synthesis: none;
+  text-rendering: optimizeLegibility;
+  -webkit-font-smoothing: antialiased;
+  --panel: rgba(15, 14, 12, 0.72);
+  --panel-border: rgba(255, 244, 214, 0.18);
+  --text: #fff8e9;
+  --muted: #c9c0ad;
+  --accent: #6be7d8;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html,
+body,
+#root {
+  width: 100%;
+  min-width: 320px;
+  height: 100%;
+  margin: 0;
+}
+
+body {
+  overflow: hidden;
+  background: #070706;
+}
+
+button {
+  font: inherit;
+}
+
+.orbit-shell {
+  position: relative;
+  width: 100vw;
+  height: 100dvh;
+  min-height: 420px;
+  overflow: hidden;
+  background: #070706;
+  color: var(--text);
+}
+
+.orbit-canvas {
+  position: absolute;
+  inset: 0;
+  display: block;
+  width: 100%;
+  height: 100%;
+  touch-action: none;
+  cursor: crosshair;
+}
+
+.orbit-toolbar {
+  position: fixed;
+  top: clamp(12px, 3vw, 28px);
+  left: clamp(12px, 3vw, 28px);
+  z-index: 2;
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  max-width: calc(100vw - 24px);
+  padding: 8px;
+  border: 1px solid var(--panel-border);
+  border-radius: 8px;
+  background: var(--panel);
+  box-shadow: 0 14px 40px rgba(0, 0, 0, 0.28);
+  backdrop-filter: blur(18px);
+}
+
+.motion-toggle {
+  display: inline-flex;
+  min-width: 116px;
+  min-height: 44px;
+  align-items: center;
+  justify-content: center;
+  gap: 9px;
+  padding: 0 15px;
+  border: 1px solid rgba(107, 231, 216, 0.46);
+  border-radius: 7px;
+  background: rgba(107, 231, 216, 0.12);
+  color: var(--text);
+  cursor: pointer;
+  transition:
+    background-color 160ms ease,
+    border-color 160ms ease,
+    transform 160ms ease;
+}
+
+.motion-toggle:hover {
+  border-color: rgba(255, 209, 111, 0.68);
+  background: rgba(255, 209, 111, 0.14);
+}
+
+.motion-toggle:active {
+  transform: translateY(1px);
+}
+
+.motion-toggle:focus-visible {
+  outline: 3px solid rgba(107, 231, 216, 0.6);
+  outline-offset: 3px;
+}
+
+.motion-toggle span {
+  line-height: 1;
+  white-space: nowrap;
+}
+
+.motion-state {
+  min-width: 96px;
+  padding: 0 8px;
+  color: var(--muted);
+  font-size: 0.875rem;
+  line-height: 1.2;
+  white-space: nowrap;
+}
+
+.sr-only {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+@media (max-width: 520px) {
+  .orbit-shell {
+    min-height: 360px;
+  }
+
+  .orbit-toolbar {
+    right: 12px;
+    align-items: stretch;
+    justify-content: space-between;
+  }
+
+  .motion-toggle {
+    min-width: 108px;
+  }
+
+  .motion-state {
+    display: flex;
+    min-width: 0;
+    align-items: center;
+    justify-content: flex-end;
+    text-align: right;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    transition-duration: 1ms !important;
+    animation-duration: 1ms !important;
+    animation-iteration-count: 1 !important;
+  }
+}
