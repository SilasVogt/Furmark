@@ -4,7 +4,7 @@ export class DependencyCycleError extends Error {
   readonly cycle: string[];
 
   constructor(cycle: string[]) {
-    super(`Dependency cycle detected: ${cycle.join(", ")}`);
+    super(`Dependency cycle detected: ${[...cycle, cycle[0]].join(" -> ")}`);
     this.name = "DependencyCycleError";
     this.cycle = cycle;
   }
@@ -50,10 +50,32 @@ export function dependencyBatches(graph: DependencyGraph): string[][] {
   }
 
   if (processed.size !== nodes.size) {
-    const cycle = [...nodes].filter((node) => !processed.has(node)).sort();
-    throw new DependencyCycleError(cycle);
+    throw new DependencyCycleError(findCycle(remainingDeps, processed));
   }
 
