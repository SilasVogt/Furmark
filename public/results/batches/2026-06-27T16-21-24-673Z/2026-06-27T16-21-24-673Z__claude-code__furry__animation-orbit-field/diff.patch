diff --git a/src/style.css b/src/style.css
index 6a6f6bd..78a5ca9 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,90 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  font-family: system-ui, sans-serif;
+  background: #04050d;
+  color: #eaf0ff;
+}
+
+.orbit {
+  position: fixed;
+  inset: 0;
+  overflow: hidden;
+}
+
+.orbit__canvas {
+  position: absolute;
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  display: block;
+  touch-action: none;
+}
+
+.orbit__panel {
+  position: absolute;
+  top: 1rem;
+  left: 1rem;
+  max-width: min(20rem, calc(100vw - 2rem));
+  padding: 1rem 1.1rem;
+  border-radius: 0.9rem;
+  background: rgba(10, 14, 34, 0.6);
+  backdrop-filter: blur(8px);
+  border: 1px solid rgba(150, 180, 255, 0.18);
+}
+
+.orbit__title {
+  margin: 0 0 0.25rem;
+  font-size: 1.15rem;
+  letter-spacing: 0.02em;
+}
+
+.orbit__hint {
+  margin: 0 0 0.75rem;
+  font-size: 0.85rem;
+  color: #aeb8d8;
+}
+
+.orbit__btn {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.5rem;
+  padding: 0.5rem 0.9rem;
+  font-size: 0.95rem;
+  font-weight: 600;
+  color: #0a0e22;
+  background: #9fc4ff;
+  border: none;
+  border-radius: 0.6rem;
+  cursor: pointer;
+}
+
+.orbit__btn:hover {
+  background: #b9d4ff;
+}
+
+.orbit__btn:focus-visible {
+  outline: 3px solid #ffd166;
+  outline-offset: 2px;
+}
+
+.orbit__note {
+  margin: 0.75rem 0 0;
+  font-size: 0.8rem;
+  color: #ffd9a8;
+}
+
+.orbit__sr {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  margin: -1px;
+  padding: 0;
+  border: 0;
+  overflow: hidden;
+  clip: rect(0 0 0 0);
+  white-space: nowrap;
+}
