+  border-radius: 16px;
+  padding: clamp(.95rem, 2vw, 1.3rem);
+  box-shadow: var(--shadow);
+}
+.trace::before {
+  content: "";
+  position: absolute;
+  inset: 0 0 auto 0;
+  height: 1px;
+  background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--brand) 65%, transparent), transparent);
+}
+.trace__head { display: flex; align-items: center; gap: .6rem; }
+.sev {
+  font: 600 .72rem/1 var(--mono);
+  letter-spacing: .04em;
+  color: #ffd9a8;
+  background: color-mix(in srgb, var(--slow) 18%, transparent);
+  border: 1px solid color-mix(in srgb, var(--slow) 42%, transparent);
+  padding: .3rem .5rem;
+  border-radius: 6px;
+}
+.trace__title { font-weight: 600; font-size: .98rem; }
+.trace__live {
+  margin-left: auto;
+  display: inline-flex;
+  align-items: center;
+  gap: .4rem;
+  font-size: .76rem;
+  color: var(--err);
+}
+.ping { position: relative; width: 7px; height: 7px; border-radius: 50%; background: var(--err); }
+.ping::after {
+  content: "";
+  position: absolute;
+  inset: -4px;
+  border-radius: 50%;
+  border: 1px solid var(--err);
+  animation: ping 1.8s ease-out infinite;
+}
+@keyframes ping { to { transform: scale(2.2); opacity: 0; } }
+.trace__sub {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: .5rem;
+  color: var(--faint);
+  font: 500 .78rem/1.4 var(--mono);
+  margin: .6rem 0 .9rem;
+}
+.trace__sub svg { width: .95em; height: .95em; vertical-align: -2px; margin-right: .3rem; }
+.trace__axis {
+  display: flex;
+  justify-content: space-between;
+  padding-left: calc(var(--label-w) + var(--lane-gap));
+  font: 500 .66rem/1 var(--mono);
+  color: var(--faint);
+  margin-bottom: .55rem;
+}
+.trace__lanes {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  gap: .5rem;
+  padding-top: 1.4rem;
+}
+.lane {
+  display: grid;
+  grid-template-columns: var(--label-w) 1fr;
+  gap: var(--lane-gap);
+  align-items: center;
+}
+.lane__label { display: flex; flex-direction: column; gap: .1rem; min-width: 0; }
+.lane__svc {
+  font: 600 .8rem/1.1 var(--mono);
+  color: var(--text);
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+.lane__meta { font: 500 .66rem/1 var(--mono); color: var(--faint); }
+.lane__track {
+  position: relative;
+  height: 26px;
+  border-radius: 7px;
+  background:
+    repeating-linear-gradient(90deg, transparent 0 calc(20% - 1px), color-mix(in srgb, var(--border) 55%, transparent) calc(20% - 1px) 20%);
+}
+.span {
+  position: absolute;
+  top: 3px;
+  bottom: 3px;
+  display: flex;
+  align-items: center;
+  padding-inline: .5rem;
+  font: 600 .67rem/1 var(--mono);
+  color: #0a0e16;
+  border-radius: 5px;
+  overflow: hidden;
+  white-space: nowrap;
+  text-overflow: ellipsis;
+  box-shadow: 0 1px 0 rgba(255, 255, 255, .2) inset, 0 4px 10px -6px rgba(0, 0, 0, .6);
+}
+.span--ok { background: linear-gradient(180deg, #5fe0ad, #3cc78f); }
+.span--warn { background: linear-gradient(180deg, #ffe08a, #ffce5c); }
+.span--slow { background: linear-gradient(180deg, #ffb27a, #ff9646); }
+.span--err { background: linear-gradient(180deg, #ff8a9c, #ff5f78); color: #1a0a0e; }
+.marker {
+  position: absolute;
+  top: 1.05rem;
+  bottom: 0;
+  width: 2px;
+  left: calc(var(--label-w) + var(--lane-gap) + (100% - var(--label-w) - var(--lane-gap)) * var(--at));
+  background: repeating-linear-gradient(180deg, color-mix(in srgb, var(--brand) 92%, white) 0 5px, transparent 5px 9px);
+}
+.marker__tag {
+  position: absolute;
+  top: -1.15rem;
+  left: 50%;
+  transform: translateX(-50%);
+  white-space: nowrap;
+  font: 600 .64rem/1 var(--mono);
+  color: var(--brand);
+  background: color-mix(in srgb, var(--brand) 14%, var(--surface));
+  border: 1px solid color-mix(in srgb, var(--brand) 35%, transparent);
+  padding: .2rem .42rem;
+  border-radius: 5px;
+}
+.marker--soft { opacity: .9; background: repeating-linear-gradient(180deg, color-mix(in srgb, var(--err) 80%, transparent) 0 5px, transparent 5px 9px); }
+.marker--soft .marker__tag {
+  color: var(--err);
+  background: color-mix(in srgb, var(--err) 12%, var(--surface));
+  border-color: color-mix(in srgb, var(--err) 35%, transparent);
+}
+.trace__foot {
+  display: flex;
+  align-items: center;
+  gap: .75rem;
+  flex-wrap: wrap;
+  margin-top: 1rem;
+  padding-top: .85rem;
+  border-top: 1px solid var(--border);
+}
+.trace__cause { flex: 1; min-width: 60%; font-size: .82rem; color: var(--muted); }
+.trace__cause strong { color: var(--text); font-weight: 600; margin-right: .3rem; }
+.trace__open {
+  display: inline-flex;
+  align-items: center;
+  gap: .3rem;
+  color: var(--brand);
+  text-decoration: none;
+  font-weight: 600;
+  font-size: .85rem;
+  white-space: nowrap;
+}
+.trace__open:hover { text-decoration: underline; }
+.trace__open svg { width: 1em; height: 1em; }
+
+/* ---------- integration strip ---------- */
+.strip {
+  border-top: 1px solid var(--border);
+  border-bottom: 1px solid var(--border);
+  background: color-mix(in srgb, var(--surface) 40%, transparent);
+}
+.strip__inner {
+  display: flex;
+  align-items: center;
+  gap: clamp(1rem, 3vw, 2rem);
+  flex-wrap: wrap;
+  padding-block: 1.1rem;
+}
+.strip__label { font-size: .82rem; color: var(--faint); }
+.strip__logos {
+  list-style: none;
+  display: flex;
+  flex-wrap: wrap;
+  gap: clamp(.8rem, 2.5vw, 1.8rem);
+  margin: 0;
+  padding: 0;
+}
+.strip__logos li { font: 600 .9rem/1 var(--mono); color: var(--muted); }
+
+/* ---------- sections ---------- */
+.section { padding: clamp(4rem, 9vw, 7rem) 0; }
+.sec-head { max-width: 60ch; margin-bottom: clamp(2rem, 4vw, 3rem); }
+.sec-head .eyebrow { margin-bottom: .95rem; }
+.sec-head h2,
+.deepdive h2,
+.workflow h2 {
+  font-size: clamp(1.6rem, 3vw, 2.3rem);
+  letter-spacing: -.02em;
+  line-height: 1.1;
+  margin: 0 0 .7rem;
+}
+.sec-head p { color: var(--muted); font-size: 1.05rem; margin: 0; }
+
+/* ---------- features ---------- */
+.features {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
+  gap: clamp(.9rem, 2vw, 1.25rem);
+}
+.card {
+  background: linear-gradient(180deg, var(--surface), var(--bg-soft));
+  border: 1px solid var(--border);
+  border-radius: 14px;
+  padding: clamp(1.2rem, 2.2vw, 1.6rem);
+  transition: border-color .15s ease, transform .15s ease;
+}
+.card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
+.card__icon {
+  display: inline-flex;
+  width: 42px;
+  height: 42px;
+  align-items: center;
+  justify-content: center;
+  border-radius: 11px;
+  background: color-mix(in srgb, var(--brand) 14%, transparent);
+  border: 1px solid color-mix(in srgb, var(--brand) 28%, transparent);
+  color: var(--brand);
+  margin-bottom: 1rem;
+}
+.card__icon svg { width: 20px; height: 20px; }
+.card h3 { font-size: 1.05rem; margin: 0 0 .45rem; letter-spacing: -.01em; }
+.card p { color: var(--muted); font-size: .93rem; line-height: 1.55; margin: 0; }
+
+/* ---------- deep dive / query ---------- */
+.deepdive__grid {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
+  gap: clamp(2rem, 4vw, 3.5rem);
+  align-items: center;
+}
+.deepdive .eyebrow { margin-bottom: .95rem; }
+.sec-sub { color: var(--muted); font-size: 1.02rem; margin: 0; }
+.checklist { list-style: none; margin: 1.4rem 0 0; padding: 0; display: grid; gap: .7rem; }
+.checklist li {
+  display: flex;
+  gap: .6rem;
+  align-items: flex-start;
+  color: var(--muted);
+  font-size: .95rem;
+}
+.checklist svg { color: var(--ok); flex: none; width: 1.1em; height: 1.1em; margin-top: .15rem; }
+.qbox {
+  background: linear-gradient(180deg, var(--surface), var(--bg-soft));
+  border: 1px solid var(--border);
+  border-radius: 14px;
+  box-shadow: var(--shadow);
+  overflow: hidden;
+}
+.qbox__bar {
+  display: flex;
+  align-items: center;
+  gap: .6rem;
+  padding: .85rem 1rem;
+  border-bottom: 1px solid var(--border);
+  background: var(--surface-2);
+}
+.qbox__bar svg { color: var(--faint); width: 1.05em; height: 1.05em; flex: none; }
+.qbox__bar code {
+  font: 500 .85rem/1.4 var(--mono);
+  color: var(--text);
+  min-width: 0;
+  overflow-x: auto;
+  white-space: nowrap;
+}
+.qbox__bar em { font-style: normal; color: var(--brand); }
+.qbox__rows { list-style: none; margin: 0; padding: .3rem; }
+.qrow {
+  display: grid;
+  grid-template-columns: auto auto minmax(0, 1fr) auto auto;
+  gap: .7rem;
+  align-items: center;
+  padding: .55rem .7rem;
+  border-radius: 8px;
+  font: 500 .8rem/1 var(--mono);
+}
+.qrow:hover { background: var(--surface-2); }
+.qrow__time { color: var(--faint); }
+.qrow__svc { color: var(--text); }
+.qrow__path { color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.qrow__d { color: var(--slow); }
+.qrow__code { font-weight: 600; padding: .16rem .42rem; border-radius: 5px; }
+.qrow__code--err { color: var(--err); background: color-mix(in srgb, var(--err) 14%, transparent); }
+.qrow__code--ok { color: var(--ok); background: color-mix(in srgb, var(--ok) 14%, transparent); }
+
+/* ---------- workflow ---------- */
+.steps {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+  gap: clamp(1rem, 2.5vw, 1.6rem);
+}
+.step { position: relative; padding-top: 1.3rem; }
+.step::before {
+  content: "";
+  position: absolute;
+  top: .35rem;
+  left: 0;
+  right: 0;
+  height: 1px;
+  background: linear-gradient(90deg, color-mix(in srgb, var(--brand) 55%, transparent), transparent);
+}
+.step__top { display: flex; align-items: center; gap: .6rem; }
+.step__icon {
+  display: inline-flex;
+  width: 34px;
+  height: 34px;
+  align-items: center;
+  justify-content: center;
+  border-radius: 9px;
+  background: color-mix(in srgb, var(--brand) 13%, transparent);
+  border: 1px solid color-mix(in srgb, var(--brand) 26%, transparent);
+  color: var(--brand);
+}
+.step__icon svg { width: 17px; height: 17px; }
+.step__k { font: 700 .8rem/1 var(--mono); color: var(--brand); }
+.step h3 { font-size: 1.08rem; margin: .8rem 0 .4rem; letter-spacing: -.01em; }
+.step p { color: var(--muted); font-size: .92rem; line-height: 1.55; margin: 0; }
+
+/* ---------- cta ---------- */
+.cta { padding: clamp(3rem, 7vw, 5.5rem) 0; }
+.cta__inner {
+  position: relative;
+  overflow: hidden;
+  text-align: center;
+  max-width: 700px;
+  margin-inline: auto;
+  background: linear-gradient(180deg, var(--surface), var(--bg-soft));
+  border: 1px solid var(--border);
+  border-radius: 20px;
+  padding: clamp(2rem, 5vw, 3.2rem);
+}
+.cta__inner::before {
+  content: "";
+  position: absolute;
+  inset: -45% 25% auto;
+  height: 60%;
+  background: radial-gradient(closest-side, color-mix(in srgb, var(--brand) 30%, transparent), transparent);
+  filter: blur(22px);
+}
+.cta__inner > * { position: relative; }
+.cta__inner h2 { font-size: clamp(1.7rem, 3.5vw, 2.5rem); letter-spacing: -.02em; margin: 0 0 .6rem; }
+.cta__inner p { color: var(--muted); font-size: 1.05rem; margin: 0 0 1.6rem; }
+.cta__fine { display: block; margin-top: 1.1rem; font: 500 .8rem/1 var(--mono); color: var(--faint); }
+
+/* ---------- footer ---------- */
+.footer {
+  border-top: 1px solid var(--border);
+  padding: clamp(2.5rem, 5vw, 3.5rem) 0 2rem;
+  margin-top: 2rem;
+}
+.footer__grid {
+  display: grid;
+  grid-template-columns: 1.6fr repeat(3, 1fr);
+  gap: 2rem;
+}
+.footer__brand p { color: var(--faint); font-size: .88rem; margin: .85rem 0 0; max-width: 32ch; }
+.footer__col h3 {
+  font-size: .76rem;
+  text-transform: uppercase;
+  letter-spacing: .07em;
+  color: var(--faint);
+  margin: 0 0 .9rem;
+}
+.footer__col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: .55rem; }
+.footer__col a { color: var(--muted); text-decoration: none; font-size: .9rem; }
+.footer__col a:hover { color: var(--text); }
+.footer__bottom {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  flex-wrap: wrap;
+  margin-top: 2.5rem;
+  padding-top: 1.4rem;
+  border-top: 1px solid var(--border);
+  color: var(--faint);
+  font-size: .82rem;
+}
+.footer__bottom nav { display: flex; gap: 1.3rem; }
+.footer__bottom a { text-decoration: none; color: var(--faint); }
+.footer__bottom a:hover { color: var(--text); }
+
+/* ---------- responsive ---------- */
+@media (max-width: 980px) {
+  .hero__grid { grid-template-columns: 1fr; }
+  .deepdive__grid { grid-template-columns: 1fr; }
+}
+@media (max-width: 900px) {
+  .nav__links { display: none; }
+  .nav__cta { margin-left: auto; }
+}
+@media (max-width: 760px) {
+  .footer__grid { grid-template-columns: 1fr 1fr; }
+  .footer__brand { grid-column: 1 / -1; }
+}
+@media (max-width: 540px) {
+  .nav__cta .btn--ghost { display: none; }
+  .footer__bottom { flex-direction: column; align-items: flex-start; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  html { scroll-behavior: auto; }
+  *, *::before, *::after { animation: none !important; transition: none !important; }
+}
