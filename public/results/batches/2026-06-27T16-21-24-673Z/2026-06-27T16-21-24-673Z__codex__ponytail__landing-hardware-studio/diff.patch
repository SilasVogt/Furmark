+  gap: 1.6rem;
+  align-items: stretch;
+  padding: 2rem 0 5rem;
+}
+
+.module-media {
+  position: relative;
+  overflow: hidden;
+  min-height: 34rem;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: #131719;
+}
+
+.module-media img {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  object-position: 38% center;
+}
+
+.module-copy {
+  align-self: center;
+  padding: 1rem 0 1rem 1.2rem;
+}
+
+.detail-rows {
+  display: grid;
+  gap: 0;
+  margin-top: 2rem;
+  border-top: 1px solid var(--line);
+}
+
+.detail-rows article {
+  padding: 1.1rem 0;
+  border-bottom: 1px solid var(--line);
+}
+
+.detail-rows h3 {
+  margin: 0;
+  color: var(--text);
+  font-size: 1.08rem;
+}
+
+.detail-rows p {
+  margin: 0.35rem 0 0;
+}
+
+.specs-section {
+  padding: 2rem 0 5.5rem;
+}
+
+.spec-grid {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 0.85rem;
+}
+
+.spec-tile {
+  min-width: 0;
+  min-height: 13rem;
+  padding: 1rem;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background:
+    linear-gradient(135deg, rgba(120, 215, 248, 0.08), transparent 34%),
+    rgba(238, 243, 245, 0.035);
+}
+
+.spec-tile.wide {
+  grid-column: span 2;
+}
+
+.spec-tile svg {
+  color: var(--accent);
+}
+
+.spec-tile strong {
+  display: block;
+  margin-top: 1.4rem;
+  color: var(--text);
+  font-size: 1.45rem;
+  line-height: 1.05;
+}
+
+.spec-tile p {
+  margin: 0.55rem 0 0;
+}
+
+.buy-section {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 1.5rem;
+  align-items: center;
+  margin-bottom: 4rem;
+  padding: 2rem;
+  border: 1px solid rgba(120, 215, 248, 0.28);
+  border-radius: 8px;
+  background:
+    linear-gradient(135deg, rgba(120, 215, 248, 0.12), transparent 44%),
+    var(--panel-strong);
+}
+
+footer {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  width: min(100% - 2rem, 1180px);
+  margin: 0 auto;
+  padding: 0 0 2rem;
+  font-size: 0.92rem;
+}
+
+:focus-visible {
+  outline: 3px solid rgba(120, 215, 248, 0.6);
+  outline-offset: 3px;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    transition-duration: 0.01ms !important;
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+  }
+}
+
+@media (max-width: 980px) {
+  .site-header {
+    grid-template-columns: 1fr auto;
+  }
+
+  nav {
+    display: none;
+  }
+
+  .hero {
+    grid-template-columns: 1fr;
+    min-height: auto;
+    padding-top: 2rem;
+  }
+
+  .hero h1 {
+    font-size: 4.4rem;
+  }
+
+  .hero-media {
+    order: -1;
+  }
+
+  .hero-media img {
+    min-height: 22rem;
+    object-position: 57% center;
+  }
+
+  .signal-strip {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .signal-strip div:nth-child(3) {
+    border-left: 0;
+    border-top: 1px solid var(--line);
+  }
+
+  .signal-strip div:nth-child(4) {
+    border-top: 1px solid var(--line);
+  }
+
+  .configure-layout,
+  .modules-section,
+  .buy-section {
+    grid-template-columns: 1fr;
+  }
+
+  .build-summary {
+    position: static;
+  }
+
+  .module-copy {
+    padding-left: 0;
+  }
+
+  .spec-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 700px) {
+  .site-header,
+  .hero,
+  .signal-strip,
+  .configure-section,
+  .modules-section,
+  .specs-section,
+  .buy-section,
+  footer {
+    width: min(100% - 1rem, 1180px);
+  }
+
+  .site-header {
+    min-height: 62px;
+  }
+
+  .nav-cta {
+    padding: 0 0.8rem;
+  }
+
+  .hero {
+    gap: 1.25rem;
+    padding: 0.75rem 0 2rem;
+  }
+
+  .hero h1 {
+    font-size: 3.2rem;
+  }
+
+  .hero p {
+    font-size: 1rem;
+  }
+
+  .hero-actions,
+  .buy-section .button {
+    width: 100%;
+  }
+
+  .hero-actions .button {
+    width: 100%;
+  }
+
+  .hero-media img {
+    min-height: 17rem;
+  }
+
+  .signal-strip {
+    grid-template-columns: 1fr;
+  }
+
+  .signal-strip div,
+  .signal-strip div:nth-child(4) {
+    border-left: 0;
+    border-top: 1px solid var(--line);
+  }
+
+  .signal-strip div:first-child {
+    border-top: 0;
+  }
+
+  .configure-section {
+    padding: 4.5rem 0 3.5rem;
+  }
+
+  .section-heading h2,
+  .module-copy h2,
+  .buy-section h2 {
+    font-size: 2.2rem;
+  }
+
+  .option-list {
+    grid-template-columns: 1fr;
+  }
+
+  .option-content {
+    min-height: 5.4rem;
+  }
+
+  .module-media {
+    min-height: 24rem;
+  }
+
+  .spec-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .spec-tile.wide {
+    grid-column: auto;
+  }
+
+  .buy-section {
+    padding: 1.25rem;
+  }
+
+  footer {
+    flex-direction: column;
+  }
+}
