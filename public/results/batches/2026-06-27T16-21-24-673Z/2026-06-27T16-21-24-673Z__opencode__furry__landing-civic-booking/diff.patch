diff --git a/src/style.css b/src/style.css
index 6a6f6bd..941cea6 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,648 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  --bg: #ffffff;
+  --bg-muted: #f4f6f9;
+  --surface: #ffffff;
+  --border: #c7ced8;
+  --border-strong: #8a96a6;
+  --text: #15243a;
+  --text-muted: #46566c;
+  --primary: #14507a;
+  --primary-strong: #0d3a5c;
+  --primary-contrast: #ffffff;
+  --accent: #b85c12;
+  --focus: #0a4d8c;
+  --ok: #1a6b3c;
+  --shadow: 0 1px 2px rgba(16, 32, 52, 0.08), 0 4px 16px rgba(16, 32, 52, 0.06);
+  --radius: 12px;
+  --radius-sm: 8px;
+  --maxw: 1120px;
+  --space: clamp(1rem, 0.6rem + 1.8vw, 2.25rem);
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html {
+  scroll-behavior: smooth;
+  scroll-padding-top: 5rem;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
+  line-height: 1.55;
+  font-size: 16px;
+  -webkit-text-size-adjust: 100%;
+}
+
+img {
+  max-width: 100%;
+  display: block;
+}
+
+a {
+  color: var(--primary-strong);
+}
+
+:focus-visible {
+  outline: 3px solid var(--focus);
+  outline-offset: 2px;
+  border-radius: 4px;
+}
+
+.visually-hidden {
+  position: absolute !important;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+.container {
+  width: 100%;
+  max-width: var(--maxw);
+  margin-inline: auto;
+  padding-inline: clamp(1rem, 0.5rem + 2.5vw, 2rem);
+}
+
+.skip-link {
+  position: absolute;
+  left: 0.5rem;
+  top: -4rem;
+  z-index: 100;
+  background: var(--primary-strong);
+  color: var(--primary-contrast);
+  padding: 0.6rem 0.9rem;
+  border-radius: var(--radius-sm);
+  text-decoration: none;
+  transition: top 0.15s ease;
+}
+.skip-link:focus-visible {
+  top: 0.5rem;
+}
+
+.btn {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 0.5rem;
+  border-radius: var(--radius-sm);
+  padding: 0.7rem 1.15rem;
+  font-size: 1rem;
+  font-weight: 600;
+  text-decoration: none;
+  border: 2px solid transparent;
+  cursor: pointer;
+  min-height: 44px;
+  line-height: 1.2;
+}
+.btn-primary {
+  background: var(--primary);
+  color: var(--primary-contrast);
+  border-color: var(--primary);
+}
+.btn-primary:hover {
+  background: var(--primary-strong);
+  border-color: var(--primary-strong);
+}
+.btn-secondary {
+  background: var(--surface);
+  color: var(--primary-strong);
+  border-color: var(--border-strong);
+}
+.btn-secondary:hover {
+  border-color: var(--primary-strong);
+}
+.btn-block {
+  width: 100%;
+}
+
+.site-header {
+  position: sticky;
+  top: 0;
+  z-index: 20;
+  background: var(--surface);
+  border-bottom: 1px solid var(--border);
+}
+.header-inner {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  min-height: 64px;
+  flex-wrap: wrap;
+  padding-block: 0.5rem;
+}
+.brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.5rem;
+  font-weight: 700;
+  font-size: 1.15rem;
+  color: var(--text);
+  text-decoration: none;
+}
+.nav-list {
+  list-style: none;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.25rem 0.25rem;
+  margin: 0;
+  padding: 0;
+}
+.nav-list a {
+  display: inline-block;
+  padding: 0.5rem 0.75rem;
+  border-radius: var(--radius-sm);
+  text-decoration: none;
+  color: var(--text);
+  font-weight: 500;
+}
+.nav-list a:hover {
+  background: var(--bg-muted);
+}
+
+.hero {
+  padding-block: var(--space);
+  background:
+    radial-gradient(1200px 400px at 80% -10%, rgba(20, 80, 122, 0.10), transparent 60%),
+    var(--bg);
+  border-bottom: 1px solid var(--border);
+}
+.hero-inner {
+  display: grid;
+  grid-template-columns: 1.2fr 1fr;
+  gap: clamp(1.5rem, 1rem + 2vw, 3rem);
+  align-items: center;
+}
+.eyebrow {
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+  font-size: 0.8rem;
+  color: var(--primary-strong);
+  font-weight: 700;
+  margin: 0 0 0.5rem;
+}
+.hero-copy h1 {
+  font-size: clamp(1.9rem, 1.2rem + 2.6vw, 3rem);
+  line-height: 1.1;
+  margin: 0 0 0.75rem;
+  letter-spacing: -0.01em;
+}
+.hero-subtitle {
+  font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem);
+  color: var(--text-muted);
+  margin: 0 0 1.25rem;
+  max-width: 52ch;
+}
+.hero-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.75rem;
+  margin-bottom: 0.75rem;
+}
+.hero-help {
+  color: var(--text-muted);
+  font-size: 0.95rem;
+  margin: 0;
+}
+
+.hero-card {
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 1.25rem;
+  box-shadow: var(--shadow);
+}
+.hero-card-label {
+  display: block;
+  font-weight: 700;
+  font-size: 0.95rem;
+  margin-bottom: 0.75rem;
+}
+.slot-list {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  gap: 0.6rem;
+}
+.slot-list li {
+  display: grid;
+  grid-template-columns: auto 1fr;
+  align-items: center;
+  gap: 0.5rem 0.75rem;
+  padding: 0.75rem 0.85rem;
+  border: 1px solid var(--border);
+  border-radius: var(--radius-sm);
+  background: var(--bg-muted);
+}
+.slot-list li svg {
+  color: var(--primary);
+}
+.slot-list li > span:nth-child(2) {
+  font-weight: 600;
+}
+.slot-meta {
+  grid-column: 2;
+  color: var(--text-muted);
+  font-size: 0.9rem;
+}
+.hero-card-note {
+  margin: 0.75rem 0 0;
+  font-size: 0.85rem;
+  color: var(--text-muted);
+}
+
+.section {
+  padding-block: var(--space);
+}
+.section-muted {
+  background: var(--bg-muted);
+  border-block: 1px solid var(--border);
+}
+.section-head {
+  max-width: 60ch;
+  margin-bottom: 1.75rem;
+}
+.section-head h2 {
+  font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
+  margin: 0 0 0.5rem;
+  letter-spacing: -0.01em;
+}
+.section-head p {
+  color: var(--text-muted);
+  margin: 0;
+}
+
+.card-grid {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+  gap: 1rem;
+}
+.card-grid-three {
+  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+}
+.card {
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 1.25rem;
+  box-shadow: var(--shadow);
+  display: flex;
+  flex-direction: column;
+  gap: 0.5rem;
+}
+.card-icon {
+  display: inline-flex;
+  width: 44px;
+  height: 44px;
+  align-items: center;
+  justify-content: center;
+  border-radius: var(--radius-sm);
+  background: rgba(20, 80, 122, 0.10);
+  color: var(--primary-strong);
+  margin-bottom: 0.25rem;
+}
+.card h3 {
+  margin: 0;
+  font-size: 1.15rem;
+}
+.card > p {
+  margin: 0;
+  color: var(--text-muted);
+}
+.card-examples {
+  list-style: none;
+  margin: 0.5rem 0 0;
+  padding: 0;
+  display: grid;
+  gap: 0.35rem;
+}
+.card-examples li {
+  display: flex;
+  align-items: center;
+  gap: 0.45rem;
+  font-size: 0.95rem;
+}
+.card-examples svg {
+  color: var(--ok);
+  flex-shrink: 0;
+}
+.card-link {
+  margin-top: 0.75rem;
+  font-weight: 600;
+  text-decoration: none;
+  align-self: flex-start;
+}
+.card-link:hover {
+  text-decoration: underline;
+}
+
+.steps {
+  list-style: none;
+  counter-reset: step;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+  gap: 1rem;
+}
+.steps li {
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 1.1rem;
+  display: grid;
+  gap: 0.35rem;
+}
+.step-num {
+  display: inline-flex;
+  width: 30px;
+  height: 30px;
+  border-radius: 50%;
+  background: var(--primary);
+  color: var(--primary-contrast);
+  align-items: center;
+  justify-content: center;
+  font-weight: 700;
+  margin-bottom: 0.25rem;
+}
+.steps h3 {
+  margin: 0;
+  font-size: 1.05rem;
+}
+.steps p {
+  margin: 0;
+  color: var(--text-muted);
+  font-size: 0.95rem;
+}
+.availability-note {
+  margin-top: 1.5rem;
+  display: flex;
+  align-items: flex-start;
+  gap: 0.6rem;
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-left: 4px solid var(--accent);
+  padding: 0.9rem 1rem;
+  border-radius: var(--radius-sm);
+}
+.availability-note svg {
+  color: var(--accent);
+  flex-shrink: 0;
+  margin-top: 0.15rem;
+}
+.availability-note p {
+  margin: 0;
+}
+
+.book-layout {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: clamp(1.5rem, 1rem + 2vw, 3rem);
+  align-items: start;
+}
+.book-copy h2 {
+  font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
+  margin: 0 0 0.5rem;
+}
+.book-copy > p {
+  color: var(--text-muted);
+  margin: 0 0 1rem;
+}
+.book-points {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  gap: 0.5rem;
+}
+.book-points li {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  font-weight: 500;
+}
+.book-points svg {
+  color: var(--ok);
+}
+.book-form {
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: clamp(1rem, 0.75rem + 1vw, 1.5rem);
+  box-shadow: var(--shadow);
+  display: grid;
+  gap: 1rem;
+}
+.field {
+  display: grid;
+  gap: 0.3rem;
+}
+.field label {
+  font-weight: 600;
+}
+.req {
+  color: var(--accent);
+}
+.help {
+  color: var(--text-muted);
+  font-size: 0.88rem;
+}
+input,
+select,
+textarea {
+  width: 100%;
+  font: inherit;
+  color: var(--text);
+  background: var(--surface);
+  border: 1px solid var(--border-strong);
+  border-radius: var(--radius-sm);
+  padding: 0.6rem 0.7rem;
+  min-height: 44px;
+}
+textarea {
+  min-height: 84px;
+  resize: vertical;
+}
+input:focus,
+select:focus,
+textarea:focus {
+  border-color: var(--focus);
+  outline: 3px solid var(--focus);
+  outline-offset: 1px;
+}
+.form-foot,
+.form-status {
+  margin: 0;
+  font-size: 0.9rem;
+}
+.form-foot {
+  color: var(--text-muted);
+}
+.form-status {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  color: var(--ok);
+  font-weight: 600;
+}
+
+.access-cta {
+  margin: 1.5rem 0 0;
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 1rem 1.1rem;
+}
+
+.contact-layout {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: clamp(1.5rem, 1rem + 2vw, 3rem);
+  align-items: start;
+}
+.contact-layout > div > h2 {
+  font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
+  margin: 0 0 0.5rem;
+}
+.contact-layout > div > p {
+  color: var(--text-muted);
+  margin: 0 0 1.25rem;
+}
+.contact-list {
+  display: grid;
+  gap: 1rem;
+  margin: 0;
+}
+.contact-list > div {
+  border: 1px solid var(--border);
+  border-radius: var(--radius-sm);
+  padding: 0.85rem 1rem;
+  background: var(--bg-muted);
+}
+.contact-list dt {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  font-weight: 700;
+  margin-bottom: 0.25rem;
+}
+.contact-list dt svg {
+  color: var(--primary);
+}
+.contact-list dd {
+  margin: 0;
+}
+.contact-card {
+  background: var(--surface);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: clamp(1rem, 0.75rem + 1vw, 1.5rem);
+  box-shadow: var(--shadow);
+}
+.contact-card h3 {
+  margin: 0 0 0.25rem;
+}
+.callback-form {
+  display: grid;
+  gap: 1rem;
+  margin-top: 0.75rem;
+}
+
+.site-footer {
+  background: #102236;
+  color: #e7edf4;
+  border-top: 1px solid #0a1726;
+}
+.footer-inner {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding-block: 1.75rem;
+}
+.footer-brand {
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  margin: 0;
+  font-weight: 700;
+}
+.footer-tag {
+  margin: 0.25rem 0 0;
+  color: #b9c6d6;
+  font-size: 0.95rem;
+}
+.footer-nav {
+  list-style: none;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.25rem 0.25rem;
+  margin: 0;
+  padding: 0;
+}
+.footer-nav a {
+  display: inline-block;
+  padding: 0.4rem 0.6rem;
+  border-radius: var(--radius-sm);
+  color: #e7edf4;
+  text-decoration: none;
+}
+.footer-nav a:hover {
+  background: rgba(255, 255, 255, 0.08);
+}
+.site-footer :focus-visible {
+  outline-color: #9ccbff;
+}
+.copyright {
+  margin: 0;
+  padding: 0.85rem 1rem 1.25rem;
+  text-align: center;
+  color: #9fadc0;
+  font-size: 0.85rem;
+}
+
+@media (max-width: 860px) {
+  .hero-inner,
+  .book-layout,
+  .contact-layout {
+    grid-template-columns: 1fr;
+  }
+  .hero-card {
+    order: 2;
+  }
+}
+
+@media (max-width: 560px) {
+  .nav-list a {
+    padding: 0.4rem 0.5rem;
+  }
+  .btn {
+    width: 100%;
+  }
+  .hero-actions .btn {
+    width: 100%;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  html {
+    scroll-behavior: auto;
+  }
+  * {
+    transition: none !important;
+  }
+}
