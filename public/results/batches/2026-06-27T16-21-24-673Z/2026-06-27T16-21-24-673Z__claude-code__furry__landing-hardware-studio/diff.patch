diff --git a/src/style.css b/src/style.css
index 6a6f6bd..34816a4 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,653 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  --bg: #0a0b0e;
+  --bg-soft: #0f1116;
+  --panel: #14161d;
+  --panel-2: #191c25;
+  --line: rgba(255, 255, 255, 0.09);
+  --line-strong: rgba(255, 255, 255, 0.18);
+  --text: #eceef3;
+  --muted: #9aa1ad;
+  --muted-soft: #707682;
+  --warm: #ffc890;
+  --warm-strong: #ffb066;
+  --radius: 16px;
+  --maxw: 1200px;
+  --font: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, Helvetica,
+    Arial, sans-serif;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html {
+  -webkit-text-size-adjust: 100%;
+}
+
+body {
+  margin: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: var(--font);
+  line-height: 1.55;
+  -webkit-font-smoothing: antialiased;
+  text-rendering: optimizeLegibility;
+  overflow-x: hidden;
+}
+
+h1,
+h2,
+h3 {
+  margin: 0;
+  font-weight: 600;
+  letter-spacing: -0.02em;
+  line-height: 1.05;
+}
+
+p {
+  margin: 0;
+}
+
+a {
+  color: inherit;
+  text-decoration: none;
+}
+
+img,
+svg {
+  display: block;
+  max-width: 100%;
+}
+
+:focus-visible {
+  outline: 2px solid var(--warm);
+  outline-offset: 2px;
+  border-radius: 6px;
+}
+
+.page {
+  position: relative;
+}
+
+/* ---------- Buttons ---------- */
+.btn {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 0.5rem;
+  padding: 0.85rem 1.4rem;
+  border-radius: 999px;
+  font-size: 0.95rem;
+  font-weight: 600;
+  letter-spacing: -0.01em;
+  border: 1px solid transparent;
+  cursor: pointer;
+  transition:
+    transform 0.15s ease,
+    background 0.2s ease,
+    border-color 0.2s ease,
+    opacity 0.2s ease;
+  white-space: nowrap;
+}
+.btn:active {
+  transform: translateY(1px);
+}
+.btn-primary {
+  background: var(--text);
+  color: #0a0b0e;
+}
+.btn-primary:hover {
+  background: #fff;
+}
+.btn-ghost {
+  background: transparent;
+  border-color: var(--line-strong);
+  color: var(--text);
+}
+.btn-ghost:hover {
+  border-color: var(--text);
+}
+
+/* ---------- Nav ---------- */
+.nav {
+  position: sticky;
+  top: 0;
+  z-index: 20;
+  backdrop-filter: blur(14px);
+  background: rgba(10, 11, 14, 0.72);
+  border-bottom: 1px solid var(--line);
+}
+.nav-inner {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: 0.85rem clamp(1rem, 4vw, 2.5rem);
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+}
+.brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.55rem;
+  font-weight: 600;
+  letter-spacing: 0.01em;
+  font-size: 1.05rem;
+}
+.brand-mark {
+  width: 16px;
+  height: 16px;
+  border-radius: 50%;
+  background: radial-gradient(circle at 35% 30%, #fff4e0, var(--warm-strong));
+  box-shadow: 0 0 14px rgba(255, 184, 107, 0.6);
+}
+.nav-links {
+  display: flex;
+  gap: clamp(1rem, 3vw, 2rem);
+  font-size: 0.92rem;
+  color: var(--muted);
+}
+.nav-links a:hover {
+  color: var(--text);
+}
+.nav-cta {
+  padding: 0.5rem 1.1rem;
+  font-size: 0.9rem;
+  font-variant-numeric: tabular-nums;
+}
+
+/* ---------- Layout helpers ---------- */
+.eyebrow {
+  text-transform: uppercase;
+  letter-spacing: 0.18em;
+  font-size: 0.74rem;
+  font-weight: 600;
+  color: var(--warm);
+}
+.section-title {
+  font-size: clamp(1.7rem, 3.4vw, 2.7rem);
+  max-width: 16ch;
+}
+.section-lede {
+  color: var(--muted);
+  font-size: clamp(1rem, 1.4vw, 1.12rem);
+  max-width: 56ch;
+}
+
+/* ---------- Hero ---------- */
+.hero {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 2.5rem)
+    clamp(2.5rem, 6vw, 4rem);
+  display: grid;
+  grid-template-columns: 1.05fr 1fr;
+  gap: clamp(1.5rem, 4vw, 3.5rem);
+  align-items: start;
+  min-height: calc(100svh - 64px);
+}
+
+.hero-stage {
+  min-width: 0;
+}
+.stage-frame {
+  position: relative;
+  border: 1px solid var(--line);
+  border-radius: 24px;
+  padding: clamp(1rem, 2.5vw, 2rem);
+  overflow: hidden;
+  background:
+    radial-gradient(
+      120% 90% at 70% 28%,
+      rgba(255, 200, 144, 0.16),
+      transparent 60%
+    ),
+    linear-gradient(180deg, #14171f, #0c0e13 78%);
+  box-shadow:
+    inset 0 1px 0 rgba(255, 255, 255, 0.05),
+    0 30px 60px -30px rgba(0, 0, 0, 0.8);
+}
+.stage-tag {
+  position: absolute;
+  top: 1rem;
+  left: 1rem;
+  z-index: 2;
+  display: inline-flex;
+  align-items: center;
+  gap: 0.4rem;
+  font-size: 0.72rem;
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  color: var(--muted);
+  background: rgba(0, 0, 0, 0.35);
+  border: 1px solid var(--line);
+  padding: 0.3rem 0.7rem;
+  border-radius: 999px;
+}
+.stage-tag::before {
+  content: "";
+  width: 7px;
+  height: 7px;
+  border-radius: 50%;
+  background: var(--warm-strong);
+  box-shadow: 0 0 8px var(--warm-strong);
+}
+.lamp-svg {
+  width: 100%;
+  height: auto;
+  position: relative;
+  z-index: 1;
+}
+.stage-floor {
+  position: absolute;
+  left: 8%;
+  right: 8%;
+  bottom: clamp(1rem, 2.5vw, 2rem);
+  height: 1px;
+  background: linear-gradient(
+    90deg,
+    transparent,
+    rgba(255, 255, 255, 0.18),
+    transparent
+  );
+}
+
+.hero-panel {
+  min-width: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 1.1rem;
+  padding-top: clamp(0.5rem, 2vw, 1.5rem);
+}
+.display {
+  font-size: clamp(2.8rem, 7vw, 4.6rem);
+  letter-spacing: -0.035em;
+  display: flex;
+  flex-direction: column;
+  gap: 0.4rem;
+}
+.display-sub {
+  font-size: clamp(1.05rem, 1.8vw, 1.4rem);
+  font-weight: 500;
+  letter-spacing: -0.01em;
+  color: var(--muted);
+}
+.lede {
+  color: var(--muted);
+  font-size: clamp(1rem, 1.3vw, 1.1rem);
+  max-width: 46ch;
+}
+
+/* ---------- Configurator ---------- */
+.config {
+  display: flex;
+  flex-direction: column;
+  gap: 0.5rem;
+  margin-top: 0.25rem;
+}
+.optgroup {
+  border: none;
+  margin: 0;
+  padding: 0;
+  min-width: 0;
+}
+.optgroup-legend {
+  padding: 0;
+  font-size: 0.78rem;
+  font-weight: 600;
+  text-transform: uppercase;
+  letter-spacing: 0.12em;
+  color: var(--muted-soft);
+  margin-bottom: 0.5rem;
+}
+.optgroup-items {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
+  gap: 0.5rem;
+}
+.opt {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  gap: 0.15rem;
+  padding: 0.7rem 0.85rem;
+  border: 1px solid var(--line);
+  border-radius: 12px;
+  background: var(--panel);
+  cursor: pointer;
+  transition:
+    border-color 0.18s ease,
+    background 0.18s ease,
+    transform 0.18s ease;
+  min-width: 0;
+}
+.opt:hover {
+  border-color: var(--line-strong);
+  background: var(--panel-2);
+}
+.opt input {
+  position: absolute;
+  opacity: 0;
+  width: 1px;
+  height: 1px;
+  pointer-events: none;
+}
+.opt.is-selected {
+  border-color: var(--warm);
+  background: linear-gradient(
+    180deg,
+    rgba(255, 200, 144, 0.12),
+    rgba(255, 200, 144, 0.03)
+  );
+  box-shadow: 0 0 0 1px var(--warm) inset;
+}
+.opt:has(input:focus-visible) {
+  outline: 2px solid var(--warm);
+  outline-offset: 2px;
+}
+.opt-name {
+  font-size: 0.94rem;
+  font-weight: 600;
+  letter-spacing: -0.01em;
+}
+.opt-price {
+  font-size: 0.78rem;
+  color: var(--muted-soft);
+  font-variant-numeric: tabular-nums;
+}
+.opt.is-selected .opt-price {
+  color: var(--warm);
+}
+.opt-swatch-item {
+  padding-left: 2.6rem;
+}
+.opt-swatch {
+  position: absolute;
+  left: 0.85rem;
+  top: 50%;
+  transform: translateY(-50%);
+  width: 1.25rem;
+  height: 1.25rem;
+  border-radius: 50%;
+  border: 1px solid rgba(255, 255, 255, 0.25);
+  box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.4);
+}
+.config-note {
+  font-size: 0.86rem;
+  color: var(--muted);
+  margin: -0.1rem 0 0.7rem;
+  min-height: 1.2em;
+}
+
+.live-spec {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.5rem 1.5rem;
+  margin: 0;
+  padding: 0.9rem 0;
+  border-top: 1px solid var(--line);
+  border-bottom: 1px solid var(--line);
+}
+.live-spec div {
+  display: flex;
+  flex-direction: column;
+}
+.live-spec dt {
+  font-size: 0.74rem;
+  text-transform: uppercase;
+  letter-spacing: 0.1em;
+  color: var(--muted-soft);
+}
+.live-spec dd {
+  margin: 0;
+  font-size: 1.15rem;
+  font-weight: 600;
+  font-variant-numeric: tabular-nums;
+}
+
+.buy {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  flex-wrap: wrap;
+  gap: 1rem;
+  margin-top: 0.4rem;
+}
+.buy-price {
+  display: flex;
+  flex-direction: column;
+}
+.buy-amount {
+  font-size: 1.9rem;
+  font-weight: 700;
+  letter-spacing: -0.02em;
+  font-variant-numeric: tabular-nums;
+}
+.buy-meta {
+  font-size: 0.82rem;
+  color: var(--muted);
+}
+.buy-btn {
+  padding: 0.95rem 1.8rem;
+  font-size: 1rem;
+}
+
+/* ---------- Spec band ---------- */
+.specband {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 2.5rem);
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
+  gap: 1px;
+  background: var(--line);
+  border-radius: var(--radius);
+  overflow: hidden;
+  border: 1px solid var(--line);
+}
+.stat {
+  background: var(--bg);
+  padding: clamp(1.1rem, 2.5vw, 1.6rem);
+  display: flex;
+  flex-direction: column;
+  gap: 0.25rem;
+}
+.stat-value {
+  font-size: clamp(1.3rem, 2.4vw, 1.85rem);
+  font-weight: 700;
+  letter-spacing: -0.02em;
+  font-variant-numeric: tabular-nums;
+}
+.stat-label {
+  font-size: 0.82rem;
+  color: var(--muted);
+}
+
+/* ---------- System ---------- */
+.system,
+.specs,
+.closing {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: clamp(3rem, 8vw, 6rem) clamp(1rem, 4vw, 2.5rem);
+}
+.system-head {
+  display: flex;
+  flex-direction: column;
+  gap: 0.9rem;
+  margin-bottom: clamp(1.8rem, 4vw, 3rem);
+}
+.system-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
+  gap: 1px;
+  background: var(--line);
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  overflow: hidden;
+}
+.module {
+  background: var(--bg-soft);
+  padding: clamp(1.4rem, 3vw, 2rem);
+}
+.module h3 {
+  font-size: 1.2rem;
+  margin-bottom: 1.1rem;
+  padding-bottom: 0.8rem;
+  border-bottom: 1px solid var(--line);
+}
+.module ul {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 1rem;
+}
+.module li {
+  display: grid;
+  gap: 0.15rem;
+}
+.module-name {
+  font-weight: 600;
+  letter-spacing: -0.01em;
+}
+.module-blurb {
+  font-size: 0.88rem;
+  color: var(--muted);
+}
+.module-finishes li {
+  grid-template-columns: auto 1fr;
+  grid-template-rows: auto auto;
+  column-gap: 0.7rem;
+  align-items: center;
+}
+.module-swatch {
+  grid-row: 1 / 3;
+  width: 1.6rem;
+  height: 1.6rem;
+  border-radius: 50%;
+  border: 1px solid rgba(255, 255, 255, 0.22);
+  box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.4);
+}
+
+/* ---------- Specs list ---------- */
+.specs {
+  border-top: 1px solid var(--line);
+}
+.specs-head {
+  display: flex;
+  flex-direction: column;
+  gap: 0.8rem;
+  margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
+}
+.specs-list {
+  margin: 0;
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
+  gap: 0 clamp(2rem, 5vw, 4rem);
+}
+.specs-row {
+  display: flex;
+  justify-content: space-between;
+  gap: 1.5rem;
+  padding: 1rem 0;
+  border-bottom: 1px solid var(--line);
+}
+.specs-row dt {
+  color: var(--muted);
+  flex-shrink: 0;
+}
+.specs-row dd {
+  margin: 0;
+  text-align: right;
+  font-weight: 500;
+}
+
+/* ---------- Closing ---------- */
+.closing {
+  border-top: 1px solid var(--line);
+}
+.closing-inner {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  text-align: center;
+  gap: 1.3rem;
+  padding: clamp(2rem, 5vw, 3.5rem);
+  border-radius: 24px;
+  background:
+    radial-gradient(
+      80% 120% at 50% 0%,
+      rgba(255, 200, 144, 0.14),
+      transparent 65%
+    ),
+    var(--bg-soft);
+  border: 1px solid var(--line);
+}
+.closing .section-title {
+  max-width: 20ch;
+}
+
+/* ---------- Footer ---------- */
+.footer {
+  border-top: 1px solid var(--line);
+}
+.footer-inner {
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: 2rem clamp(1rem, 4vw, 2.5rem);
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  flex-wrap: wrap;
+  gap: 1rem;
+  color: var(--muted);
+}
+.footer-note {
+  font-size: 0.86rem;
+}
+
+/* ---------- Responsive ---------- */
+@media (min-width: 901px) {
+  .hero-stage {
+    position: sticky;
+    top: 88px;
+  }
+}
+
+@media (max-width: 900px) {
+  .hero {
+    grid-template-columns: 1fr;
+    min-height: 0;
+  }
+  .nav-links {
+    display: none;
+  }
+  .display {
+    font-size: clamp(2.6rem, 12vw, 3.6rem);
+  }
+}
+
+@media (max-width: 520px) {
+  .specs-row {
+    flex-direction: column;
+    gap: 0.25rem;
+  }
+  .specs-row dd {
+    text-align: left;
+  }
+  .buy {
+    flex-direction: column;
+    align-items: stretch;
+  }
+  .buy-btn {
+    width: 100%;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  * {
+    transition-duration: 0.001ms !important;
+  }
+}
