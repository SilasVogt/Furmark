+}
+
+.metric-cpu {
+  --bar-bg: #f5ce67;
+  --bar-edge: #775b09;
+  --bar-pattern:
+    repeating-linear-gradient(
+      45deg,
+      rgba(255, 255, 255, 0.42) 0 6px,
+      transparent 6px 12px
+    );
+}
+
+.metric-memory {
+  --bar-bg: #8ee5ce;
+  --bar-edge: #0a6255;
+  --bar-pattern:
+    radial-gradient(circle, rgba(255, 255, 255, 0.5) 0 2px, transparent 2px 9px);
+}
+
+.metric-latency {
+  --bar-bg: #8cb8ff;
+  --bar-edge: #173e83;
+  --bar-pattern:
+    repeating-linear-gradient(
+      0deg,
+      rgba(255, 255, 255, 0.36) 0 4px,
+      transparent 4px 12px
+    );
+}
+
+.metric-errors {
+  --bar-bg: #ff8f70;
+  --bar-edge: #7f250f;
+  --bar-pattern:
+    repeating-linear-gradient(
+      45deg,
+      rgba(255, 255, 255, 0.36) 0 4px,
+      transparent 4px 12px
+    ),
+    repeating-linear-gradient(
+      -45deg,
+      rgba(255, 255, 255, 0.3) 0 4px,
+      transparent 4px 12px
+    );
+}
+
+.metric-network {
+  --bar-bg: #c6ec75;
+  --bar-edge: #526b0e;
+  --bar-pattern:
+    repeating-linear-gradient(
+      90deg,
+      rgba(255, 255, 255, 0.38) 0 5px,
+      transparent 5px 13px
+    );
+}
+
+.feed-panel {
+  display: grid;
+  grid-template-rows: auto minmax(0, 1fr) auto;
+  min-height: 420px;
+}
+
+.feed-list {
+  display: grid;
+  align-content: start;
+  gap: 9px;
+  margin: 0;
+  padding: 14px;
+  overflow: auto;
+  list-style: none;
+}
+
+.feed-item,
+.empty-feed {
+  border: 1px solid rgba(255, 250, 241, 0.12);
+  border-radius: 8px;
+  background: rgba(255, 250, 241, 0.055);
+}
+
+.feed-item {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 10px;
+  align-items: center;
+  padding: 11px;
+}
+
+.feed-item .metric-shape {
+  width: 18px;
+  height: 18px;
+}
+
+.feed-item strong,
+.feed-item small {
+  display: block;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.feed-item strong {
+  color: #fffaf1;
+  font-size: 0.94rem;
+}
+
+.feed-item small {
+  margin-top: 2px;
+  color: #d8d1c3;
+  font-size: 0.78rem;
+}
+
+.empty-feed {
+  padding: 14px;
+  color: #d8d1c3;
+}
+
+.stats {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 1px;
+  margin: 0;
+  border-top: 1px solid rgba(255, 250, 241, 0.12);
+  background: rgba(255, 250, 241, 0.12);
+}
+
+.stats div {
+  min-width: 0;
+  padding: 12px;
+  background: #181817;
+}
+
+.stats dt,
+.stats dd {
+  margin: 0;
+}
+
+.stats dt {
+  color: #d8d1c3;
+  font-size: 0.72rem;
+  font-weight: 800;
+  text-transform: uppercase;
+}
+
+.stats dd {
+  margin-top: 5px;
+  color: #fffaf1;
+  font-size: 1.35rem;
+  font-weight: 850;
+}
+
+@media (max-width: 900px) {
+  .app-shell {
+    width: min(100% - 20px, 760px);
+    padding: 18px 0;
+  }
+
+  .topbar {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  h1 {
+    font-size: 2.1rem;
+  }
+
+  .control-group {
+    justify-content: stretch;
+  }
+
+  .control-button {
+    flex: 1 1 180px;
+  }
+
+  .dashboard {
+    grid-template-columns: 1fr;
+  }
+
+  .rain-stage {
+    height: 520px;
+  }
+
+  .feed-panel {
+    min-height: auto;
+  }
+}
+
+@media (max-width: 520px) {
+  .app-shell {
+    width: min(100% - 14px, 480px);
+  }
+
+  .panel-header {
+    padding: 0 10px;
+  }
+
+  .rain-stage {
+    height: 500px;
+    min-height: 500px;
+  }
+
+  .lane span {
+    font-size: 0.65rem;
+    padding: 3px 5px;
+  }
+
+  .metric-copy strong {
+    font-size: 0.78rem;
+  }
+
+  .metric-copy span {
+    font-size: 0.62rem;
+  }
+
+  .stats {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .metric-bar {
+    will-change: auto;
+  }
+}
