+// ponytail: iterative DFS over sorted neighbors so the reported cycle is
+// deterministic; only nodes actually on a cycle are returned, not the whole
+// stuck set (a dependent of a cyclic node is blocked but not on a cycle).
+function findCycle(nodes: Set<string>, graph: DependencyGraph): string[] {
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const n of nodes) color.set(n, WHITE);
+  const stack: string[] = [];
+
+  for (const root of [...nodes].sort()) {
+    if (color.get(root) !== WHITE) continue;
+    const work: [string, number][] = [[root, 0]];
+    color.set(root, GRAY);
+    stack.push(root);
+    while (work.length > 0) {
+      const [u, i] = work[work.length - 1];
+      const neighbors = (graph[u] ?? []).slice().sort();
+      if (i >= neighbors.length) {
+        color.set(u, BLACK);
+        stack.pop();
+        work.pop();
+        continue;
+      }
+      work[work.length - 1][1] = i + 1;
+      const v = neighbors[i];
+      const vc = color.get(v);
+      if (vc === GRAY) {
+        const idx = stack.indexOf(v);
+        return stack.slice(idx);
+      }
+      if (vc === WHITE) {
+        color.set(v, GRAY);
+        stack.push(v);
+        work.push([v, 0]);
+      }
+    }
+  }
+  return [...nodes].filter((n) => !color.get(n)).sort();
+}
