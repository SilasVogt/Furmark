+
+const clamp = (value: number, min: number, max: number) =>
+  Math.min(Math.max(value, min), max);
+
+const pulse = (progress: number, center: number, width = 0.15) =>
+  clamp(1 - Math.abs(progress - center) / width, 0, 1);
+
+const nearestStationId = (progress: number) =>
+  stations.reduce((nearest, station) =>
+    Math.abs(progress - station.center) < Math.abs(progress - nearest.center)
+      ? station
+      : nearest,
+  ).id;
+
 function App() {
-  return <main><h1>Furmark task workspace</h1></main>;
+  const stageRef = useRef<HTMLElement>(null);
+
+  useEffect(() => {
+    const stage = stageRef.current;
+
+    if (!stage) {
+      return;
+    }
+
+    const scene = stage.querySelector<HTMLElement>(".machine-scene");
+    const part = stage.querySelector<HTMLElement>(".part-carrier");
+    const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
+    let animationFrame = 0;
+
+    const setProgress = (progress: number) => {
+      const feedAction = pulse(progress, 0.04);
+      const pressAction = pulse(progress, 0.3, 0.16);
+      const rivetAction = pulse(progress, 0.52, 0.13);
+      const paintAction = pulse(progress, 0.72, 0.14);
+      const inspectAction = pulse(progress, 0.93, 0.13);
+      const sceneWidth = scene?.clientWidth ?? window.innerWidth;
+      const partWidth = part?.offsetWidth ?? 104;
+      const partTravel = Math.max(0, sceneWidth - partWidth - sceneWidth * 0.1);
+
+      stage.style.setProperty("--progress", progress.toFixed(4));
+      stage.style.setProperty("--progress-pct", `${(progress * 100).toFixed(2)}%`);
+      stage.style.setProperty("--belt-offset", `${(-220 * progress).toFixed(1)}px`);
+      stage.style.setProperty("--part-x", `${(partTravel * progress).toFixed(1)}px`);
+      stage.style.setProperty("--feed-action", feedAction.toFixed(3));
+      stage.style.setProperty("--feed-opacity", (0.35 + feedAction * 0.65).toFixed(3));
+      stage.style.setProperty("--feed-y", `${(-10 * feedAction).toFixed(1)}px`);
+      stage.style.setProperty("--press-action", pressAction.toFixed(3));
+      stage.style.setProperty("--press-y", `${(30 * pressAction).toFixed(1)}px`);
+      stage.style.setProperty("--rivet-action", rivetAction.toFixed(3));
+      stage.style.setProperty("--rivet-y", `${(24 * rivetAction).toFixed(1)}px`);
+      stage.style.setProperty("--paint-action", paintAction.toFixed(3));
+      stage.style.setProperty("--paint-scale", (0.12 + paintAction * 0.88).toFixed(3));
+      stage.style.setProperty("--heat-opacity", (0.2 + paintAction * 0.8).toFixed(3));
+      stage.style.setProperty("--inspect-action", inspectAction.toFixed(3));
+      stage.style.setProperty("--scan-width", `${(24 + inspectAction * 76).toFixed(1)}%`);
+      stage.dataset.active = nearestStationId(progress);
+    };
+
+    const calculateProgress = () => {
+      const stageTop = stage.getBoundingClientRect().top + window.scrollY;
+      const scrollLength = Math.max(1, stage.offsetHeight - window.innerHeight);
+
+      return clamp((window.scrollY - stageTop) / scrollLength, 0, 1);
+    };
+
+    const update = () => {
+      animationFrame = 0;
+
+      if (mediaQuery.matches) {
+        stage.dataset.motion = "reduced";
+        setProgress(1);
+        return;
+      }
+
+      stage.dataset.motion = "scroll";
+      setProgress(calculateProgress());
+    };
+
+    const scheduleUpdate = () => {
+      if (animationFrame) {
+        return;
+      }
+
+      animationFrame = window.requestAnimationFrame(update);
+    };
+
+    scheduleUpdate();
+    window.addEventListener("scroll", scheduleUpdate, { passive: true });
+    window.addEventListener("resize", scheduleUpdate);
+    mediaQuery.addEventListener("change", scheduleUpdate);
+
+    return () => {
+      if (animationFrame) {
+        window.cancelAnimationFrame(animationFrame);
+      }
+
+      window.removeEventListener("scroll", scheduleUpdate);
+      window.removeEventListener("resize", scheduleUpdate);
+      mediaQuery.removeEventListener("change", scheduleUpdate);
+    };
+  }, []);
+
+  return (
