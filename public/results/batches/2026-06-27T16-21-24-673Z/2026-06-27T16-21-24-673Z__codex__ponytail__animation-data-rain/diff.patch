-import React from "react";
+import React, { useCallback, useEffect, useRef, useState } from "react";
 import { createRoot } from "react-dom/client";
+import { Pause, Play } from "lucide-react";
 import "./style.css";
 
+type MetricKey = "cpu" | "memory" | "latency" | "errors";
+type BarState = "falling" | "stacked";
+
+type Bar = {
+  id: number;
+  kind: MetricKey;
+  lane: number;
+  value: number;
+  height: number;
+  y: number;
+  speed: number;
+  state: BarState;
+};
+
+const metrics: Record<MetricKey, { label: string; unit: string; className: string }> = {
+  cpu: { label: "CPU", unit: "%", className: "cpu" },
+  memory: { label: "Memory", unit: "%", className: "memory" },
+  latency: { label: "Latency", unit: "ms", className: "latency" },
+  errors: { label: "Errors", unit: "/min", className: "errors" },
+};
+
+const metricKeys = Object.keys(metrics) as MetricKey[];
+const gap = 6;
+const stageFallbackHeight = 420;
+
+function randomEvent(kind: MetricKey) {
+  if (kind === "latency") return Math.round(80 + Math.random() * 420);
+  if (kind === "errors") return Math.round(Math.random() * 18);
+  return Math.round(35 + Math.random() * 64);
+}
+
+function barHeight(kind: MetricKey, value: number) {
+  const max = kind === "latency" ? 500 : kind === "errors" ? 20 : 100;
+  return 30 + Math.round((Math.min(value, max) / max) * 84);
+}
+
 function App() {
-  return <main><h1>Furmark task workspace</h1></main>;
+  const [running, setRunning] = useState(true);
+  const [reduced, setReduced] = useState(() => window.matchMedia("(prefers-reduced-motion: reduce)").matches);
+  const [bars, setBars] = useState<Bar[]>([]);
+  const [feed, setFeed] = useState<string[]>([]);
+  const [frame, setFrame] = useState(0);
+  const stageRef = useRef<HTMLDivElement>(null);
+  const stackHeights = useRef([0, 0, 0, 0]);
+  const nextId = useRef(1);
+  const reducedRef = useRef(reduced);
+
+  useEffect(() => {
+    reducedRef.current = reduced;
+  }, [reduced]);
+
+  const spawnMetric = useCallback(() => {
+    const kind = metricKeys[Math.floor(Math.random() * metricKeys.length)];
+    const lane = metricKeys.indexOf(kind);
+    const value = randomEvent(kind);
+    const height = barHeight(kind, value);
+    const stageHeight = stageRef.current?.clientHeight || stageFallbackHeight;
+
+    setFeed((items) => [
+      `${metrics[kind].label} ${value}${metrics[kind].unit}`,
+      ...items.slice(0, 5),
+    ]);
+
+    setBars((current) => {
+      let next = current;
+      if (stackHeights.current[lane] > stageHeight * 0.74) {
+        stackHeights.current[lane] = 0;
+        next = current.filter((bar) => bar.lane !== lane || bar.state !== "stacked");
+      }
+
+      let y = -height;
+      let state: BarState = "falling";
+      if (reducedRef.current) {
+        y = Math.max(0, stageHeight - stackHeights.current[lane] - height);
+        stackHeights.current[lane] += height + gap;
+        state = "stacked";
+      }
+
+      return [
+        ...next,
+        {
+          id: nextId.current++,
+          kind,
+          lane,
+          value,
+          height,
+          y,
+          speed: 160 + Math.random() * 120,
+          state,
+        },
+      ];
+    });
+  }, []);
+
+  useEffect(() => {
+    for (let index = 0; index < 4; index += 1) spawnMetric();
+  }, [spawnMetric]);
+
+  useEffect(() => {
+    if (!running) return;
+    const interval = window.setInterval(spawnMetric, 820);
+    return () => window.clearInterval(interval);
+  }, [running, spawnMetric]);
+
+  useEffect(() => {
+    if (!reduced) return;
+    const stageHeight = stageRef.current?.clientHeight || stageFallbackHeight;
+
+    setBars((current) =>
+      current.map((bar) => {
+        if (bar.state === "stacked") return bar;
+        const y = Math.max(0, stageHeight - stackHeights.current[bar.lane] - bar.height);
+        stackHeights.current[bar.lane] += bar.height + gap;
+        return { ...bar, y, state: "stacked" };
+      }),
+    );
+  }, [reduced]);
+
+  useEffect(() => {
+    if (!running || reduced) return;
+
+    let raf = 0;
+    let previous = performance.now();
+
+    const tick = (time: number) => {
+      const dt = Math.min(40, time - previous) / 1000;
+      previous = time;
+      const stageHeight = stageRef.current?.clientHeight || stageFallbackHeight;
+
+      setBars((current) =>
+        current.map((bar) => {
+          if (bar.state === "stacked") return bar;
+
+          const y = bar.y + bar.speed * dt;
+          const stackTop = stageHeight - stackHeights.current[bar.lane];
+          if (y + bar.height >= stackTop) {
+            stackHeights.current[bar.lane] += bar.height + gap;
+            return { ...bar, y: Math.max(0, stackTop - bar.height), state: "stacked" };
+          }
+
+          return { ...bar, y };
+        }),
+      );
+
+      setFrame((value) => value + 1);
+      raf = requestAnimationFrame(tick);
+    };
+
+    raf = requestAnimationFrame(tick);
+    return () => cancelAnimationFrame(raf);
+  }, [running, reduced]);
+
+  return (
+    <main className="app">
+      <section className="toolbar" aria-label="Animation controls">
+        <div>
+          <h1>Metric Data Rain</h1>
+          <p>{running ? "Simulated feed live" : "Feed paused"} · frame {frame}</p>
+        </div>
+        <div className="controls">
+          <button type="button" onClick={() => setRunning((value) => !value)}>
+            {running ? <Pause size={18} aria-hidden="true" /> : <Play size={18} aria-hidden="true" />}
+            {running ? "Pause" : "Resume"}
+          </button>
+          <label className="switch">
+            <input
+              type="checkbox"
+              checked={reduced}
+              onChange={(event) => setReduced(event.target.checked)}
+            />
+            Reduced motion
+          </label>
+        </div>
+      </section>
+
+      <section className="dashboard">
+        <div className="stage" ref={stageRef} aria-label="Metric bars falling and stacking by lane">
+          {metricKeys.map((kind, lane) => (
+            <div className="lane" key={kind}>
+              <div className="lane-label">{metrics[kind].label}</div>
+              {bars
+                .filter((bar) => bar.lane === lane)
+                .map((bar) => (
+                  <div
+                    className={`bar ${metrics[bar.kind].className} ${bar.state}`}
+                    key={bar.id}
+                    style={{ height: bar.height, transform: `translateY(${bar.y}px)` }}
+                    aria-label={`${metrics[bar.kind].label} event ${bar.value}${metrics[bar.kind].unit}, ${bar.state}`}
+                  >
+                    <span className="mark" aria-hidden="true" />
+                    <strong>{metrics[bar.kind].label}</strong>
+                    <span>{bar.value}{metrics[bar.kind].unit}</span>
+                  </div>
+                ))}
+            </div>
+          ))}
+        </div>
+
+        <aside className="feed" aria-label="Recent metric feed">
+          <h2>Incoming events</h2>
+          <ol>
+            {feed.map((item, index) => (
+              <li key={`${item}-${index}`}>{item}</li>
+            ))}
+          </ol>
+        </aside>
+      </section>
+    </main>
+  );
 }
 
 createRoot(document.getElementById("root")!).render(<App />);
diff --git a/src/style.css b/src/style.css
index 6a6f6bd..f788598 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,253 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-width: 320px;
+  background: #f4f2ed;
+  color: #171717;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+}
+
+button,
+input {
+  font: inherit;
+}
+
+.app {
+  min-height: 100vh;
+  padding: clamp(16px, 3vw, 32px);
+}
+
+.toolbar {
+  align-items: center;
+  display: flex;
+  gap: 18px;
+  justify-content: space-between;
+  margin: 0 auto 18px;
+  max-width: 1180px;
+}
+
+h1,
+h2,
+p {
+  margin: 0;
+}
+
+h1 {
+  font-size: clamp(2rem, 4vw, 4.4rem);
+  line-height: 0.95;
+}
+
+.toolbar p {
+  color: #595751;
+  font-weight: 700;
+  margin-top: 8px;
+}
+
+.controls {
+  align-items: center;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+  justify-content: flex-end;
+}
+
+button,
+.switch {
+  align-items: center;
+  background: #171717;
+  border: 1px solid #171717;
+  border-radius: 8px;
+  color: #fff;
+  cursor: pointer;
+  display: inline-flex;
+  font-weight: 800;
+  gap: 8px;
+  min-height: 42px;
+  padding: 0 14px;
+}
+
+.switch {
+  background: #fff;
+  color: #171717;
+}
+
+.switch input {
+  accent-color: #171717;
+  inline-size: 18px;
+  block-size: 18px;
+}
+
+.dashboard {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: minmax(0, 1fr) 260px;
+  margin: 0 auto;
+  max-width: 1180px;
+}
+
+.stage {
+  background:
+    linear-gradient(#d8d4ca 1px, transparent 1px) 0 0 / 100% 25%,
+    #fcfbf7;
+  border: 2px solid #171717;
+  border-radius: 8px;
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  height: min(66vh, 570px);
+  min-height: 390px;
+  overflow: hidden;
+  position: relative;
+}
+
+.lane {
+  border-left: 1px solid #d8d4ca;
+  min-width: 0;
+  overflow: hidden;
+  position: relative;
+}
+
+.lane:first-child {
+  border-left: 0;
+}
+
+.lane-label {
+  background: rgba(255, 255, 255, 0.9);
+  border-bottom: 1px solid #d8d4ca;
+  color: #34332f;
+  font-size: 0.78rem;
+  font-weight: 900;
+  letter-spacing: 0;
+  padding: 8px 10px;
+  position: relative;
+  z-index: 2;
+}
+
+.bar {
+  align-items: center;
+  border: 2px solid #171717;
+  border-radius: 8px 8px 4px 4px;
+  box-shadow: 0 7px 0 rgba(0, 0, 0, 0.12);
+  display: grid;
+  gap: 3px;
+  grid-template-columns: 16px minmax(0, 1fr);
+  left: 9%;
+  padding: 7px;
+  position: absolute;
+  top: 0;
+  width: 82%;
+  will-change: transform;
+}
+
+.bar strong,
+.bar span:last-child {
+  font-size: clamp(0.64rem, 1.2vw, 0.8rem);
+  line-height: 1;
+  min-width: 0;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.bar span:last-child {
+  color: rgba(23, 23, 23, 0.74);
+  font-weight: 800;
+}
+
+.mark {
+  background: #171717;
+  display: block;
+  grid-row: 1 / 3;
+  height: 16px;
+  width: 16px;
+}
+
+.cpu {
+  background: #92d9ff;
+}
+
+.cpu .mark {
+  border-radius: 3px;
+}
+
+.memory {
+  background: #ffdc6f;
+}
+
+.memory .mark {
+  border-radius: 50%;
+}
+
+.latency {
+  background: repeating-linear-gradient(135deg, #ffa6a6 0 9px, #ffd0d0 9px 18px);
+}
+
+.latency .mark {
+  clip-path: polygon(50% 0, 100% 100%, 0 100%);
+}
+
+.errors {
+  background: #b8e986;
+}
+
+.errors .mark {
+  clip-path: polygon(50% 0, 61% 35%, 98% 35%, 68% 56%, 79% 91%, 50% 70%, 21% 91%, 32% 56%, 2% 35%, 39% 35%);
+}
+
+.stacked {
+  box-shadow: none;
+}
+
+.feed {
+  background: #171717;
+  border-radius: 8px;
+  color: #fff;
+  min-height: 260px;
+  padding: 16px;
+}
+
+.feed h2 {
+  font-size: 1rem;
+  margin-bottom: 12px;
+}
+
+.feed ol {
+  display: grid;
+  gap: 10px;
+  list-style: decimal-leading-zero;
+  margin: 0;
+  padding-left: 28px;
+}
+
+.feed li {
+  color: #f4f2ed;
+  font-weight: 800;
+}
+
+@media (max-width: 820px) {
+  .toolbar,
+  .dashboard {
+    grid-template-columns: 1fr;
+  }
+
+  .toolbar {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .controls {
+    justify-content: flex-start;
+  }
+
+  .stage {
+    min-height: 430px;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .bar {
+    transition: none;
+  }
+}
