+  top: 34%;
+  height: 32%;
+  opacity: var(--cut-done);
+  background: #313a40;
+  border-radius: 999px;
+}
+
+.part-hole {
+  top: 50%;
+  width: 14%;
+  aspect-ratio: 1;
+  opacity: var(--drill-done);
+  transform: translateY(-50%);
+  background: #edf2f4;
+  border: 2px solid #313a40;
+  border-radius: 50%;
+}
+
+.part-hole-left {
+  left: 10%;
+}
+
+.part-hole-right {
+  right: 10%;
+}
+
+.part-coat {
+  inset: 0;
+  opacity: var(--paint-done);
+  mix-blend-mode: multiply;
+  background: linear-gradient(135deg, #2db1a0, #65d4c7);
+  border: 2px solid #1d6e66;
+  border-radius: 8px;
+}
+
+.part-box {
+  inset: -10px -8px -8px;
+  opacity: var(--pack-done);
+  background:
+    linear-gradient(90deg, transparent 0 44%, rgba(23, 27, 31, 0.18) 44% 48%, transparent 48%),
+    rgba(244, 184, 70, 0.58);
+  border: 2px solid #9f6c17;
+  border-radius: 6px;
+}
+
+.static-parts {
+  display: none;
+}
+
+.stage-list {
+  display: grid;
+  gap: 10px;
+  margin: 0;
+  padding: 0;
+  list-style: none;
+}
+
+.stage-card {
+  display: grid;
+  grid-template-columns: 48px minmax(0, 1fr);
+  gap: 12px;
+  align-items: start;
+  min-height: 94px;
+  padding: 14px;
+  color: #171b1f;
+  background: rgba(248, 251, 252, 0.82);
+  border: 1px solid #b7c2c8;
+  border-left: 5px solid #8a989f;
+  border-radius: 8px;
+  opacity: 0.58;
+  transform: translateX(0);
+  transition:
+    opacity 160ms ease,
+    transform 160ms ease,
+    border-color 160ms ease,
+    background-color 160ms ease;
+}
+
+.stage-card > span {
+  display: grid;
+  place-items: center;
+  width: 38px;
+  height: 32px;
+  color: #f8fbfc;
+  font-size: 0.82rem;
+  font-weight: 900;
+  background: #171b1f;
+  border-radius: 5px;
+}
+
+.stage-card p {
+  font-size: 0.92rem;
+  line-height: 1.45;
+}
+
+.factory-scroll[data-phase="0"] .stage-card:nth-child(1),
+.factory-scroll[data-phase="1"] .stage-card:nth-child(2),
+.factory-scroll[data-phase="2"] .stage-card:nth-child(3),
+.factory-scroll[data-phase="3"] .stage-card:nth-child(4),
+.factory-scroll[data-phase="4"] .stage-card:nth-child(5),
+.factory-scroll[data-phase="all"] .stage-card {
+  opacity: 1;
+  transform: translateX(-6px);
+  background: #ffffff;
+  border-left-color: #d3543f;
+}
+
+.factory-scroll[data-phase="2"] .stage-card:nth-child(3),
+.factory-scroll[data-phase="3"] .stage-card:nth-child(4) {
+  border-left-color: #2db1a0;
+}
+
+.factory-scroll[data-phase="4"] .stage-card:nth-child(5),
+.factory-scroll[data-phase="all"] .stage-card {
+  border-left-color: #f4b846;
+}
+
+.process-map {
+  padding: clamp(42px, 8vw, 110px) clamp(20px, 6vw, 80px);
+  background: #f8fbfc;
+}
+
+.process-map > p {
+  max-width: 720px;
+  margin-bottom: 28px;
+  font-size: 1.05rem;
+}
+
+.process-map .stage-list {
+  grid-template-columns: repeat(5, minmax(0, 1fr));
+}
+
+.process-map .stage-card {
+  min-height: 160px;
+  opacity: 1;
+  transform: none;
+}
+
+@media (max-width: 900px) {
+  .intro {
+    min-height: 64svh;
+  }
+
+  .factory-scroll {
+    height: 390vh;
+  }
+
+  .factory-stage {
+    align-items: start;
+    padding-top: 18px;
+  }
+
+  .factory-grid {
+    grid-template-columns: 1fr;
+    gap: 14px;
+  }
+
+  .machine {
+    min-height: clamp(330px, 68vw, 480px);
+  }
+
+  .factory-grid > .stage-list {
+    grid-template-columns: repeat(5, minmax(112px, 1fr));
+    gap: 8px;
+  }
+
+  .factory-grid .stage-card {
+    grid-template-columns: 1fr;
+    min-height: 118px;
+    padding: 10px;
+  }
+
+  .factory-grid .stage-card p {
+    font-size: 0.82rem;
+    line-height: 1.35;
+  }
+
+  .process-map .stage-list {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 620px) {
+  .intro {
+    min-height: 58svh;
+    padding: 28px 18px;
+  }
+
+  .intro p {
+    font-size: 1rem;
+  }
+
+  .factory-scroll {
+    height: 360vh;
+  }
+
+  .factory-stage {
+    min-height: 100svh;
+    padding: 10px;
+  }
+
+  .machine-hud {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .hud-meter {
+    width: 100%;
+    flex-basis: auto;
+  }
+
+  .machine {
+    min-height: 340px;
+  }
+
+  .station-step {
+    top: -32px;
+    width: 34px;
+    height: 22px;
+    font-size: 0.7rem;
+  }
+
+  .station-tool {
+    width: 48px;
+  }
+
+  .tool-head {
+    height: 36px;
+    min-width: 34px;
+  }
+
+  .tool-head span {
+    width: 15px;
+  }
+
+  .station-paint .tool-head span,
+  .station-pack .tool-head span {
+    width: 34px;
+  }
+
+  .carrier {
+    width: 78px;
+    height: 62px;
+  }
+
+  .factory-grid > .stage-list {
+    grid-template-columns: repeat(5, minmax(92px, 1fr));
+  }
+
+  .factory-grid .stage-card {
+    min-height: 96px;
+  }
+
+  .factory-grid .stage-card p {
+    display: none;
+  }
+
+  .process-map {
+    padding: 44px 16px;
+  }
+
+  .process-map .stage-list {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    transition-duration: 0.001ms !important;
+    animation-duration: 0.001ms !important;
+    animation-iteration-count: 1 !important;
+  }
+
+  .factory-scroll {
+    height: auto;
+  }
+
+  .factory-stage {
+    position: static;
+    min-height: auto;
+  }
+
+  .factory-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .carrier {
+    display: none;
+  }
+
+  .static-parts {
+    position: absolute;
+    inset: 0;
+    display: block;
+  }
+
+  .static-part {
+    position: absolute;
+    left: var(--station-x);
+    bottom: calc(20% + clamp(72px, 12vw, 112px) + 6px);
+    width: clamp(42px, 7vw, 74px);
+    height: 42px;
+    transform: translateX(-50%);
+  }
+
+  .part-small {
+    width: 100%;
+  }
+
+  .part-small .part-slot,
+  .part-small .part-hole,
+  .part-small .part-coat {
+    opacity: 1;
+  }
+
+  .part-small .part-box {
+    opacity: 0.45;
+  }
+
+  .spark-field,
+  .spray-field {
+    display: none;
+  }
+
+  .factory-scroll .stage-card {
+    opacity: 1;
+    transform: none;
+  }
+}
