+function shouldMerge(last: Interval, interval: Interval, mergeTouching: boolean): boolean {
+  if (last.start === interval.start && last.end === interval.end) return true;
+  if (interval.start < last.end) return true;
+  if (!mergeTouching) return false;
+  return interval.start === last.end || areAdjacentIntegers(last.end, interval.start);
 }
 
+function areAdjacentIntegers(left: number, right: number): boolean {
+  return Number.isInteger(left) && Number.isInteger(right) && right === left + 1;
+}
+
+function normalizeInterval(interval: Interval, index: number): Interval {
+  const value = interval as Partial<Record<keyof Interval, unknown>> | null;
+  if (value === null || typeof value !== "object") {
+    throw new Error(`Interval ${index} must be an object with start and end`);
+  }
+
+  const { start, end } = value;
+  assertFiniteNumber(start, `Interval ${index} start`);
+  assertFiniteNumber(end, `Interval ${index} end`);
+  return start <= end ? { start, end } : { start: end, end: start };
+}
+
+function assertFiniteNumber(value: unknown, label: string): asserts value is number {
+  if (typeof value !== "number" || !Number.isFinite(value)) {
+    throw new Error(`${label} must be a finite number`);
+  }
+}
