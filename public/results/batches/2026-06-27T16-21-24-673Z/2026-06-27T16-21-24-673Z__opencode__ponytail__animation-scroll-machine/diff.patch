--- a/src/main.tsx
+++ b/src/main.tsx
@@ -1,9 +1,197 @@
-import React from "react";
+import { useEffect, useRef, useState } from "react";
 import { createRoot } from "react-dom/client";
+import {
+  Frame,
+  Cog,
+  CircleDot,
+  Paintbrush,
+  CheckCircle2,
+  type LucideIcon,
+} from "lucide-react";
 import "./style.css";
 
+type Station = {
+  name: string;
+  desc: string;
+  icon: LucideIcon;
+  tint: string;
+};
+
+const STATIONS: Station[] = [
+  { name: "Frame", desc: "Bare chassis is loaded onto the conveyor.", icon: Frame, tint: "#94a3b8" },
+  { name: "Gears", desc: "Transmission gears are seated into the housing.", icon: Cog, tint: "#f59e0b" },
+  { name: "Wheels", desc: "Axles and wheels are pressed onto the hubs.", icon: CircleDot, tint: "#0ea5e9" },
+  { name: "Paint", desc: "Body is painted, baked, and cured.", icon: Paintbrush, tint: "#ec4899" },
+  { name: "QA", desc: "Final inspection, then shipped to dispatch.", icon: CheckCircle2, tint: "#22c55e" },
+];
+
+function usePrefersReducedMotion() {
+  const [reduced, setReduced] = useState(
+    () =>
+      typeof matchMedia !== "undefined" &&
+      matchMedia("(prefers-reduced-motion: reduce)").matches,
+  );
+  useEffect(() => {
+    const mq = matchMedia("(prefers-reduced-motion: reduce)");
+    const handler = () => setReduced(mq.matches);
+    mq.addEventListener("change", handler);
+    return () => mq.removeEventListener("change", handler);
+  }, []);
+  return reduced;
+}
+
+function AssemblyLine() {
+  const stageRef = useRef<HTMLDivElement>(null);
+  const partRef = useRef<HTMLDivElement>(null);
+  const fillRef = useRef<HTMLDivElement>(null);
+  const nameRef = useRef<HTMLSpanElement>(null);
+  const descRef = useRef<HTMLParagraphElement>(null);
+  const stationRefs = useRef<Array<HTMLLIElement | null>>([]);
+  const layerRefs = useRef<Array<HTMLDivElement | null>>([]);
+
+  useEffect(() => {
+    let raf = 0;
+    const update = () => {
+      const doc = document.documentElement;
+      const max = doc.scrollHeight - window.innerHeight;
+      const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
+
+      const track = stageRef.current;
+      const part = partRef.current;
+      if (track && part) {
+        const x = p * (track.clientWidth - part.offsetWidth);
+        part.style.transform = `translateX(${x}px)`;
+      }
+      if (fillRef.current) fillRef.current.style.width = `${p * 100}%`;
+
+      const idx = Math.min(
+        STATIONS.length - 1,
+        Math.max(0, Math.floor(p * STATIONS.length)),
+      );
+      stationRefs.current.forEach((el, i) =>
+        el?.classList.toggle("is-active", i === idx),
+      );
+      layerRefs.current.forEach((el, i) => {
+        if (el) el.style.opacity = i <= idx ? "1" : "0";
+      });
+      const s = STATIONS[idx];
+      if (nameRef.current) nameRef.current.textContent = s.name;
+      if (descRef.current) descRef.current.textContent = s.desc;
+    };
+    const onScroll = () => {
+      cancelAnimationFrame(raf);
+      raf = requestAnimationFrame(update);
+    };
+    update();
+    window.addEventListener("scroll", onScroll, { passive: true });
+    window.addEventListener("resize", onScroll);
+    return () => {
+      cancelAnimationFrame(raf);
+      window.removeEventListener("scroll", onScroll);
+      window.removeEventListener("resize", onScroll);
+    };
+  }, []);
+
+  return (
+    <>
+      <div className="stage-wrap">
+        <header className="stage-head">
+          <h1>Assembly Line&nbsp;MK&#8209;V</h1>
+          <p>Scroll to drive the build.</p>
+        </header>
+
+        <div className="stage" ref={stageRef}>
+          <ol className="stations">
+            {STATIONS.map((s, i) => {
+              const Icon = s.icon;
+              return (
+                <li
+                  key={s.name}
+                  className="station"
+                  style={{ left: `calc((100% - 3rem) * ${i / (STATIONS.length - 1)} + 1.5rem)`, "--tint": s.tint } as React.CSSProperties}
+                  ref={(el) => {
+                    stationRefs.current[i] = el;
+                  }}
+                >
+                  <span className="station-icon">
+                    <Icon size={22} strokeWidth={2} />
+                  </span>
+                  <span className="station-name">{s.name}</span>
+                </li>
+              );
+            })}
+          </ol>
+
+          <div className="belt">
+            <div className="belt-surface" />
+            <div className="part" ref={partRef} aria-label="Workpiece moving through stations">
+              <div className="layer layer-frame" ref={(el) => { layerRefs.current[0] = el; }} />
+              <div className="layer layer-gears" ref={(el) => { layerRefs.current[1] = el; }} />
+              <div className="layer layer-wheels" ref={(el) => { layerRefs.current[2] = el; }} />
+              <div className="layer layer-paint" ref={(el) => { layerRefs.current[3] = el; }} />
+              <div className="layer layer-qa" ref={(el) => { layerRefs.current[4] = el; }} />
+            </div>
+          </div>
+
+          <div className="rail">
+            <div className="rail-fill" ref={fillRef} />
+          </div>
+        </div>
+
+        <div className="readout">
+          <div className="readout-row">
+            <span className="readout-k">Now building&nbsp;/</span>
+            <span className="readout-v" ref={nameRef}>Frame</span>
+          </div>
+          <p className="readout-desc" ref={descRef}>
+            Bare chassis is loaded onto the conveyor.
+          </p>
+        </div>
+      </div>
+
+      {/* scroll spacer gives the wheel room to drive progress 0 -> 1 */}
+      <div className="scroll-spacer" aria-hidden="true" />
+    </>
+  );
+}
+
+function StaticWalkthrough() {
+  return (
+    <main className="static">
+      <header className="static-head">
+        <h1>Assembly Line&nbsp;MK&#8209;V</h1>
+        <p>
+          Reduced-motion mode: the same five stations, in order, without
+          scroll-driven motion.
+        </p>
+      </header>
+      <ol className="timeline">
+        {STATIONS.map((s, i) => {
+          const Icon = s.icon;
+          return (
+            <li key={s.name} className="timeline-item">
+              <span className="timeline-num">{i + 1}</span>
+              <span className="timeline-icon" style={{ color: s.tint }}>
+                <Icon size={28} strokeWidth={2} />
+              </span>
+              <div>
+                <h2>{s.name}</h2>
+                <p>{s.desc}</p>
+              </div>
+            </li>
+          );
+        })}
+      </ol>
+      <footer className="static-foot">
+        <CheckCircle2 size={20} /> Product complete &mdash; shipped.
+      </footer>
+    </main>
+  );
+}
+
 function App() {
-  return <main><h1>Furmark task workspace</h1></main>;
+  const reduced = usePrefersReducedMotion();
+  return reduced ? <StaticWalkthrough /> : <AssemblyLine />;
 }
 
 createRoot(document.getElementById("root")!).render(<App />);
diff --git a/src/style.css b/src/style.css
index 6a6f6bd..affc82b 100644
--- a/src/style.css
+++ b/src/style.css
@@ -1 +1,318 @@
-body { margin: 0; font-family: system-ui, sans-serif; }
+:root {
+  --bg: #0b1020;
+  --panel: #131a2e;
+  --ink: #e6ecff;
+  --muted: #8a96c0;
+  --line: #283150;
+  --accent: #38bdf8;
+}
+
+* { box-sizing: border-box; }
+html, body { margin: 0; }
+body {
+  background: var(--bg);
+  color: var(--ink);
+  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
+  -webkit-font-smoothing: antialiased;
+}
+
+/* ===== Animated (scroll-driven) view ===== */
+
+.stage-wrap {
+  position: fixed;
+  inset: 0 0 auto 0;
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+  gap: 1.25rem;
+  padding: clamp(1rem, 3vw, 2.5rem);
+  max-width: 1100px;
+  margin: 0 auto;
+  height: 100vh;
+  pointer-events: none;
+}
+
+.stage-head h1 {
+  margin: 0;
+  font-size: clamp(1.4rem, 3.5vw, 2.2rem);
+  letter-spacing: 0.02em;
+}
+.stage-head p {
+  margin: 0.25rem 0 0;
+  color: var(--muted);
+  font-size: clamp(0.85rem, 1.6vw, 1rem);
+}
+
+.stage {
+  position: relative;
+  padding: 2.5rem 0 0;
+}
+
+.stations {
+  position: relative;
+  list-style: none;
+  margin: 0 0 1rem;
+  padding: 0;
+  height: 3.25rem;
+}
+.station {
+  position: absolute;
+  top: 0;
+  transform: translateX(-50%);
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 0.25rem;
+  color: var(--muted);
+  transition: color 0.25s ease, transform 0.25s ease;
+}
+.station-icon {
+  display: grid;
+  place-items: center;
+  width: 2.5rem;
+  height: 2.5rem;
+  border-radius: 50%;
+  background: var(--panel);
+  border: 2px solid var(--line);
+  color: var(--muted);
+  transition: border-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
+}
+.station-name {
+  font-size: 0.75rem;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+}
+.station.is-active {
+  color: var(--ink);
+}
+.station.is-active .station-icon {
+  color: var(--tint, var(--accent));
+  border-color: var(--tint, var(--accent));
+  box-shadow: 0 0 0 4px color-mix(in srgb, var(--tint, var(--accent)) 22%, transparent);
+}
+
+.belt {
+  position: relative;
+  height: 70px;
+  border-radius: 10px;
+  background: #0a0f1f;
+  border: 1px solid var(--line);
+  overflow: hidden;
+}
+.belt-surface {
+  position: absolute;
+  inset: 12px 0;
+  background-image: repeating-linear-gradient(
+    115deg,
+    #1c2746 0 14px,
+    #232f55 14px 28px
+  );
+  background-size: 40px 100%;
+  animation: belt-move 1.1s linear infinite;
+}
+@keyframes belt-move {
+  to { background-position: 40px 0; }
+}
+@media (prefers-reduced-motion: reduce) {
+  .belt-surface { animation: none; }
+}
+
+.part {
+  position: absolute;
+  top: 10px;
+  left: 0;
+  width: 64px;
+  height: 50px;
+  will-change: transform;
+}
+.layer {
+  position: absolute;
+  inset: 0;
+  transition: opacity 0.3s ease;
+  opacity: 0;
+}
+.layer-frame {
+  opacity: 1; /* base, always visible */
+  background: linear-gradient(#64748b, #475569);
+  border-radius: 8px;
+  border: 1px solid #334155;
+}
+.layer-gears::before,
+.layer-gears::after {
+  content: "";
+  position: absolute;
+  border-radius: 50%;
+  background: radial-gradient(circle, #f59e0b 30%, #b45309 31%, #f59e0b 45%, #b45309 46%);
+  background-size: 8px 8px;
+}
+.layer-gears::before { width: 20px; height: 20px; top: 10px; left: 12px; }
+.layer-gears::after  { width: 14px; height: 14px; top: 18px; left: 34px; }
+
+.layer-wheels::before,
+.layer-wheels::after {
+  content: "";
+  position: absolute;
+  bottom: -6px;
+  width: 16px;
+  height: 16px;
+  border-radius: 50%;
+  background: #0f172a;
+  border: 3px solid #475569;
+}
+.layer-wheels::before { left: 6px; }
+.layer-wheels::after  { right: 6px; }
+
+.layer-paint {
+  background: linear-gradient(135deg, #ec4899, #8b5cf6);
+  border-radius: 8px;
+  mix-blend-mode: screen;
+  opacity: 0; /* set by JS; keep base blend ready */
+}
+
+.layer-qa::after {
+  content: "\2713";
+  position: absolute;
+  top: -10px;
+  right: -10px;
+  width: 22px;
+  height: 22px;
+  display: grid;
+  place-items: center;
+  font-size: 13px;
+  font-weight: 700;
+  color: #052e16;
+  background: #22c55e;
+  border-radius: 50%;
+  border: 2px solid #052e16;
+}
+
+.rail {
+  margin-top: 1.25rem;
+  height: 6px;
+  border-radius: 99px;
+  background: var(--line);
+  overflow: hidden;
+}
+.rail-fill {
+  height: 100%;
+  width: 0;
+  background: linear-gradient(90deg, var(--accent), #818cf8);
+}
+
+.readout {
+  margin-top: 0.5rem;
+  padding: 0.75rem 1rem;
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 10px;
+}
+.readout-row {
+  display: flex;
+  gap: 0.5rem;
+  align-items: baseline;
+}
+.readout-k {
+  color: var(--muted);
+  font-size: 0.8rem;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+}
+.readout-v {
+  font-size: 1.1rem;
+  font-weight: 600;
+  color: var(--accent);
+}
+.readout-desc {
+  margin: 0.35rem 0 0;
+  color: var(--ink);
+  font-size: 0.95rem;
+  line-height: 1.4;
+}
+
+.scroll-spacer {
+  height: 420vh;
+}
+
+/* ===== Reduced-motion static view ===== */
+
+.static {
+  max-width: 720px;
+  margin: 0 auto;
+  padding: clamp(1.5rem, 5vw, 3rem) clamp(1rem, 4vw, 2rem) 4rem;
+}
+.static-head h1 {
+  margin: 0 0 0.35rem;
+  font-size: clamp(1.5rem, 4vw, 2.2rem);
+}
+.static-head p {
+  margin: 0 0 2rem;
+  color: var(--muted);
+  line-height: 1.5;
+}
+.timeline {
+  list-style: none;
+  margin: 0;
+  padding: 0;
+  display: grid;
+  gap: 1rem;
+}
+.timeline-item {
+  display: grid;
+  grid-template-columns: auto auto 1fr;
+  align-items: center;
+  gap: 1rem;
+  padding: 1rem 1.1rem;
+  background: var(--panel);
+  border: 1px solid var(--line);
+  border-radius: 12px;
+}
+.timeline-num {
+  font-variant-numeric: tabular-nums;
+  font-weight: 700;
+  color: var(--muted);
+}
+.timeline-icon {
+  display: grid;
+  place-items: center;
+  width: 2.75rem;
+  height: 2.75rem;
+  border-radius: 10px;
+  background: color-mix(in srgb, currentColor 12%, var(--panel));
+}
+.timeline-item h2 {
+  margin: 0 0 0.2rem;
+  font-size: 1.05rem;
+}
+.timeline-item p {
+  margin: 0;
+  color: var(--muted);
+  line-height: 1.45;
+}
+.static-foot {
+  margin-top: 2rem;
+  display: flex;
+  align-items: center;
+  gap: 0.5rem;
+  padding: 1rem 1.1rem;
+  border-radius: 12px;
+  background: color-mix(in srgb, #22c55e 16%, var(--panel));
+  border: 1px solid color-mix(in srgb, #22c55e 45%, var(--line));
+  color: #bbf7d0;
+  font-weight: 600;
+}
+
+/* ===== Mobile ===== */
+@media (max-width: 560px) {
+  .station-name { display: none; }
+  .station-icon { width: 2rem; height: 2rem; }
+  .belt { height: 60px; }
+  .part { width: 54px; height: 44px; }
+  .stage { padding-top: 1.75rem; }
+  .readout-desc { font-size: 0.9rem; }
+  .timeline-item {
+    grid-template-columns: auto 1fr;
+  }
+  .timeline-icon { grid-column: 1; }
+  .timeline-item h2,
+  .timeline-item p { grid-column: 2; }
+}
