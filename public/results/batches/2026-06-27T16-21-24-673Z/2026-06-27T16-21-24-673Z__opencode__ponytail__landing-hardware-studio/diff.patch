+}
+
+/* ---------- configurator ---------- */
+.config {
+  border-top: 1px solid var(--line);
+  background: linear-gradient(180deg, var(--bg-2), var(--bg));
+  padding: clamp(56px, 9vh, 96px) 0;
+}
+
+.config__grid {
+  display: grid;
+  grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
+  gap: 56px;
+  max-width: var(--maxw);
+  margin: 0 auto;
+  padding: 0 24px;
+}
+
+.config__controls {
+  display: flex;
+  flex-direction: column;
+  gap: 26px;
+  min-width: 0;
+}
+
+.seg {
+  border: none;
+  margin: 0;
+  padding: 0;
+  min-width: 0;
+}
+
+.seg legend {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  width: 100%;
+  margin-bottom: 12px;
+  font-size: 13px;
+  font-weight: 600;
+  color: var(--text);
+}
+
+.seg__value {
+  font-variant-numeric: tabular-nums;
+  font-weight: 700;
+}
+
+.seg__row {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 8px;
+}
+
+.seg__btn {
+  display: flex;
+  flex-direction: column;
+  align-items: flex-start;
+  gap: 4px;
+  padding: 14px 14px;
+  border-radius: var(--radius);
+  border: 1px solid var(--line);
+  background: var(--panel);
+  color: var(--text);
+  text-align: left;
+  cursor: pointer;
+  transition: border-color 0.15s ease, background 0.15s ease;
+  min-width: 0;
+}
+
+.seg__btn:hover {
+  border-color: var(--line-strong);
+}
+
+.seg__btn.is-active {
+  border-color: var(--accent);
+  background: var(--accent-soft);
+  box-shadow: inset 0 0 0 1px var(--accent);
+}
+
+.seg__swatch {
+  width: 22px;
+  height: 22px;
+  border-radius: 6px;
+  margin-bottom: 6px;
+  display: block;
+}
+
+.seg__label {
+  font-size: 14px;
+  font-weight: 600;
+}
+
+.seg__note {
+  font-size: 11px;
+  color: var(--muted);
+  letter-spacing: 0.02em;
+}
+
+/* range */
+.temp {
+  -webkit-appearance: none;
+  appearance: none;
+  width: 100%;
+  height: 6px;
+  border-radius: 999px;
+  background: linear-gradient(90deg, #ffb347, #ffe6c2 38%, #ffffff 55%, #c8e0ff);
+  outline: none;
+  margin: 6px 0 10px;
+}
+
+.temp::-webkit-slider-thumb {
+  -webkit-appearance: none;
+  appearance: none;
+  width: 22px;
+  height: 22px;
+  border-radius: 50%;
+  background: var(--text);
+  border: 3px solid var(--bg);
+  box-shadow: 0 0 0 1px var(--line-strong);
+  cursor: pointer;
+}
+
+.temp::-moz-range-thumb {
+  width: 22px;
+  height: 22px;
+  border-radius: 50%;
+  background: var(--text);
+  border: 3px solid var(--bg);
+  box-shadow: 0 0 0 1px var(--line-strong);
+  cursor: pointer;
+}
+
+.temp:focus-visible {
+  outline: 2px solid var(--accent);
+  outline-offset: 4px;
+}
+
+.temp__scale {
+  display: flex;
+  justify-content: space-between;
+  font-size: 11px;
+  color: var(--muted-2);
+  letter-spacing: 0.04em;
+}
+
+.config__buy {
+  margin-top: 6px;
+  padding-top: 22px;
+  border-top: 1px solid var(--line);
+}
+
+.config__total {
+  display: flex;
+  align-items: baseline;
+  justify-content: space-between;
+  margin-bottom: 14px;
+}
+
+.config__total span {
+  color: var(--muted);
+  font-size: 13px;
+}
+
+.config__total strong {
+  font-size: 30px;
+  font-weight: 600;
+  letter-spacing: -0.02em;
+}
+
+.config__fine {
+  margin: 12px 0 0;
+  font-size: 12px;
+  color: var(--muted-2);
+  text-align: center;
+}
+
+/* ---------- specs ---------- */
+.specs {
+  border-top: 1px solid var(--line);
+  padding: clamp(64px, 10vh, 112px) 0;
+}
+
+.specs__grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 1px;
+  background: var(--line);
+  border: 1px solid var(--line);
+  border-radius: var(--radius);
+  overflow: hidden;
+  max-width: var(--maxw);
+  margin: 0 auto;
+}
+
+.spec {
+  background: var(--bg);
+  padding: 30px 26px;
+  min-width: 0;
+}
+
+.spec dt {
+  font-size: 11px;
+  letter-spacing: 0.18em;
+  text-transform: uppercase;
+  color: var(--muted);
+  margin-bottom: 16px;
+}
+
+.spec dd {
+  margin: 0;
+  display: flex;
+  align-items: baseline;
+  gap: 8px;
+  flex-wrap: wrap;
+}
+
+.spec__value {
+  font-size: clamp(30px, 3.4vw, 40px);
+  font-weight: 600;
+  letter-spacing: -0.02em;
+  font-variant-numeric: tabular-nums;
+}
+
+.spec__unit {
+  font-size: 13px;
+  color: var(--muted);
+}
+
+/* ---------- footer ---------- */
+.foot {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  flex-wrap: wrap;
+  padding: 32px 24px;
+  max-width: var(--maxw);
+  margin: 0 auto;
+  border-top: 1px solid var(--line);
+  font-size: 12px;
+  color: var(--muted-2);
+  letter-spacing: 0.04em;
+}
+
+.foot span:first-child {
+  font-weight: 700;
+  letter-spacing: 0.3em;
+  color: var(--text);
+}
+
+/* ---------- responsive ---------- */
+@media (max-width: 880px) {
+  .hero {
+    grid-template-columns: 1fr;
+    gap: 32px;
+    padding-top: 40px;
+    min-height: auto;
+  }
+  .hero__stage {
+    order: -1;
+  }
+  .config__grid {
+    grid-template-columns: 1fr;
+    gap: 36px;
+  }
+  .specs__grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+  .nav__links {
+    gap: 16px;
+  }
+  .nav__links a:not(.nav__buy) {
+    display: none;
+  }
+}
+
+@media (max-width: 520px) {
+  .seg__row {
+    grid-template-columns: 1fr;
+  }
+  .specs__grid {
+    grid-template-columns: 1fr;
+  }
+  .hero__cta .btn {
+    flex: 1 1 auto;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  * {
+    transition: none !important;
+  }
+}
